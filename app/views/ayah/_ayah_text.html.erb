<%= turbo_frame_tag :ayah_text do %>
  <%
    script = @presenter.script
    font_class = get_quran_script_font_family(script, @ayah) || 'qpc-hafs'
  %>

   <div class="flex items-start justify-between gap-4 flex-wrap" data-controller="ayah-script-selector">
     <div class="flex items-center gap-2">
       <span class="inline-flex items-center px-2 py-1 rounded bg-gray-100 text-gray-700 text-xs"><%= @presenter.script_label %></span>
     </div>

    <button type="button"
            class="px-3 py-1.5 bg-white text-gray-900 rounded text-sm border border-gray-200 hover:bg-gray-50"
            data-action="click->ayah-script-selector#open">
      Change script
    </button>

    <div class="hidden fixed inset-0 bg-black/40 z-[10000]" data-ayah-script-selector-target="backdrop" data-action="click->ayah-script-selector#close"></div>
    <div class="hidden fixed top-0 right-0 h-full w-[420px] max-w-[90vw] bg-white border-l border-gray-200 z-[10001] flex-col" data-ayah-script-selector-target="panel">
      <div class="p-4 border-b border-gray-200 flex items-center justify-between">
        <div class="font-semibold text-gray-900">Select script</div>
        <button type="button" class="text-gray-500 hover:text-gray-900" data-action="click->ayah-script-selector#close">
          <i class="fa fa-times"></i>
        </button>
      </div>
      <div class="p-4 overflow-y-auto flex-1">
        <%= form_with url: ayah_text_path(@ayah.verse_key), method: :get, local: true, data: { turbo_frame: :ayah_text }, html: { data: { ayah_script_selector_target: "form" } } do %>
          <div class="space-y-2">
            <% @presenter.scripts.each do |value, label| %>
              <label class="flex items-start gap-2 text-sm text-gray-800">
                <%= radio_button_tag "script", value, script == value, data: { action: "change->ayah-script-selector#change" } %>
                <span><%= label %></span>
              </label>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mt-4 bg-white border border-gray-200 rounded p-5 flex justify-center">
    <% if script == 'image' %>
      <img class="max-w-full h-auto" alt="<%= @ayah.verse_key %>" src="<%= @ayah.image_url(type: 'v1', format: 'png') %>">
    <% else %>
      <% if script.to_s.start_with?('code_') %>
        <%= render 'shared/page_font', verses: [@ayah] %>
      <% end %>
      <div dir="rtl" class="<%= font_class %> text-3xl leading-relaxed text-right">
        <%= safe_html @ayah.read_attribute(script) %>
      </div>
    <% end %>
  </div>
<% end %>


