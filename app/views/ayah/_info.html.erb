<% active_tab = params[:tab].presence || 'ayah' %>
<div class="p-3 sm:p-6" id="modal-body" data-controller="tabs">
  <ul class="nav nav-tabs flex flex-nowrap overflow-x-auto overflow-y-hidden whitespace-nowrap border-b border-gray-200" id="ayahTabs" role="tablist">
    <li class="m-0 flex-none" role="presentation">
      <button class="btn-tab<%= ' btn-tab-active' if active_tab == 'ayah' %>" id="ayah-tab" data-action="click->tabs#switch" data-tabs-target-value="ayah" type="button" role="tab" aria-controls="ayah" aria-selected="<%= active_tab == 'ayah' %>">Ayah</button>
    </li>
    <li class="m-0 flex-none" role="presentation">
      <button class="btn-tab<%= ' btn-tab-active' if active_tab == 'translations' %>" id="translations-tab" data-action="click->tabs#switch" data-tabs-target-value="translations" type="button" role="tab" aria-controls="translations" aria-selected="<%= active_tab == 'translations' %>">Translations</button>
    </li>
    <li class="m-0 flex-none" role="presentation">
      <button class="btn-tab<%= ' btn-tab-active' if active_tab == 'tafsirs' %>" id="tafsirs-tab" data-action="click->tabs#switch" data-tabs-target-value="tafsirs" type="button" role="tab" aria-controls="tafsirs" aria-selected="<%= active_tab == 'tafsirs' %>">Tafsirs</button>
    </li>
    <li class="m-0 flex-none" role="presentation">
      <button class="btn-tab<%= ' btn-tab-active' if active_tab == 'words' %>" id="words-tab" data-action="click->tabs#switch" data-tabs-target-value="words" type="button" role="tab" aria-controls="words" aria-selected="<%= active_tab == 'words' %>">Words</button>
    </li>
    <li class="m-0 flex-none" role="presentation">
      <button class="btn-tab<%= ' btn-tab-active' if active_tab == 'theme' %>" id="theme-tab" data-action="click->tabs#switch" data-tabs-target-value="theme" type="button" role="tab" aria-controls="theme" aria-selected="<%= active_tab == 'theme' %>">Theme</button>
    </li>
    <li class="m-0 flex-none" role="presentation">
      <button class="btn-tab<%= ' btn-tab-active' if active_tab == 'transliteration' %>" id="transliteration-tab" data-action="click->tabs#switch" data-tabs-target-value="transliteration" type="button" role="tab" aria-controls="transliteration" aria-selected="<%= active_tab == 'transliteration' %>">Transliteration</button>
    </li>
    <li class="m-0 flex-none" role="presentation">
      <button class="btn-tab<%= ' btn-tab-active' if active_tab == 'topics' %>" id="topics-tab" data-action="click->tabs#switch" data-tabs-target-value="topics" type="button" role="tab" aria-controls="topics" aria-selected="<%= active_tab == 'topics' %>">Topics</button>
    </li>
    <li class="m-0 flex-none" role="presentation">
      <button class="btn-tab<%= ' btn-tab-active' if active_tab == 'recitation' %>" id="recitation-tab" data-action="click->tabs#switch" data-tabs-target-value="recitation" type="button" role="tab" aria-controls="recitation" aria-selected="<%= active_tab == 'recitation' %>">Recitation</button>
    </li>
  </ul>

  <div class="tab-content p-2 sm:p-4" id="ayahTabsContent">
    <div class="tab-pane fade <%= 'show active' if active_tab == 'ayah' %> <%= 'hidden' unless active_tab == 'ayah' %>" id="ayah" role="tabpanel" aria-labelledby="ayah-tab">
      <%= turbo_frame_tag :ayah_text, src: ayah_text_path(@ayah.verse_key, script: 'text_qpc_hafs') %>
    </div>

    <div class="tab-pane fade <%= 'show active' if active_tab == 'translations' %> <%= 'hidden' unless active_tab == 'translations' %>" id="translations" role="tabpanel" aria-labelledby="translations-tab">
      <%= turbo_frame_tag :ayah_translations, src: ayah_translations_path(@ayah.verse_key, translation_ids: [131]) %>
    </div>

    <div class="tab-pane fade <%= 'show active' if active_tab == 'tafsirs' %> <%= 'hidden' unless active_tab == 'tafsirs' %>" id="tafsirs" role="tabpanel" aria-labelledby="tafsirs-tab">
      <%= turbo_frame_tag :ayah_tafsirs, src: ayah_tafsirs_path(@ayah.verse_key) %>
    </div>

    <div class="tab-pane fade <%= 'show active' if active_tab == 'words' %> <%= 'hidden' unless active_tab == 'words' %>" id="words" role="tabpanel" aria-labelledby="words-tab">
      <%= turbo_frame_tag :ayah_words, src: ayah_words_path(@ayah.verse_key) %>
    </div>

    <div class="tab-pane fade <%= 'show active' if active_tab == 'theme' %> <%= 'hidden' unless active_tab == 'theme' %>" id="theme" role="tabpanel" aria-labelledby="theme-tab">
      <%= turbo_frame_tag :ayah_theme, src: ayah_theme_path(@ayah.verse_key) %>
    </div>

    <div class="tab-pane fade <%= 'show active' if active_tab == 'transliteration' %> <%= 'hidden' unless active_tab == 'transliteration' %>" id="transliteration" role="tabpanel" aria-labelledby="transliteration-tab">
      <%= turbo_frame_tag :ayah_transliteration, src: ayah_transliteration_path(@ayah.verse_key) %>
    </div>

    <div class="tab-pane fade <%= 'show active' if active_tab == 'topics' %> <%= 'hidden' unless active_tab == 'topics' %>" id="topics" role="tabpanel" aria-labelledby="topics-tab">
      <%= turbo_frame_tag :ayah_topics, src: ayah_topics_path(@ayah.verse_key) %>
    </div>

    <div class="tab-pane fade <%= 'show active' if active_tab == 'recitation' %> <%= 'hidden' unless active_tab == 'recitation' %>" id="recitation" role="tabpanel" aria-labelledby="recitation-tab">
      <%= turbo_frame_tag :ayah_recitation, src: ayah_recitation_path(@ayah.verse_key) %>
    </div>
  </div>
</div>
