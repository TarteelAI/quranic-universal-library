<%= turbo_frame_tag :ayah_tafsirs do %>
  <div dir="rtl" class="qpc-hafs text-2xl sm:text-3xl leading-relaxed text-right bg-white border border-gray-200 rounded p-3 sm:p-5 mb-3 sm:mb-4">
    <%= @ayah.text_qpc_hafs %>
  </div>

   <div class="flex items-start justify-between gap-4 flex-wrap" data-controller="ayah-tafsir-selector">
     <div class="flex flex-wrap gap-2">
       <span class="inline-flex items-center px-3 py-1 rounded bg-blue-100 text-blue-800 text-sm font-medium">
         <%= @presenter.tafsir_ids.size %> tafsir<%= 's' if @presenter.tafsir_ids.size != 1 %> selected
       </span>
     </div>

    <button type="button"
            class="px-3 py-1.5 bg-white text-gray-900 rounded text-sm border border-gray-200 hover:bg-gray-50"
            data-action="click->ayah-tafsir-selector#open">
      Change tafsirs
    </button>

    <div class="hidden fixed inset-0 bg-black/40 z-[10000]" data-ayah-tafsir-selector-target="backdrop" data-action="click->ayah-tafsir-selector#close"></div>
    <div class="hidden fixed top-0 right-0 h-full w-[420px] max-w-[90vw] bg-white border-l border-gray-200 z-[10001] flex-col" data-ayah-tafsir-selector-target="panel">
      <div class="p-4 border-b border-gray-200 flex items-center justify-between">
        <div class="font-semibold text-gray-900">Select tafsirs</div>
        <button type="button" class="text-gray-500 hover:text-gray-900" data-action="click->ayah-tafsir-selector#close">
          <i class="fa fa-times"></i>
        </button>
      </div>
      <div class="p-4 overflow-y-auto flex-1">
        <%= form_with url: ayah_tafsirs_path(@ayah.verse_key), method: :get, local: true, data: { turbo_frame: :ayah_tafsirs }, html: { data: { ayah_tafsir_selector_target: "form" } } do %>
          <div class="space-y-2">
            <% @presenter.tafsir_resources.each do |rc| %>
              <label class="flex items-start gap-2 text-sm text-gray-800">
                <%= check_box_tag "tafsir_ids[]", rc.id, @presenter.tafsir_ids.include?(rc.id), class: "mt-1", data: { action: "change->ayah-tafsir-selector#change" } %>
                <span><%= rc.name %></span>
              </label>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mt-3 sm:mt-4 space-y-4 sm:space-y-6">
    <% if @presenter.tafsir_by_id.present? %>
      <% @presenter.tafsir_ids.each do |rid| %>
        <% t = @presenter.tafsir_by_id[rid] %>
        <% next unless t %>
        <% rc = @presenter.tafsir_resources_by_id[rid] %>
        <div class="bg-white border border-gray-200 rounded p-3 sm:p-4">
          <div class="text-xs text-gray-500"><%= rc&.name.presence || "Tafsir ##{rid}" %></div>
          <% ayahs = (@presenter.tafsir_ayahs_by_id || {})[rid] || [] %>
          <% if ayahs.any? %>
            <div class="mt-3 bg-emerald-50 border border-emerald-200 rounded p-3">
              <div class="text-sm font-semibold text-emerald-900">
                This tafsir is for <%= ayahs.size %> ayahs from <%= ayahs.first.verse_key %>
                to <%= ayahs.last.verse_key %>
              </div>
              <div class="mt-2 space-y-2">
                <div class="bg-white/70 border border-emerald-100 rounded p-2 sm:p-3 qpc-hafs">
                  <% ayahs.each do |v| %>
                    <%= v.text_qpc_hafs %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
          <div class="mt-2 text-sm text-gray-900"><%= safe_html t.text %></div>
        </div>
      <% end %>
    <% else %>
      <div class="text-sm text-gray-600">No tafsir found for the selected resources.</div>
    <% end %>
  </div>
<% end %>


