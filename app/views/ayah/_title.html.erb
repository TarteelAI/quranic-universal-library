<div class="flex flex-wrap items-center justify-between p-3 sm:p-6 border-b border-gray-200 gap-4" id="modal-header">
  <div class="text-lg font-semibold flex flex-wrap items-center justify-between flex-grow gap-4">
    <div class="flex flex-col">
        <div class="flex items-center gap-2">
          <strong><%= @ayah.chapter.name_simple %></strong>
          <% current_tab = params[:tab].presence || 'ayah' %>
          <span class="relative inline-block" data-controller="ayah-jump" data-ayah-jump-tab-value="<%= current_tab %>">
            <button type="button" class="badge badge-info" data-action="click->ayah-jump#toggle">
              Ayah <%= @ayah.verse_number %>
              <i class="fa fa-chevron-down text-[10px]"></i>
            </button>
            <div id="ayah-jump-panel" class="hidden absolute left-0 mt-2 bg-white border border-gray-200 rounded shadow-lg p-3 z-[10002]" data-ayah-jump-target="panel">
              <select class="w-[220px]"
                      data-controller="select2"
                      data-parent="#ayah-jump-panel"
                      data-ayah-jump-target="select"
                      data-action="change->ayah-jump#jump">
                <% 1.upto(@ayah.chapter.verses_count) do |n| %>
                  <% key = "#{@ayah.chapter_id}:#{n}" %>
                  <option value="<%= key %>" <%= "selected" if n == @ayah.verse_number %>><%= key %></option>
                <% end %>
              </select>
            </div>
          </span>
        </div>

        <div class="mt-1">
          <small class="text-gray-600">
            <%= @ayah.chapter.translated_names.english.first.name %>
          </small>
        </div>
    </div>

    <div class="flex gap-2 flex-wrap">
      <%= link_to 'Previous ayah', ayah_path(@ayah.previous_ayah.verse_key, tab: current_tab), class: 'btn btn-dark px-3 py-1.5 whitespace-nowrap', data: { ayah_nav: true, turbo_frame: :ayah_info, turbo_action: 'replace' } if @ayah.previous_ayah %>
      <%= link_to 'Next ayah', ayah_path(@ayah.next_ayah.verse_key, tab: current_tab), class: 'btn btn-dark px-3 py-1.5 whitespace-nowrap', data: { ayah_nav: true, turbo_frame: :ayah_info, turbo_action: 'replace' } if @ayah.next_ayah %>
    </div>
  </div>

  <button type="button" class="text-gray-400 hover:text-gray-600 transition-colors p-1 -mr-1" data-bs-dismiss="modal" data-action="click->ajax-modal#hide" aria-label="Close">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>
</div>

