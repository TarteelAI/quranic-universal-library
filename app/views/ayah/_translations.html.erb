<%= turbo_frame_tag :ayah_translations do %>
  <div dir="rtl" class="qpc-hafs text-2xl sm:text-3xl leading-relaxed text-right bg-white border border-gray-200 rounded p-3 sm:p-5 mb-3 sm:mb-4">
    <%= @ayah.text_qpc_hafs %>
  </div>

  <div class="flex items-start justify-between gap-4 flex-wrap" data-controller="ayah-translation-selector">
    <div class="flex flex-wrap gap-2">
      <span class="inline-flex items-center px-3 py-1 rounded bg-blue-100 text-blue-800 text-sm font-medium">
        <%= @presenter.translation_ids.size %> translation<%= 's' if @presenter.translation_ids.size != 1 %> selected
      </span>
    </div>

    <button type="button"
            class="px-3 py-1.5 bg-white text-gray-900 rounded text-sm border border-gray-200 hover:bg-gray-50"
            data-action="click->ayah-translation-selector#open">
      Change translations
    </button>

    <div class="hidden fixed inset-0 bg-black/40 z-[10000]" data-ayah-translation-selector-target="backdrop" data-action="click->ayah-translation-selector#close"></div>
    <div class="hidden fixed top-0 right-0 h-full w-[420px] max-w-[90vw] bg-white border-l border-gray-200 z-[10001] flex-col" data-ayah-translation-selector-target="panel">
      <div class="p-4 border-b border-gray-200 flex items-center justify-between">
        <div class="font-semibold text-gray-900">Select translations</div>
        <button type="button" class="text-gray-500 hover:text-gray-900" data-action="click->ayah-translation-selector#close">
          <i class="fa fa-times"></i>
        </button>
      </div>
      <div class="p-4 border-b border-gray-200">
        <input type="text"
               placeholder="Search translations..."
               class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
               data-ayah-translation-selector-target="search"
               data-action="input->ayah-translation-selector#search">
      </div>
      <div class="p-4 overflow-y-auto flex-1">
        <%= form_with url: ayah_translations_path(@ayah.verse_key), method: :get, local: true, data: { turbo_frame: :ayah_translations }, html: { data: { ayah_translation_selector_target: "form" } } do %>
          <div class="space-y-3" data-ayah-translation-selector-target="translationList">
            <% @presenter.translation_resources_grouped_by_language.each do |language, resources| %>
              <div class="translation-group" data-language="<%= language.downcase %>">
                <button type="button"
                        class="flex items-center justify-between w-full px-3 py-2 text-left bg-gray-50 border border-gray-200 rounded-md text-sm font-medium text-gray-900 hover:bg-gray-100"
                        data-action="click->ayah-translation-selector#toggleGroup"
                        data-group="<%= language.downcase %>">
                  <span><%= language %> (<%= resources.size %>)</span>
                  <i class="fa fa-chevron-down transition-transform duration-200" data-ayah-translation-selector-target="chevron" data-group="<%= language.downcase %>"></i>
                </button>
                <div class="mt-2 space-y-2 hidden" data-ayah-translation-selector-target="groupContent" data-group="<%= language.downcase %>">
                  <% resources.each do |rc| %>
                    <label class="flex items-start gap-2 text-sm text-gray-800 translation-item" data-name="<%= rc.name.downcase %>">
                      <%= check_box_tag "translation_ids[]", rc.id, @presenter.translation_ids.include?(rc.id), class: "mt-1", data: { action: "change->ayah-translation-selector#change" } %>
                      <span><%= rc.name %></span>
                    </label>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mt-3 sm:mt-4 space-y-4 sm:space-y-6">
    <% if @presenter.translations.any? %>
      <% @presenter.translation_ids.each do |rid| %>
        <% tr = @presenter.translations.find { |t| t.resource_content_id == rid } %>
        <% next unless tr %>
        <% rc = @presenter.translation_resources_by_id[rid] %>
        <div class="bg-white border border-gray-200 rounded p-3 sm:p-4" data-controller="translation-footnote-toggle">
          <div class="text-xs text-gray-500"><%= rc&.name.presence || "Translation ##{rid}" %></div>
          <div class="mt-2 text-sm text-gray-900"><%= safe_html(@presenter.translation_html_by_id[rid]) %></div>
          <% footnotes = @presenter.translation_footnotes_by_id[rid] || {} %>
          <% if footnotes.any? %>
            <div class="mt-3 space-y-2">
              <% footnotes.each do |fid, fn| %>
                <div class="hidden bg-gray-50 border border-gray-200 rounded p-3" data-footnote-block-id="<%= fid %>">
                  <div class="flex items-start justify-between gap-3">
                    <div class="text-xs text-gray-500">Footnote <%= fid %></div>
                    <button type="button"
                            class="text-gray-400 hover:text-gray-700"
                            data-action="click->translation-footnote-toggle#close"
                            data-footnote-close-id="<%= fid %>">
                      <i class="fa fa-times"></i>
                    </button>
                  </div>
                  <div class="mt-2 text-sm text-gray-900"><%= safe_html fn.text %></div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="text-sm text-gray-600">No translations found for the selected resources.</div>
    <% end %>
  </div>
<% end %>


