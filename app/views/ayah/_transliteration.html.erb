<%= turbo_frame_tag :ayah_transliteration do %>
  <div dir="rtl" class="qpc-hafs text-3xl leading-relaxed text-right bg-white border border-gray-200 rounded p-5 mb-4">
    <%= @ayah.text_qpc_hafs %>
  </div>

   <div class="flex items-start justify-between gap-4 flex-wrap" data-controller="ayah-transliteration-selector">
     <div class="flex flex-wrap gap-2">
       <% rc = @presenter.transliteration_resources_by_id[@presenter.transliteration_id] %>
       <span class="inline-flex items-center px-2 py-1 rounded bg-gray-100 text-gray-700 text-xs">
         <%= rc&.name.presence || "Transliteration ##{@presenter.transliteration_id}" %>
       </span>
     </div>

    <button type="button"
            class="px-3 py-1.5 bg-white text-gray-900 rounded text-sm border border-gray-200 hover:bg-gray-50"
            data-action="click->ayah-transliteration-selector#open">
      Change transliteration
    </button>

    <div class="hidden fixed inset-0 bg-black/40 z-[10000]" data-ayah-transliteration-selector-target="backdrop" data-action="click->ayah-transliteration-selector#close"></div>
    <div class="hidden fixed top-0 right-0 h-full w-[420px] max-w-[90vw] bg-white border-l border-gray-200 z-[10001] flex-col" data-ayah-transliteration-selector-target="panel">
      <div class="p-4 border-b border-gray-200 flex items-center justify-between">
        <div class="font-semibold text-gray-900">Select transliteration</div>
        <button type="button" class="text-gray-500 hover:text-gray-900" data-action="click->ayah-transliteration-selector#close">
          <i class="fa fa-times"></i>
        </button>
      </div>
      <div class="p-4 overflow-y-auto flex-1">
        <%= form_with url: ayah_transliteration_path(@ayah.verse_key), method: :get, local: true, data: { turbo_frame: :ayah_transliteration }, html: { data: { ayah_transliteration_selector_target: "form" } } do %>
          <div class="space-y-2">
            <% @presenter.transliteration_resources.each do |r| %>
              <label class="flex items-start gap-2 text-sm text-gray-800">
                <%= radio_button_tag "transliteration_id", r.id, @presenter.transliteration_id == r.id, data: { action: "change->ayah-transliteration-selector#change" } %>
                <span><%= r.name %></span>
              </label>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mt-4 bg-white border border-gray-200 rounded p-5">
    <% tr = @presenter.transliteration %>
    <% if tr.present? %>
      <div class="text-sm text-gray-900"><%= safe_html tr.text %></div>
    <% else %>
      <div class="text-sm text-gray-600">No transliteration available.</div>
    <% end %>
  </div>
<% end %>


