<%= turbo_frame_tag :ayah_words do %>
   <div class="flex items-start justify-between gap-4 flex-wrap" data-controller="ayah-word-translation-selector">
     <div class="text-sm text-gray-700">
       Word by word translation
     </div>

    <button type="button"
            class="px-3 py-1.5 bg-white text-gray-900 rounded text-sm border border-gray-200 hover:bg-gray-50"
            data-action="click->ayah-word-translation-selector#open">
      Change translation
    </button>

    <div class="hidden fixed inset-0 bg-black/40 z-[10000]" data-ayah-word-translation-selector-target="backdrop" data-action="click->ayah-word-translation-selector#close"></div>
    <div class="hidden fixed top-0 right-0 h-full w-[420px] max-w-[90vw] bg-white border-l border-gray-200 z-[10001] flex-col" data-ayah-word-translation-selector-target="panel">
      <div class="p-4 border-b border-gray-200 flex items-center justify-between">
        <div class="font-semibold text-gray-900">Select translation</div>
        <button type="button" class="text-gray-500 hover:text-gray-900" data-action="click->ayah-word-translation-selector#close">
          <i class="fa fa-times"></i>
        </button>
      </div>
      <div class="p-4 overflow-y-auto flex-1">
        <%= form_with url: ayah_words_path(@ayah.verse_key), method: :get, local: true, data: { turbo_frame: :ayah_words }, html: { data: { ayah_word_translation_selector_target: "form" } } do %>
          <div class="space-y-2">
            <% @presenter.word_translation_resources.each do |rc| %>
              <label class="flex items-start gap-2 text-sm text-gray-800">
                <%= radio_button_tag "word_translation_id", rc.id, @presenter.word_translation_id == rc.id, data: { action: "change->ayah-word-translation-selector#change" } %>
                <span><%= rc.name %></span>
              </label>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div dir="rtl" class="mt-4 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
    <% @presenter.words.each do |w| %>
      <% wt = @presenter.word_translation_by_word_id[w.id] %>
      <div class="bg-white border border-gray-200 rounded p-3">
        <div dir="rtl" class="qpc-hafs arabic text-2xl leading-none font-semibold text-gray-900 text-center">
          <%= w.text_qpc_hafs.presence || w.text_uthmani %>
        </div>
        <div class="mt-2 text-xs text-gray-500 text-center"><%= w.location %></div>
        <div dir="ltr" class="mt-2 text-sm text-gray-800 text-center"><%= wt&.text.presence || '-' %></div>
      </div>
    <% end %>
  </div>
<% end %>


