<%
  recitations = Recitation.all.map do |a|
    [a.humanize, a.id]
  end
%>

<%= render 'tools/header',
           name: 'Ayah recitations',
           title: @recitation.humanize,
           key: 'ayah_recitation'
%>

<div class="page-wrapper container max-w-7xl mx-auto px-4">
  <div class="page-section filters">
    <%= form_tag ayah_audio_files_path, method: :get do %>
      <div data-controller="chapter-verses-filter" class="flex flex-wrap">
        <%= render 'shared/filters' %>

        <div class="mb-4 me-2">
          <%= select_tag :id, options_for_select(recitations, params[:id]), class: 'form-select w-[85vw] sm:w-[200px]', data: { controller: 'select2' } %>
          <p class="text-sm text-gray-600 mt-1">Filter reciter</p>
        </div>

        <div class="mb-4">
          <%= submit_tag 'Filter', class: 'btn btn-success', data: { disable_with: 'Please wait..' } %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="page-section mt-4">
    <h2 class="text-2xl mb-4">Ayah segments</h2>
    <div class="tools-table-overflow">
    <table class="w-full hover:bg-gray-50">
      <thead class="sticky top-0 z-10 bg-white border-b-2 border-black">
      <tr>
        <th><%= sort_order_link 'Id', :id, id: @recitation.id %></th>
        <th><%= sort_order_link 'Surah', :chapter_id %></th>
        <th><%= sort_order_link 'Ayah', :verse_number %></th>
        <th>Segment Progress</th>
        <th>Actions</th>
      </tr>
      </thead>

      <tbody>
      <% @audio_files.each do |file| %>
        <tr class="hover:bg-gray-200 border-b">
          <th scope="row" class="py-2 pl-2"><%= file.id %></th>
          <th scope="row" class="py-2"><%= file.chapter_id %></th>
          <th scope="row" class="py-2"><%= file.verse_number %></th>

          <td class="py-2">
            <% progress = file.segment_progress %>

            <div class="w-full bg-gray-200 rounded-full h-6">
              <div class="h-6 rounded-full text-white text-xs flex items-center justify-center transition-all duration-300 bg-green-500"
                   role="progressbar"
                   aria-valuenow="<%= progress %>"
                   aria-valuemin="0" aria-valuemax="100"
                   style="width: <%= progress %>%; min-width: 30px">
                <%= progress %>%
              </div>
            </div>
          </td>

          <td class="py-2">
            <div class="flex gap-1">
              <%= link_to 'Show', ayah_audio_file_path(@recitation.id, chapter_id: file.chapter_id), class: 'btn btn-success' %>
              <%= link_to 'Fix Segments', segment_builder_ayah_audio_file_path(@recitation.id, chapter_id: file.chapter_id, verse: file.verse_number), class: 'btn btn-success' %>
            </div>
          </td>
        </tr>
      <% end %>

      <tr>
        <td colspan="5">
          <%= pagination_section @pagy %>
        </td>
      </tr>
      </tbody>
    </table>
    </div>
  </div>
</div>


