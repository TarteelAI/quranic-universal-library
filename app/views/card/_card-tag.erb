<%
  slug = nil
  if tag.is_a?(String)
    color = resource_tag_class(tag)
    text = tag
  elsif tag.is_a?(Array)
    text, slug  = tag
    color = resource_tag_class(text)
  else
    color = tag.color_class.presence || 'blue'
    text = tag.name
    slug = tag.slug
  end
%>

<% if !local_assigns[:tool] && (slug.present? || tag.try(:description).present?) %>
  <%= link_to text, docs_path(slug), class: "tag tag-#{color}", data: { controller: 'ajax-modal', url: docs_path(slug), css_class: 'modal-lg' } %>
<% else %>
  <span class="tag tag-<%= color %>">
    <%= text %>
  </span>
<% end %>


