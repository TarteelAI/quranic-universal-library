<% if resource.restrict_download? %>
  <% url = copyright_resource_path(resource.id) %>
  <div class="text-left text-sm">
    This resource is © copyrighted.
    <%= link_to 'learn more', url,
                class: 'text-blue-600 hover:underline',
                data: { controller: 'ajax-modal', url: url, css_class: 'modal-lg' }
    %>
  </div>
<% else %>
  <div class="relative" data-controller="dropdown">
    <button class="px-4 py-2 rounded font-medium transition-colors w-full md:w-auto bg-white text-gray-800 border border-gray-300 rounded-lg text-left whitespace-nowrap text-sm focus:outline-none focus:ring-2 focus:ring-[#C5C8E6] focus:ring-offset-2 flex items-center justify-between gap-2" id="dropdown-<%= resource.id %>" data-action="click->dropdown#toggle" aria-expanded="false">
      <span>Select download format</span>
      <svg data-dropdown-target="icon" class="w-4 h-4 transition-transform duration-200" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.24a.75.75 0 01-1.06 0L5.21 8.29a.75.75 0 01.02-1.08z" clip-rule="evenodd" />
      </svg>
    </button>
    <ul class="absolute right-0 mt-2 min-w-48 bg-white border border-gray-200 rounded-md shadow-lg z-50 hidden" data-dropdown-target="menu" aria-labelledby="dropdown-<%= resource.id %>">
      <% if resource.downloadable_files.any? %>
      <% resource.downloadable_files.each do |file| %>
        <li class="py-2 px-4 hover:bg-gray-100">
          <% if user_signed_in? %>
            <%= link_to resource_download_file_path(resource.resource_type, token: file.token), target: '_blank', class: 'block w-full truncate whitespace-normal break-words text-gray-800 hover:!text-black' do %>
              Download <%= file.file_type %>
            <% end %>
          <% else %>
            <%= link_to '#_', class: 'block w-full truncate whitespace-normal break-words text-gray-800 hover:!text-black', data: { controller: 'ajax-modal', url: new_user_session_path(user_return_to: "/resources/#{resource.resource_type}/#{resource.id}", modal: true) } do %>
              Download <%= file.file_type %>
            <% end %>
          <% end %>
        </li>
      <% end %>
      <% else %>
        <li class="py-2 px-4 text-gray-500">No formats available</li>
      <% end %>
    </ul>
  </div>
<% end %>
