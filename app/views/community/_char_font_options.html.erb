<%
  selected_font = get_quran_script_font_family(params[:script], Verse.first)
%>
<div class="flex flex-wrap gap-4 my-4 sticky">
  <div class="w-full">
    <div class="flex flex-column mb-4">
      <div>
        Font size:(<span id="font-size"></span>)
        <input type="range" min="15" max="100" value="28" class="font-size-slider">
      </div>

      <div id=font-switcher>
        <label for="font-switcher">
          Change font
        </label>


        <%= select_tag :change_font, options_for_select(all_quran_fonts, selected_font),class: "w-[100%] border-gray-400 rounded-[5px] h-[38px]"%>
      </div>
    </div>
  </div>
</div>
