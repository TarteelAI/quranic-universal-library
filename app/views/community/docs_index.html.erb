<div id="resources">
  <% unless request.xhr? %>
    <div class="tw-border-b tw-border-gray-200 tw-bg-gray-50 tw-pt-[80px] tw-pb-10">
      <div class="tw-container tw-max-w-7xl tw-mx-auto tw-px-4">
        <p class="tw-text-sm tw-font-semibold tw-uppercase tw-tracking-wide tw-text-blue-600">Documentation</p>
        <h1 class="tw-mt-2 tw-text-3xl tw-font-bold tw-text-gray-900">QUL Documentation</h1>
        <p class="tw-mt-3 tw-max-w-3xl tw-text-gray-700">
          Start here to download QUL resources and integrate them in your app. Contributor setup docs are available as a secondary track.
        </p>
      </div>
    </div>
  <% end %>

  <%= render "community/docs_markdown", docs_page: @docs_page %>
</div>
