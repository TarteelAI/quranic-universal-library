<div id="resources">
  <% unless request.xhr? %>
    <div class="border-b border-gray-200 bg-gray-50 pt-[80px] pb-10">
      <div class="container max-w-7xl mx-auto px-4">
        <p class="text-sm font-semibold uppercase tracking-wide text-blue-600">Documentation</p>
        <h1 class="mt-2 text-3xl font-bold text-gray-900">QUL Documentation</h1>
        <p class="mt-3 max-w-3xl text-gray-700">
          Start here to download QUL resources and integrate them in your app. Contributor setup docs are available as a secondary track.
        </p>
      </div>
    </div>
  <% end %>

  <%= render "community/docs_markdown", docs_page: @docs_page %>
</div>
