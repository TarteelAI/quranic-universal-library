<div id="title" class="hidden">
  <%= tag.name %>
</div>

<div id="body">
  <div class="p-6 qul-docs">
    <div class="prose max-w-none">
      <%= safe_html tag.description %>

      <% if tag.glossary_term.present? %>
        <div class="d-block">
          <%= link_to "Click here", "https://www.tarteel.ai/glossary/#{tag.glossary_term}", class: 'underline hover:no-underline' %>
          to read more
          about <%= tag.name %>
          on <%= link_to 'Tarteel glossary', 'https://www.tarteel.ai/glossary', class: 'underline hover:no-underline' %>
          page.
        </div>
      <% end %>

      <% if tag.downloadable_resources.any? %>
        <div class="mt-8">
          <h2 class="text-3xl font-semibold text-gray-800 mb-6">
            Resources related to <strong><%= tag.name %></strong> tag
          </h2>

          <% grouped_resources = tag.downloadable_resources.group_by(&:resource_type) %>

          <div class="space-y-8">
            <% grouped_resources.each do |resource_type, resources| %>
              <% first = resources.first %>
              <div class="border rounded-xl shadow-sm p-6 bg-white">
                <h3 class="text-xl font-medium text-gray-700 border-b pb-2 mb-4 capitalize">
                  <%= first.group_name %>
                </h3>

                <ul class="space-y-3">
                  <% resources.each do |resource| %>
                    <li>
                      <%= link_to resource.name, detail_resources_path(resource.resource_type, resource.id), class: "text-blue-600 hover:text-blue-800 underline" %>
                    </li>
                  <% end %>
                </ul>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
