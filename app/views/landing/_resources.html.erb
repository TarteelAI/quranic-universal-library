<div class="sidescroll-container">
  <h2 class="tw-text-3xl md:tw-text-5xl tw-text-white">Developer Resources</h2>
</div>
<div class="sidescroll-container tw-grid tw-grid-flow-col tw-auto-cols-[400px] tw-overflow-auto tw-items-center tw-relative tw-mt-10 tw-gap-3 md:tw-gap-4">
  <% featured_developer_resources.each do |card| %>
    <%= render 'card/card-container', url: card.url, type: card.type do %>
      <%= render 'card/card_content', card: card, show_stats: true %>
    <% end %>
  <% end %>
</div>
<div class="sidescroll-container">
  <p class="tw-mt-10">
    <%= link_to 'VIEW ALL DEVELOPER RESOURCES', resources_path, class: 'tw-text-white tw-opacity-70 tw-font-semibold hover:tw-opacity-100 hover:tw-text-white tw-transition-opacity tw-duration-300' %>
  </p>
</div>
