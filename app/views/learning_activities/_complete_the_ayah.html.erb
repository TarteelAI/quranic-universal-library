<%
  data = generate_complete_the_ayah_quiz
  verse = data[:verse]
  words = data[:words]
  words_to_show = data[:words_to_show]
  remaining_words = data[:remaining_words]
%>

<h2 class="heading my-3 text-3xl font-bold text-center mb-6 text-gray-800">Complete the Ayah Challenge</h2>

<div class="quiz" data-controller="activities--fill-in-blank" data-ayah="<%= verse.verse_key %>">
  <div class="px-6 py-5 rounded-lg mb-6 bg-gradient-to-br from-blue-50 to-indigo-50 border-2 border-blue-200 shadow-md">
    <div class="text-center mb-4">
      <div class="inline-block px-4 py-2 rounded-full bg-blue-500 text-white text-sm font-semibold mb-3">
        Fill in the Blanks
      </div>
      <p class="text-base font-medium text-gray-700">Click or drag and drop the missing words to complete the ayah.</p>
    </div>
    <div class="ayah-text-container px-6 py-6 rounded-lg bg-white shadow-sm">
      <div class="qpc-hafs flex flex-wrap items-center justify-center gap-3 leading-relaxed" style="font-size: 32px; direction: rtl; text-align: center;">
        <% words.each do |word| %>
          <% if words_to_show.include?(word) %>
            <span class="word-box qpc-hafs inline-flex items-center justify-center px-4 py-3 rounded-lg bg-blue-50 border-2 border-blue-200 shadow-sm" style="font-size: 32px; min-height: 60px; line-height: 1.2;">
              <%= word.text_qpc_hafs %>
            </span>
          <% else %>
            <span class="blank-box inline-flex items-center justify-center min-w-[100px] h-[60px] rounded-lg border-2 border-dashed border-red-400 bg-red-50 cursor-pointer hover:border-red-500 hover:bg-red-100 transition-all duration-200"
                  data-word-id="<%= word.id %>"
                  style="line-height: 1.2;">
              <span class="text-2xl text-red-400 font-bold">?</span>
            </span>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mb-4">
    <p class="text-center text-lg font-bold text-gray-800 mb-4">Available Words:</p>
    <div class="flex flex-wrap justify-center gap-3 mb-4" id="options">
      <% remaining_words.each do |word| %>
        <div class="draggable-word qpc-hafs inline-flex items-center justify-center px-5 py-4 rounded-lg font-semibold transition-all duration-200 bg-gradient-to-r from-green-500 to-emerald-500 hover:from-green-600 hover:to-emerald-600 text-white shadow-lg hover:shadow-xl transform hover:scale-105 cursor-grab active:cursor-grabbing border-0"
             data-word-id="<%= word.id %>"
             style="font-size: 28px; min-height: 60px; line-height: 1.2;">
          <%= word.text_qpc_hafs %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="text-center">
    <button type="button" data-action="click->activities--fill-in-blank#resetActivity" class="reset-btn px-8 py-3 rounded-lg font-semibold text-lg transition-all duration-200 bg-gradient-to-r from-gray-500 to-gray-600 hover:from-gray-600 hover:to-gray-700 text-white shadow-lg hover:shadow-xl transform hover:scale-105 border-0">
      Reset
    </button>
  </div>
</div>