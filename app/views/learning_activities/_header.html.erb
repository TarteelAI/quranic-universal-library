<%= render 'layouts/qul_head' %>

<%= render 'layouts/grid' do %>
  <div class="pt-6 md:pt-8 pb-4 md:pb-6">
    <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-4 md:mb-6 leading-tight">
      Learning Activities
    </h1>
    <div class="relative overflow-hidden rounded-xl bg-gradient-to-r from-green-50 to-emerald-50 border border-green-200/50 shadow-sm px-4 md:px-6 py-4 md:py-5">
      <div class="flex items-start gap-3 md:gap-4">
        <div class="flex-shrink-0 mt-0.5">
