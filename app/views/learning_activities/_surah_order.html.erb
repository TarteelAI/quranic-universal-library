<%
  data = generate_surah_order_quiz
  mode = data[:mode]
%>

<h2 class="heading my-3 text-3xl font-bold text-center mb-6 text-gray-800">Surah Order Challenge</h2>

<div class="quiz" data-controller="activities--surah-order" data-mode="<%= mode %>">
  <% if mode == 'sort' %>
    <div class="px-6 py-5 rounded-lg mb-6 bg-gradient-to-br from-blue-50 to-indigo-50 border-2 border-blue-200 shadow-md">
      <div class="text-center mb-4">
        <div class="inline-block px-4 py-2 rounded-full bg-blue-500 text-white text-sm font-semibold mb-3">
          Sort Challenge
        </div>
        <p class="text-xl font-semibold text-gray-700">
          Sort these surahs in their correct order in the Quran
        </p>
      </div>
    </div>

    <div class="mb-6">
      <p class="text-center text-lg font-bold text-gray-800 mb-4">Available Surahs:</p>
      <div class="flex flex-wrap justify-center gap-3 mb-6" id="available-surahs">
        <% data[:surahs].each do |surah| %>
          <div class="sortable-surah px-6 py-4 rounded-lg font-semibold text-lg transition-all duration-200 bg-gradient-to-r from-green-500 to-emerald-500 hover:from-green-600 hover:to-emerald-600 text-white shadow-lg hover:shadow-xl transform hover:scale-105 cursor-grab active:cursor-grabbing border-0 flex items-center justify-center min-h-[60px] text-center"
               data-surah-id="<%= surah[:id] %>"
               data-chapter-number="<%= surah[:chapter_number] %>">
            <%= surah[:name] %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="mb-6">
      <p class="text-center text-lg font-bold text-gray-800 mb-4">Sort Here (Drag or Click):</p>
      <div class="flex flex-wrap justify-center gap-3" id="sort-slots" style="direction: rtl;">
        <% 4.times do |index| %>
          <div class="sort-slot min-w-[150px] min-h-[60px] rounded-lg border-2 border-dashed border-blue-400 bg-blue-50 cursor-pointer hover:border-blue-500 hover:bg-blue-100 transition-all duration-200 flex items-center justify-center"
               data-slot-index="<%= index %>">
            <span class="text-xl text-blue-400 font-bold">?</span>
          </div>
        <% end %>
      </div>
    </div>

    <div class="text-center">
      <button type="button" data-action="click->activities--surah-order#resetActivity" class="reset-btn px-8 py-3 rounded-lg font-semibold text-lg transition-all duration-200 bg-gradient-to-r from-gray-500 to-gray-600 hover:from-gray-600 hover:to-gray-700 text-white shadow-lg hover:shadow-xl transform hover:scale-105 border-0">
        Reset
      </button>
    </div>

    <script type="application/json" id="correct-order-data">
      <%= data[:correct_order].map { |s| { id: s[:id], chapter_number: s[:chapter_number] } }.to_json.html_safe %>
    </script>
  <% else %>
    <%
      current_surah = data[:current_surah]
      direction = data[:direction]
      n = data[:n]
      
      if mode == 'next'
        question_text = "What surah came after"
        direction_icon = "→"
        show_before_icon = false
      elsif mode == 'previous'
        question_text = "What surah came before"
        direction_icon = "←"
        show_before_icon = true
      elsif mode == 'nth_after'
        question_text = "What is the #{n.ordinalize} surah after"
        direction_icon = "→"
        show_before_icon = false
      elsif mode == 'nth_before'
        question_text = "What is the #{n.ordinalize} surah before"
        direction_icon = "←"
        show_before_icon = true
      end
    %>

    <div class="px-6 py-5 rounded-lg mb-6 bg-gradient-to-br from-blue-50 to-indigo-50 border-2 border-blue-200 shadow-md">
      <div class="text-center">
        <div class="inline-block px-4 py-2 rounded-full bg-blue-500 text-white text-sm font-semibold mb-3">
          Surah <%= current_surah.chapter_number %>
        </div>
        <h3 class="text-4xl font-bold mb-3 text-gray-800 tracking-wide">
          <%= current_surah.name_simple %>
        </h3>
        <div class="flex items-center justify-center gap-3 mt-4">
          <% if show_before_icon %>
            <span class="text-3xl text-blue-600 font-bold">?</span>
            <span class="text-2xl text-blue-600"><%= direction_icon %></span>
          <% end %>
          <p class="text-xl font-semibold text-gray-700">
            <%= question_text %> this surah?
          </p>
          <% unless show_before_icon %>
            <span class="text-2xl text-blue-600"><%= direction_icon %></span>
            <span class="text-3xl text-blue-600 font-bold">?</span>
          <% end %>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-6" id="options">
      <% data[:options].each do |option| %>
        <button class="surah-option px-6 py-4 rounded-lg font-semibold text-lg transition-all duration-200 bg-gradient-to-r from-blue-500 to-indigo-500 hover:from-blue-600 hover:to-indigo-600 text-white shadow-lg hover:shadow-xl transform hover:scale-105 option border-0" data-correct="<%= option[:correct] %>">
          <%= option[:name] %>
        </button>
      <% end %>
    </div>
  <% end %>
</div>
