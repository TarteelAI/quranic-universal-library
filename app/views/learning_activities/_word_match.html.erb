<%
  data = generate_word_match_quiz
  pairs = data[:pairs]
  left_words = data[:left_words]
  right_translations = data[:right_translations]
%>

<h2 class="heading my-3 text-2xl md:text-3xl font-bold text-center mb-4 md:mb-6 text-gray-800 px-2">
  Word Match Challenge
</h2>

<div class="quiz p-2 md:p-4 rounded-3 word-match" data-controller="activities--word-match">
  <div class="px-3 md:px-6 py-3 md:py-4 rounded-lg mb-4 md:mb-6 bg-gradient-to-r from-blue-50 to-indigo-50 border-2 border-blue-200 shadow-md">
    <div class="flex items-center justify-center gap-2 md:gap-3 flex-wrap text-center">
      <span class="font-bold text-blue-700 text-sm md:text-base">How to play:</span>
      <span class="text-gray-700 text-xs md:text-sm">Click on a word or dot to start a line and connect it to the matching translation.</span>
    </div>
  </div>

  <div class="flex flex-column flex-md-row gap-3 md:gap-6 relative" id="match-area">
    <div class="flex-fill">
      <div class="text-center mb-2 md:mb-4">
        <h3 class="text-lg md:text-2xl font-bold text-blue-600 mb-1 md:mb-2">Arabic Words</h3>
        <div class="inline-block px-3 md:px-4 py-1 rounded-full bg-blue-500 text-white text-xs md:text-sm font-semibold">
          <%= left_words.length %> words
        </div>
      </div>
      <div class="list-group border-2 border-blue-200 rounded-lg shadow-lg bg-white p-1 md:p-2" id="left-column">
        <% left_words.each do |w| %>
          <div class="list-group-item flex items-center justify-between qpc-hafs rounded-lg mb-1 md:mb-2 border-2 border-gray-100 shadow-sm bg-gradient-to-r from-blue-50 to-white hover:from-blue-100 hover:border-blue-300 transition-all duration-200 cursor-pointer py-2 md:py-3"
               data-id="<%= w[:id] %>">
            <div class="flex items-center gap-2 md:gap-3">
              <span class="anchor-dot ms-1 md:ms-2 bg-blue-500 border-2 border-white shadow-md rounded-full w-6 h-6 md:w-5 md:h-5 transition-all hover:scale-125" data-side="left"></span>
              <span class="qpc-hafs text-base md:text-xl font-bold text-gray-800"><%= w[:text] %></span>
            </div>
            <div class="flex items-center gap-2"><span class="status-icon"></span></div>
          </div>
        <% end %>
      </div>
    </div>

    <div class="flex-fill">
      <div class="text-center mb-2 md:mb-4">
        <h3 class="text-lg md:text-2xl font-bold text-green-600 mb-1 md:mb-2">Translations</h3>
        <div class="inline-block px-3 md:px-4 py-1 rounded-full bg-green-500 text-white text-xs md:text-sm font-semibold">
          <%= right_translations.length %> options
        </div>
      </div>
      <div class="list-group border-2 border-green-200 rounded-lg shadow-lg bg-white p-1 md:p-2" id="right-column">
        <% right_translations.each do |t| %>
          <div class="list-group-item flex items-center justify-between rounded-lg mb-1 md:mb-2 border-2 border-gray-100 shadow-sm bg-gradient-to-r from-green-50 to-white hover:from-green-100 hover:border-green-300 transition-all duration-200 cursor-pointer py-2 md:py-3"
               data-id="<%= t[:id] %>">
            <div class="flex items-center gap-2 md:gap-3">
              <span class="anchor-dot me-1 md:me-2 bg-green-500 border-2 border-white shadow-md rounded-full w-6 h-6 md:w-5 md:h-5 transition-all hover:scale-125" data-side="right"></span>
              <span class="text-sm md:text-lg font-semibold text-gray-800"><%= t[:text] %></span>
            </div>
            <div class="flex items-center gap-2"><span class="status-icon"></span></div>
          </div>
        <% end %>
      </div>
    </div>

    <svg id="match-svg" class="absolute top-0 start-0 w-full h-full pointer-events-none"></svg>
  </div>

  <div class="mt-4 md:mt-6">
    <div class="mb-2 flex items-center justify-between text-xs md:text-sm font-semibold text-gray-700">
      <span>Progress</span>
      <span id="progress-text" class="text-blue-600">0%</span>
    </div>
    <div class="w-full bg-gray-200 rounded-full h-6 md:h-8 shadow-inner overflow-hidden">
      <div id="progress-bar" class="h-6 md:h-8 rounded-full text-white text-xs md:text-sm font-bold flex items-center justify-center transition-all duration-500 bg-gradient-to-r from-green-500 to-emerald-500 shadow-lg" role="progressbar" style="width: 0%" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
    </div>
  </div>
</div>
