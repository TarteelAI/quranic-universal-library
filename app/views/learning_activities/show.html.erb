<%
  tarteel_link = 'https://tarteel.go.link/?adj_t=1foxrfdy&adj_engagement_type=fallback_click&adj_fallback=https%3A%2F%2Fwww.tarteel.ai&adj_redirect_macos=https%3A%2F%2Fwww.tarteel.ai'
  activity = (params[:activity] || params[:id]).presence.to_s.downcase
%>
<div class="pt-20 md:pt-32 px-2 md:px-4 pb-10 md:pb-20 quiz-container overflow-auto">
  <div class="box">
    <% if params[:ayah].present? && @filtered_ayah.nil? %>
      <div class="px-4 py-3 rounded mb-4 bg-yellow-100 border border-yellow-400 text-yellow-700">
        <strong>Invalid Ayah:</strong> The ayah "<%= params[:ayah] %>" was not found. Please use the format "chapter:verse" (e.g., "1:1"). Showing random content instead.
      </div>
    <% end %>

    <% if valid_activity?(activity) %>
      <%= set_page_title "#{activity.humanize} - Quranic quiz" %>
      <%= render activity %>
      <%= link_to 'Try another', learning_activity_path(activity), class: 'px-4 py-2 rounded font-medium transition-colors border border-gray-800 text-gray-800 hover:bg-gray-800 hover:text-white me-3 my-3' %>
      <div class="result my-5" id="quiz-result">
        <div class="text-red-600 hidden" id="incorrect-message">
          Incorrect answer. Try again! You can also use Tarteel app to test your memorization. Download
          <a class='text-danger' href="<%= tarteel_link %>" target="_blank">
            Tatreel app here
          </a> to test and improve your memorization.
        </div>
        <div class="hidden text-green-600" id="correct-message">
          Correct! MashaAllah, you got it right. Download
          <a href="<%= tarteel_link %>" target="_blank">Tarteel app</a> to
          memorize more.
        </div>
      </div>
      <div class="more-activities flex justify-center gap-2 mt-4 hidden">
        <% ayah_key = @filtered_ayah&.verse_key || '1:1' %>
        <%= link_to 'Learn more about this ayah', '#_', class: 'px-4 py-2 rounded font-medium transition-colors border border-green-600 text-green-600 hover:bg-green-600 hover:text-white me-3 ayah-info', data: { controller: 'ajax-modal', url: "/ayah/#{ayah_key}", css_class: 'modal-lg ayah-modal', use_turbo: true} %>
        <% next_url = @filtered_ayah ? learning_activity_path(activity, ayah: @filtered_ayah.verse_key) : learning_activity_path(activity) %>
        <%= link_to 'Next Challenge', next_url, class: 'px-4 py-2 rounded font-medium transition-colors border border-gray-800 text-gray-800 hover:bg-gray-800 hover:text-white me-3' %>
        <%= link_to 'More learning activities', learning_activities_path, class: 'px-4 py-2 rounded font-medium transition-colors border border-gray-800 text-gray-800 hover:bg-gray-800 hover:text-white' %>
      </div>
    <% else %>
      <div class="px-4 py-3 rounded mb-4 bg-yellow-100 border border-yellow-400 text-yellow-700">
        This activity does not exist, try one from list below instead?
      </div>
      <ol class="list-none p-0 m-0">
        <% learning_activities.each do |item| %>
          <li class="flex justify-between items-start p-3 border border-gray-200 rounded mb-2 bg-white hover:bg-gray-50">
            <div class="ms-2 me-auto">
              <div class="fw-bold">
                <%= item.title %>
              </div>
              <%= item.description %>
            </div>
            <span>
              <%= link_to 'Try', item.url, class: 'px-4 py-2 rounded font-medium transition-colors bg-green-600 hover:bg-green-700 text-white' %>
            </span>
          </li>
        <% end %>
      </ol>
    <% end %>
  </div>
</div>