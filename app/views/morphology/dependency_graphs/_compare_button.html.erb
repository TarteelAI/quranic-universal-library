<%= turbo_frame_tag "treebank_compare_button", class: "inline-block" do %>
  <% if @compare_mode %>
    <%= link_to morphology_dependency_graph_path(@graph, locale: @locale),
                class: "inline-flex items-center justify-center px-3 py-1.5 bg-red-600 text-white rounded text-sm hover:bg-red-700",
                data: { turbo_stream: true, controller: "tooltip" },
                title: "Close compare" do %>
      <i class="fa fa-times"></i>
    <% end %>
  <% else %>
    <%= link_to morphology_dependency_graph_path(@graph, locale: @locale, compare: 1),
                class: "inline-flex items-center justify-center px-3 py-1.5 bg-blue-600 text-white rounded text-sm hover:bg-blue-700",
                data: { turbo_stream: true, controller: "tooltip" },
                title: "Compare (side-by-side)" do %>
      <i class="fa fa-columns"></i>
    <% end %>
  <% end %>
<% end %>

