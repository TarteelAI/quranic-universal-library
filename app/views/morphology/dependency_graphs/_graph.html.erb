<div>
  <% if collection.any? %>
    <div class="border-0 mb-4 morphology-graph-index" data-controller="graph-settings">
      <div class="bg-gray-100 p-4 rounded-t-lg">
        <div class="flex justify-between items-center flex-wrap gap-4">
          <% if @verse_info %>
            <div>
              <div class="flex items-center gap-2 mb-1">
                <p class="mb-0"><span class="font-semibold">Verse:</span> <%= @verse_info[:verse_key] %></p>

                <% if @navigation[:prev_id] %>
                  <%= link_to morphology_dependency_graph_path(@navigation[:prev_id], locale: @locale), class: 'px-2 py-1 bg-blue-500 text-white rounded text-sm hover:bg-blue-600', title: 'Previous' do %>
                    <i class="fa fa-chevron-left"></i>
                  <% end %>
                <% else %>
                  <span class="px-2 py-1 bg-gray-400 text-white rounded text-sm cursor-not-allowed" title="No previous">
                    <i class="fa fa-chevron-left"></i>
                  </span>
                <% end %>

                <% if @navigation[:next_id] %>
                  <%= link_to morphology_dependency_graph_path(@navigation[:next_id], locale: @locale), class: 'px-2 py-1 bg-blue-500 text-white rounded text-sm hover:bg-blue-600', title: 'Next' do %>
                    <i class="fa fa-chevron-right"></i>
                  <% end %>
                <% else %>
                  <span class="px-2 py-1 bg-gray-400 text-white rounded text-sm cursor-not-allowed" title="No next">
                    <i class="fa fa-chevron-right"></i>
                  </span>
                <% end %>

                <%= form_with url: morphology_dependency_graph_path(@graph), method: :get, local: true, class: 'flex items-center gap-2 ml-3' do %>
                  <%= select_tag :locale,
                      options_for_select([['العربية', 'ar'], ['English', 'en'], ['Urdu', 'ur']], @locale || 'ar'),
                      class: 'px-2 py-1 border border-gray-300 rounded text-sm focus:outline-none focus:ring-1 focus:ring-blue-500',
                      onchange: 'this.form.submit()' %>
                <% end %>
              </div>
              <p class="mb-0 text-sm"><span class="font-semibold">Graph Number:</span> <%= @verse_info[:graph_number] %> of <%= @verse_info[:total_graphs] %></p>
            </div>
          <% end %>

          <div class="text-sm">
            <p class="mb-1"><span class="font-semibold">Total Nodes:</span> <%= collection.count %></p>
            <p class="mb-0">
              <span class="font-semibold">Types:</span>
              Word: <%= collection.where(type: 'word').count %> |
              Reference: <%= collection.where(type: 'reference').count %> |
              Phrase: <%= collection.where(type: 'phrase').count %> |
              Elided: <%= collection.where(type: 'elided').count %>
            </p>
          </div>

          <div>
            <%= render "compare_button" %>

            <button type="button"
                    class="px-3 py-1.5 bg-gray-600 text-white rounded text-sm hover:bg-gray-700"
                    data-action="click->graph-settings#showModal"
                    data-controller="tooltip"
                    title="Graph settings">
              <i class="fa fa-cog"></i>
            </button>

            <button type="button"
                    class="px-3 py-1.5 bg-green-600 text-white rounded text-sm hover:bg-green-700"
                    onclick="document.getElementById('graphSplitterModal').classList.remove('hidden'); document.body.style.overflow = 'hidden';"
                    data-controller="tooltip"
                    title="Split graph">
              <i class="fa fa-scissors"></i>
            </button>
            <%= link_to "<i class='fa fa-edit'></i>".html_safe, edit_morphology_dependency_graph_path(@graph, locale: @locale), class: 'px-3 py-1.5 bg-black text-white rounded text-sm hover:bg-gray-800', data: { controller: 'tooltip' }, title: 'Edit graph' %>
          </div>
        </div>
      </div>

      <%= render "compare_content" %>

      <%= render 'graph_settings' %>

      <%= render 'graph_splitter_modal' %>
    </div>
  <% end %>
</div>

