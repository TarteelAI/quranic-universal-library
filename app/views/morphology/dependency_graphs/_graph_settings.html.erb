<div class="fixed inset-0 z-50 overflow-y-auto hidden" 
     id="graph-settings-modal" 
     tabindex="-1" 
     aria-labelledby="graph-settings-modal-label" 
     aria-hidden="true"
     data-graph-settings-target="modal">
  <!-- Backdrop -->
  <div class="fixed inset-0 bg-black bg-opacity-50 transition-opacity" data-action="click->graph-settings#hideModal"></div>
  <div class="flex min-h-full items-center justify-center p-4">
    <div class="relative bg-white rounded-lg shadow-xl w-full max-w-6xl max-h-[90vh] overflow-hidden">
      <div class="flex items-center justify-between p-4 border-b">
        <h5 class="text-lg font-semibold" id="graph-settings-modal-label">Graph Display Settings</h5>
        <button type="button" class="absolute top-2 right-2 text-gray-400 hover:text-gray-900 bg-transparent hover:bg-gray-200 rounded-lg p-1.5 inline-flex items-center justify-center transition-colors" data-action="click->graph-settings#hideModal" aria-label="Close">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
          </svg>
        </button>
      </div>
      <div class="p-4 overflow-y-auto" style="max-height: calc(90vh - 120px);">
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 mb-4">
          <div>
            <label class="block text-sm font-medium text-gray-600 mb-1">Arabic Font Size</label>
            <input type="number" id="setting-token-font-size" value="34" min="10" max="60"
                   class="w-full px-2 py-1 border border-gray-300 rounded text-sm"
                   data-setting="syntaxGraphTokenFontSize">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-600 mb-1">POS Tag Font Size</label>
            <input type="number" id="setting-tag-font-size" value="12" min="8" max="30"
                   class="w-full px-2 py-1 border border-gray-300 rounded text-sm"
                   data-setting="syntaxGraphTagFontSize">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-600 mb-1">Header Font Size</label>
            <input type="number" id="setting-header-font-size" value="10" min="8" max="24"
                   class="w-full px-2 py-1 border border-gray-300 rounded text-sm"
                   data-setting="syntaxGraphHeaderFontSize">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-600 mb-1">Elided Word Font Size</label>
            <input type="number" id="setting-elided-font-size" value="22" min="10" max="40"
                   class="w-full px-2 py-1 border border-gray-300 rounded text-sm"
                   data-setting="syntaxGraphElidedWordFontSize">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-600 mb-1">Edge Label Font Size</label>
            <input type="number" id="setting-edge-label-font-size" value="13" min="8" max="24"
                   class="w-full px-2 py-1 border border-gray-300 rounded text-sm"
                   data-setting="syntaxGraphEdgeLabelFontSize">
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
          <div>
            <label class="block text-sm font-medium text-gray-600 mb-1">Header Line Spacing</label>
            <input type="number" id="setting-header-line-gap" value="15" min="0" max="60"
                   class="w-full px-2 py-1 border border-gray-300 rounded text-sm"
                   data-setting="syntaxGraphHeaderTextDeltaY">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-600 mb-1">POS Tag Gap</label>
            <input type="number" id="setting-pos-tag-gap" value="25" min="0" max="100"
                   class="w-full px-2 py-1 border border-gray-300 rounded text-sm"
                   data-setting="syntaxGraphPosTagGap">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-600 mb-1">Bracket Offset (Y)</label>
            <input type="number" id="setting-bracket-delta-y" value="16" min="0" max="60"
                   class="w-full px-2 py-1 border border-gray-300 rounded text-sm"
                   data-setting="syntaxGraphBracketDeltaY">
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
          <div>
            <label class="block text-sm font-medium text-gray-600 mb-1">Word Gap</label>
            <input type="number" id="setting-word-gap" value="63" min="0" max="200"
                   class="w-full px-2 py-1 border border-gray-300 rounded text-sm"
                   data-setting="syntaxGraphWordGap">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-600 mb-1">Arabic Y Offset</label>
            <input type="number" id="setting-header-extra-gap" value="10" min="0" max="60"
                   class="w-full px-2 py-1 border border-gray-300 rounded text-sm"
                   data-setting="syntaxGraphHeaderExtraGap">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-600 mb-1">POS Tag Y Offset</label>
            <input type="number" id="setting-pos-tag-y-offset" value="65" min="0" max="200"
                   class="w-full px-2 py-1 border border-gray-300 rounded text-sm"
                   data-setting="syntaxGraphPosTagYOffset">
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
          <div>
            <label class="block text-sm font-medium text-gray-600 mb-1">Default Font</label>
            <input type="text" id="setting-default-font" value="Helvetica Neue, Arial, sans-serif"
                   class="w-full px-2 py-1 border border-gray-300 rounded text-sm"
                   data-setting="defaultFont">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-600 mb-1">Arabic Font</label>
            <%= select_tag :arabic_font,
                            options_for_select(
                            [["Select", ""]] + arabic_fonts_options,
                            params[:arabic_font]
                            ),
                            id: "setting-arabic-font",
                            data: { setting: "defaultArabicFont" },
                            class: "w-full px-2 py-1 border border-gray-300 rounded text-sm" %>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-600 mb-1">Elided Word Font</label>
            <input type="text" id="setting-elided-word-font" value="Arial, sans-serif"
                   class="w-full px-2 py-1 border border-gray-300 rounded text-sm"
                   data-setting="elidedWordFont">
          </div>
        </div>
      </div>
      <div class="flex items-center justify-end gap-2 p-4 border-t">
        <div class="flex gap-2">
          <button type="button" id="apply-graph-settings" data-action="click->graph-settings#apply click->graph-settings#hideModal"
                  class="px-3 py-1.5 bg-blue-600 text-white rounded text-sm hover:bg-blue-700">
            Apply Settings
          </button>
          <button type="button" id="reset-graph-settings" data-action="click->graph-settings#reset click->graph-settings#hideModal"
                  class="px-3 py-1.5 bg-gray-500 text-white rounded text-sm hover:bg-gray-600">
            Reset to Defaults
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

