<%= render 'tools/header',
           name: 'Ayah Dependency Graphs',
           key: 'ayah_dependency_graph',
           wide_container: true
%>

<div class="page-wrapper container px-4">
  <div class="page-section">
    <div class="w-full">
      <div class="bg-white border border-gray-200 rounded-lg shadow-sm mb-4">
        <div class="flex justify-between items-center bg-gray-50 p-3 border-b border-gray-200">
          <div class="flex items-center gap-3">
            <strong>Verse:</strong><%= @graph.verse_key %> (Graph <%= @graph.graph_number %>)
          </div>
          <h3 class="text-xl mb-0">Edit Syntax Graph</h3>
          <div>
            <%= link_to 'Back to detail', morphology_dependency_graph_path(@graph), class: 'px-3 py-1.5 bg-black text-white rounded text-sm hover:bg-black-700' %>
          </div>
        </div>

        <div class="p-4">
          <% if flash[:alert] %>
            <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded mb-4">
              <%= flash[:alert] %>
            </div>
          <% end %>
          
          <% if flash[:notice] %>
            <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded mb-4">
              <%= flash[:notice] %>
            </div>
          <% end %>

          <%= hidden_field_tag :graph_id, @graph.id, id: 'graph_id' %>

          <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
            <div class="lg:col-span-9">
              <%= render 'nodes_section', presenter: @presenter, graph_id: @graph.id %>
              <%= render 'phrase_nodes_section', presenter: @presenter, graph_id: @graph.id %>
              <%= render 'edges_section', presenter: @presenter, graph_id: @graph.id %>
            </div>

            <div class="lg:col-span-3">
              <div class="sticky top-6">
                <div class="bg-white border border-gray-200 rounded-lg shadow-sm" id="graph_preview_panel">
                  <div class="flex justify-between items-center py-2 bg-gray-50 px-3 border-b border-gray-200">
                    <h2 class="text-lg font-semibold m-0">Preview</h2>
                    <div>
                      <button type="button" 
                              class="px-2 py-1 text-sm rounded font-medium transition-colors border border-gray-600 text-gray-600 hover:bg-gray-600 hover:text-white me-1"
                              onclick="window.dispatchEvent(new CustomEvent('refresh-graph-preview'));"
                              title="Refresh">
                        <i class="fa fa-refresh"></i>
                      </button>
                      <button type="button" 
                              class="px-2 py-1 text-sm rounded font-medium transition-colors border border-blue-600 text-blue-600 hover:bg-blue-600 hover:text-white"
                              onclick="document.getElementById('graphPreviewModal').classList.remove('hidden'); document.body.style.overflow = 'hidden';"
                              title="Expand">
                        <i class="fa fa-expand"></i>
                      </button>
                    </div>
                  </div>
                  <div class="p-2 bg-white">
                    <div class="syntax-graph-container rounded bg-gray-100 min-h-[150px] max-h-[50vh] overflow-auto"
                         data-controller="syntax-graph"
                         data-syntax-graph-url-value="<%= syntax_graph_morphology_dependency_graph_path(@graph) %>"
                         id="graph_preview_container">
                      <div data-syntax-graph-target="container" class="p-3 text-center text-gray-500">Loading syntax graph...</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="fixed inset-0 z-50 overflow-y-auto hidden" id="graphPreviewModal" tabindex="-1" aria-labelledby="graphPreviewModalLabel" aria-hidden="true">
  <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('graphPreviewModal').classList.add('hidden'); document.body.style.overflow = '';"></div>
  <div class="flex min-h-full items-center justify-center p-4">
    <div class="relative bg-white rounded-lg shadow-xl w-full max-w-6xl">
      <div class="flex items-center justify-between p-4 border-b">
        <h5 class="text-lg font-semibold" id="graphPreviewModalLabel">
          Graph Preview - <%= @graph.verse_key %> (Graph <%= @graph.graph_number %>)
        </h5>
        <div class="flex items-center gap-2">
          <button type="button" 
                  class="px-3 py-1.5 text-xs font-medium bg-transparent text-gray-600 border border-gray-600 hover:bg-gray-600 hover:text-white rounded transition-colors"
                  onclick="window.dispatchEvent(new CustomEvent('refresh-graph-preview'));">
            <i class="fa fa-refresh"></i> Refresh
          </button>
          <button type="button" class="absolute top-2 right-2 text-gray-400 hover:text-gray-900 bg-transparent hover:bg-gray-200 rounded-lg p-1.5 inline-flex items-center justify-center transition-colors" onclick="document.getElementById('graphPreviewModal').classList.add('hidden'); document.body.style.overflow = '';" aria-label="Close">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
              <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          </button>
        </div>
      </div>
      <div class="p-4">
        <div class="syntax-graph-container bg-gray-100 min-h-[500px] max-h-[80vh] overflow-auto"
             data-controller="syntax-graph"
             data-syntax-graph-url-value="<%= syntax_graph_morphology_dependency_graph_path(@graph) %>"
             id="graph_preview_modal_container">
          <div data-syntax-graph-target="container" class="p-3">Loading syntax graph...</div>
        </div>
      </div>
    </div>
  </div>
</div>
