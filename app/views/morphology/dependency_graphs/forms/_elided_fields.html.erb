<%
  field_name_prefix = "nodes[#{node_id}]"
  value ||= ''
  pos ||= ''
%>
<div class="flex gap-2">
  <div class="mb-2 w-1/2">
    <label class="block text-sm font-medium text-gray-700 mb-1">Value:</label>
    <%= text_field_tag field_name_prefix + "[value]", 
                       value,
                       class: 'w-full border border-gray-300 rounded px-2 py-2 text-sm',
                       placeholder: 'e.g., *',
                       data: { node_id: node_id, field: 'value', action: 'change->graph-bulk-edit#saveNodeField' } %>
  </div>
  <div class="w-1/2">
    <label class="block text-sm font-medium text-gray-700 mb-1">POS:</label>
    <%= text_field_tag field_name_prefix + "[pos]", 
                       pos,
                       class: 'w-full border border-gray-300 rounded px-2 py-2 text-sm',
                       placeholder: 'POS tag',
                       data: { node_id: node_id, field: 'pos', action: 'change->graph-bulk-edit#saveNodeField' } %>
  </div>
</div>
