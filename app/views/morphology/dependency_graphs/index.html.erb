<%= render 'tools/header',
           name: 'Ayah Dependency Graphs',
           key: 'ayah_dependency_graph',
           wide_container: true
%>

<div class="page-wrapper container px-4">
  <div class="page-section filters">
    <%= form_tag morphology_dependency_graphs_path, method: :get do %>
      <div data-controller="chapter-verses-filter" class="flex flex-wrap">
        <%= render 'shared/filters' %>

        <div class="mb-4 me-4">
          <%= select_tag :review_status,
                         options_for_select([['All', ''], ['Approved', 'approved'], ['In progress', 'in_progress']], params[:review_status].to_s),
                         class: 'w-44 border border-gray-300 rounded px-2 py-2 text-sm bg-white h-[38px]' %>
          <label class="block text-sm font-medium text-gray-700">Status</label>
        </div>

        <%
          pos_tags = I18n.t('morphology.pos_tags', locale: :en, default: {}).to_h
          pos_tags = pos_tags.except('pronoun')
          pos_options = pos_tags.map { |k, v| ["#{v} (#{k})", k] }.sort_by { |opt| opt[0].to_s }

          edge_relations = I18n.t('morphology.edge_relations', locale: :en, default: {}).to_h
          edge_options = edge_relations.map { |k, v| ["#{v} (#{k})", k] }.sort_by { |opt| opt[0].to_s }
        %>

        <div class="mb-4 me-4">
          <%= select_tag :pos_tag,
                         options_for_select([['Any', '']] + pos_options, params[:pos_tag].to_s),
                         class: 'w-44 border border-gray-300 rounded px-2 py-2 text-sm bg-white h-[38px]',
                         data: { controller: 'select2', placeholder: 'POS tag' } %>
          <label class='block text-sm font-medium text-gray-700'>
            Filter by POS tag
          </label>
        </div>

        <div class="mb-4 me-4">
          <%= select_tag :edge_relation,
                         options_for_select([['Any', '']] + edge_options, params[:edge_relation].to_s),
                         class: 'w-44 border border-gray-300 rounded px-2 py-2 text-sm bg-white h-[38px]',
                         data: { controller: 'select2', placeholder: 'Edge relation' } %>
          <label class="block text-sm font-medium text-gray-700">
            Filter by Edge relation
          </label>
        </div>

        <div class="mb-4 me-4">
          <%= select_tag :with_graphs,
                         options_for_select([['All', '0'], ['Only with graphs', '1']], params[:with_graphs].to_s.presence || '0'),
                         class: 'w-44 border border-gray-300 rounded px-2 py-2 text-sm bg-white h-[38px]' %>
          <label class="block text-sm font-medium text-gray-700">With graphs</label>
        </div>

        <div class="mb-4">
          <%= submit_tag 'Filter', class: 'btn btn-success mr-3 h-[38px]', data: { disable_with: 'Please wait..' } %>
          <%= link_to 'Clear', morphology_dependency_graphs_path, class: 'text-sm text-gray-700 hover:underline' if has_filters?(:filter_chapter, :verse_number, :verse_key, :review_status, :with_graphs, :pos_tag, :edge_relation) %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="page-section mt-4">
    <h2 class="text-2xl mb-4">Ayah list</h2>

    <div class="tools-table-overflow">
      <table class="w-full hover:bg-gray-50">
        <thead class="sticky top-0 z-10 bg-white border-b-2 border-black">
          <tr>
            <th>Key</th>
            <th>Ayah</th>
            <th>Graphs</th>
            <th>Review status</th>
            <th>Actions</th>
          </tr>
        </thead>

        <tbody>
          <% @verses.each do |verse| %>
            <tr class="hover:bg-gray-200 border-b">
              <th scope="row" class="py-2 pl-2"><%= verse.verse_key %></th>
              <td class="py-2">
                <div class="text-qpc-hafs text-left">
                  <%= truncate verse.text_qpc_hafs, length: 70 %>
                </div>
              </td>
              <td class="py-2"><%= verse.try(:graphs_count).to_i %></td>
              <td class="py-2"><%= verse.try(:review_status_label).to_s.humanize %></td>
              <td class="py-2">
                <% if verse.try(:graphs_count).to_i > 0 %>
                  <%= link_to 'View',
                              morphology_dependency_graph_path(verse.try(:first_graph_id)),
                              class: 'btn btn-success' %>
                <% else %>
                  <span class="inline-flex items-center justify-center px-3 py-1.5 rounded text-sm font-medium bg-gray-200 text-gray-500 cursor-not-allowed">View</span>
                <% end %>
              </td>
            </tr>
          <% end %>

          <tr>
            <td colspan="5">
              <%= pagination_section @pagy %>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

