<%= render 'layouts/qul_head' %>

<div class="container mx-auto px-4 py-6">
  <div class="flex items-start justify-between gap-4 flex-wrap">
    <div class="text-2xl md:text-3xl font-semibold text-gray-900">
      <%= @presenter.title %>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to '#_', class: "px-3 py-1.5 bg-white text-gray-900 rounded text-sm border border-gray-200 hover:bg-gray-50",
                  data: { controller: 'ajax-modal', url: @presenter.read_ayah_path, css_class: 'modal-lg', use_turbo: true } do %>
        Read ayah
      <% end %>

      <%= link_to morphology_dependency_graph_path(@presenter.ayah_graph), class: "px-3 py-1.5 bg-white text-gray-900 rounded text-sm border border-gray-200 hover:bg-gray-50" do %>
        Dependency graph
      <% end %>
    </div>
  </div>

  <div class="mt-2 flex items-center gap-3 flex-wrap">
    <div class="text-sm text-gray-600">
      <%= @presenter.word_location %>
    </div>

    <div class="flex items-center gap-2">
      <% if @presenter.prev_word_path.present? %>
        <%= link_to @presenter.prev_word_path, class: "px-2 py-1 bg-blue-600 text-white rounded text-sm hover:bg-blue-700" do %>
          <i class="fa fa-chevron-left"></i>
        <% end %>
      <% else %>
        <span class="px-2 py-1 bg-gray-300 text-white rounded text-sm cursor-not-allowed"><i class="fa fa-chevron-left"></i></span>
      <% end %>
      <% if @presenter.next_word_path.present? %>
        <%= link_to @presenter.next_word_path, class: "px-2 py-1 bg-blue-600 text-white rounded text-sm hover:bg-blue-700" do %>
          <i class="fa fa-chevron-right"></i>
        <% end %>
      <% else %>
        <span class="px-2 py-1 bg-gray-300 text-white rounded text-sm cursor-not-allowed"><i class="fa fa-chevron-right"></i></span>
      <% end %>
    </div>
  </div>

  <div class="mt-8 flex justify-center">
    <% if @presenter.segments.any? %>
      <div class="text-qpc-hafs text-6xl md:text-7xl font-bold text-center">
        <% @presenter.segments.each do |segment| %><span class="<%= @presenter.pos_text_class(segment.part_of_speech_key) %>"><%= segment.text_qpc_hafs.presence || segment.text_uthmani %></span><% end %>
      </div>
    <% else %>
      <div dir="rtl" class="qpc-hafs arabic text-6xl md:text-7xl leading-none font-bold"><%= @presenter.word&.text_qpc_hafs.presence || @presenter.word&.text_uthmani %></div>
    <% end %>
  </div>

  <div class="mt-4 flex justify-center">
    <div class="bg-white rounded p-3 inline-block border border-gray-200">
      <img class="max-w-full h-auto" alt="<%= @presenter.word_location %>" src="<%= @presenter.corpus_image_url %>">
    </div>
  </div>

  <div class="mt-4 text-sm text-gray-700 flex flex-col gap-1 items-center">
    <div><span class="font-semibold">Meaning:</span> <%= @presenter.meaning %></div>
    <div><span class="font-semibold">Transliteration:</span> <%= @presenter.transliteration %></div>
  </div>

  <div class="mt-6 bg-gray-100 rounded p-5">
    <div class="text-sm text-gray-700"><%= safe_html @presenter.description_html %></div>
  </div>

  <% if @presenter.segments.any? %>
    <div class="mt-8 bg-white rounded border border-gray-200">
      <div class="px-5 py-4 flex items-center justify-between gap-4 flex-wrap">
        <div>
          <div class="text-base font-semibold text-gray-900">Segments</div>
          <div class="mt-1 text-xs text-gray-500">Word <%= @presenter.word_location %> has <%= @presenter.segments.size %> segments</div>
        </div>
      </div>
      <div class="border-t border-gray-200 divide-y divide-gray-200">
        <% @presenter.segments.each do |segment| %>
          <div class="px-5 py-4">
            <div dir="rtl" class="text-qpc-hafs text-4xl md:text-5xl font-bold leading-none">
              <span class="<%= @presenter.pos_text_class(segment.part_of_speech_key) %>"><%= segment.text_uthmani %></span>
            </div>
            <div class="mt-2 text-sm text-gray-700 flex flex-wrap gap-x-2 gap-y-1">
              <span class="font-semibold"><%= segment.part_of_speech_name.presence || segment.part_of_speech_key.presence || "-" %></span>
              <% if segment.grammar_term_name.present? %>
                <span class="text-gray-400">•</span>
                <span><%= segment.grammar_term_name.humanize %></span>
              <% end %>
              <% if segment.grammar_term_desc_english.present? %>
                <span class="text-gray-400">•</span>
                <span class="text-gray-600"><%= safe_html segment.grammar_term_desc_english %></span>
              <% end %>
            </div>
            <% if segment.grammar_term_desc_arabic.present? %>
              <div dir="rtl" class="mt-1 text-sm text-gray-700 arabic"><%= safe_html segment.grammar_term_desc_arabic %></div>
            <% end %>
            <% if segment.topic_id.present? %>
              <div class="mt-2 text-sm" dir="ltr">
                <a class="text-blue-700 underline" href="<%= @presenter.topic_path(segment.topic_id) %>"><%= @presenter.topic_label(segment.topic) %></a>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="mt-8 bg-white rounded border border-gray-200 px-5 py-4">
    <div class="text-base font-semibold text-gray-900">Word info</div>
    <div class="mt-3 grid grid-cols-1 md:grid-cols-2 gap-3 text-sm text-gray-700">
      <div>
        <span class="font-semibold">Lemma:</span>
        <% if @presenter.lemma_modal_url.present? %>
          <%= link_to @presenter.lemma_text, '#_', class: "text-blue-700 underline",
                      data: { controller: 'ajax-modal', css_class: 'modal-lg', url: @presenter.lemma_modal_url } %>
        <% else %>
          <%= @presenter.lemma_text %>
        <% end %>
      </div>
      <div>
        <span class="font-semibold">Stem:</span>
        <% if @presenter.stem_modal_url.present? %>
          <%= link_to @presenter.stem_text, '#_', class: "text-blue-700 underline",
                      data: { controller: 'ajax-modal', css_class: 'modal-lg', url: @presenter.stem_modal_url } %>
        <% else %>
          <%= @presenter.stem_text %>
        <% end %>
      </div>
      <div>
        <span class="font-semibold">Root:</span>
        <% if @presenter.root_modal_url.present? %>
          <%= link_to @presenter.root_text, '#_', class: "text-blue-700 underline",
                      data: { controller: 'ajax-modal', css_class: 'modal-lg', url: @presenter.root_modal_url } %>
        <% else %>
          <%= @presenter.root_text %>
        <% end %>
      </div>
      <div><span class="font-semibold">Case:</span> <%= @presenter.case_text %></div>
      <div class="md:col-span-2"><span class="font-semibold">Case reason:</span> <%= @presenter.case_reason_text %></div>
    </div>
  </div>
</div>


