<%= turbo_frame_tag 'add-ayah' do %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= label_tag 'add_ayah_key', 'Add ayah', class: 'block text-xs font-bold text-blue-600 uppercase tracking-wider mb-1' %>
      <%= select_tag 'add_ayah_key', options_for_select(Verse.order('id asc').pluck(:verse_key, :verse_key)), include_blank: true, class: 'w-full px-3 py-2 border border-blue-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white add-suggestion', data: { placeholder: 'Select ayah to add', controller: 'select2' } %>
    </div>

    <div>
      <%= label_tag 'search', 'Search ayah', class: 'block text-xs font-bold text-blue-600 uppercase tracking-wider mb-1' %>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <i class="fas fa-search text-blue-300 text-xs"></i>
        </div>
        <%= search_field 'search', '', class: 'w-full pl-9 px-3 py-2 border border-blue-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white search-suggestion', placeholder: 'search using ayah key (e.g. 1:1)' %>
      </div>
    </div>
  </div>
<% end %>