<%
  ayah = options[:ayah]
  ranges = options[:matches]&.compact_blank.presence || []
  matcher = options[:matcher]
  phrase_ayah_id = options[:phrase_ayah_id]
  persisted = phrase_ayah_id
  skipped_words = options[:skipped_words] || []
%>

<div
  id="<%= dom_id ayah %>"
  data-ranges="<%= ranges %>"
  data-ayahid="<%= ayah.id %>"
  data-ayahkey="<%= ayah.verse_key %>"
  class="ayah bg-white rounded-xl border-2 <%= persisted ? 'border-green-500 shadow-md' : 'border-gray-100 shadow-sm' %> p-5 mb-4 transition-all hover:border-blue-200">

  <div class="flex justify-between items-center mb-4 pb-4 border-b border-gray-50">
    <div class="flex items-center gap-2">
      <% if persisted %>
        <%= link_to "/cms/morphology_phrase_verses/#{phrase_ayah_id}",
                    target: '_blank',
                    title: 'See ayah in admin',
                    data: { controller: 'tooltip' } do %>

          <div class="flex items-center justify-center w-6 h-6 rounded-full bg-green-500 text-white text-xs">
            <i class="fas fa-check"></i>
          </div>
        <% end %>
      <% end %>

      <span class="px-2.5 py-0.5 rounded-md text-sm font-bold bg-gray-800 text-white">
        <%= ayah.verse_key %>
      </span>
      <span class="px-2.5 py-0.5 rounded-md text-xs font-medium bg-blue-50 text-blue-700 border border-blue-100">
        <%= matcher %>
      </span>
      <% if ranges.any? %>
        <span class="px-2.5 py-0.5 rounded-md text-xs font-mono bg-gray-100 text-gray-600">
          <%= ranges.inspect %>
        </span>
      <% end %>
    </div>

    <div class="flex items-center gap-1.5">
      <% if @access %>
        <button
          class="h-8 px-3 text-xs font-medium bg-green-600 hover:bg-green-700 text-white rounded transition-colors flex items-center gap-1.5"
          data-action="savePhrase"
          title="Save phrase"
          data-controller="tooltip">
          <i class="fas fa-save"></i>
          <span class="hidden md:inline">Save</span>
        </button>

        <button
          class="h-8 w-8 flex items-center justify-center bg-white border border-slate-300 text-slate-600 hover:bg-slate-50 rounded transition-colors"
          data-action="resetSelection"
          title="Reset selection"
          data-controller="tooltip">
          <i class="fas fa-redo-alt text-xs"></i>
        </button>

        <button
          class="h-8 w-8 flex items-center justify-center bg-white border border-red-200 text-red-600 hover:bg-red-50 rounded transition-colors"
          data-action="removePhrase"
          title="Remove phrase"
          data-controller="tooltip">
          <i class="fas fa-trash text-xs"></i>
        </button>

        <button
          class="h-8 w-8 flex items-center justify-center bg-white border border-slate-300 text-slate-600 hover:bg-slate-50 rounded transition-colors"
          data-action="bookmark"
          title="Bookmark"
          data-controller="tooltip">
          <i class="fas fa-bookmark text-xs"></i>
        </button>
      <% end %>

      <% if persisted %>
        <%= link_to "/cms/morphology_phrase_verses/#{phrase_ayah_id}",
                    target: '_blank',
                    class: 'text-gray-400 hover:text-blue-500 transition-colors',
                    title: 'Open in CMS',
                    data: { controller: 'tooltip' } do %>
          <i class="fas fa-external-link-alt"></i>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="words flex flex-wrap gap-y-6 quran-text">
    <% ayah.words.order('position asc').each do |w| %>
      <% next if w.ayah_mark? %>
      <%
        range = ranges.detect { |r| w.position >= r[0].to_i && w.position <= r[1].to_i } || [-1, -1]
        selected = w.position >= range[0] && w.position <= range[1]
        skipped = skipped_words.include?(w.position)
      %>

      <div
        class="word flex flex-col items-center px-2 relative group <%= 'selected' if selected %> <%= 'removed' if skipped %>"
        data-position="<%= w.position %>">
        <% if @access %>
          <div class="absolute -top-5 opacity-0 group-hover:opacity-100 transition-opacity flex gap-1 z-10">
            <i
              class="fa-solid fa-xmark cursor-pointer text-[10px] w-5 h-5 flex items-center justify-center rounded-full <%= skipped ? 'active bg-red-500 text-white' : 'bg-white text-slate-400 border border-slate-200 hover:bg-red-500 hover:text-white hover:border-red-500' %> shadow-sm"
              data-action="remove"
              title="Exclude"
              data-controller="tooltip"></i>
            <i
              class="fa-solid fa-plus cursor-pointer text-[10px] w-5 h-5 flex items-center justify-center rounded-full <%= selected ? 'active bg-green-500 text-white' : 'bg-white text-slate-400 border border-slate-200 hover:bg-green-500 hover:text-white hover:border-green-500' %> shadow-sm"
              data-action="add"
              title="Include"
              data-controller="tooltip"></i>
          </div>
        <% end %>

        <span class="qpc-hafs text-2xl mb-1 <%= 'text-green-600 font-bold' if selected %> <%= 'text-red-400 line-through' if skipped %>">
          <%= w.text_qpc_hafs %>
        </span>

        <span class="text-xs font-mono text-gray-500 bg-gray-50 px-1.5 py-0.5 rounded">
          <%= w.position %>
        </span>
      </div>
    <% end %>
  </div>
</div>