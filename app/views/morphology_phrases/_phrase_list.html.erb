<div class="tw-bg-slate-50 tw-rounded-xl tw-border tw-border-slate-200 tw-p-6 tw-mb-6">
  <div class="tw-mb-4 tw-flex tw-items-center tw-gap-2">
    <i class="fas fa-filter tw-text-slate-400"></i>
    <h3 class="tw-text-sm tw-font-bold tw-text-slate-700 tw-uppercase tw-tracking-wider">Filters</h3>
  </div>

  <%= form_tag morphology_phrases_path, method: :get do %>
    <div data-controller="chapter-verses-filter" class="tw-flex tw-items-start tw-flex-wrap tw-gap-4">
      <%= render 'shared/filters' %>

      <div class="tw-flex-grow-1 sm:tw-flex-grow-0">
        <%= search_field_tag :text, params[:text], class: 'tw-w-full sm:tw-w-64 tw-px-3 tw-py-2 tw-border tw-border-slate-300 tw-rounded-lg focus:tw-ring-2 focus:tw-ring-blue-500 focus:tw-border-blue-500 tw-transition-all', placeholder: 'Search content...' %>
        <p class="tw-text-xs tw-text-slate-500 tw-mt-1">Keyword search</p>
      </div>

      <div class="tw-flex tw-items-start tw-pt-1">
        <%= submit_tag 'Apply Filters', class: 'tw-h-10 tw-px-6 tw-text-sm tw-font-bold tw-bg-green-600 hover:tw-bg-green-700 tw-text-white tw-rounded-lg tw-transition-all tw-shadow-sm hover:tw-shadow-md', data: { disable_with: 'Loading...' } %>
        <%= link_to 'Clear', morphology_phrases_path, class: 'tw-h-10 tw-px-4 tw-flex tw-items-center tw-text-sm tw-font-medium tw-text-slate-500 hover:tw-text-slate-700 hover:tw-underline tw-transition-colors' if has_filters?(:filter_chapter, :filter_verse, :text) %>
      </div>
    </div>
  <% end %>
</div>

<div class="page-section tw-mt-4">
  <h2 class="tw-text-2xl tw-mb-4">Phrase list</h2>
  <div class="tools-table-overflow">
  <table class="tw-w-full hover:tw-bg-gray-50 tw-mt-4">
    <thead class="tw-sticky tw-top-0 tw-z-10 tw-bg-white tw-border-b-2 tw-border-black">
    <tr>
      <th><%= sort_order_link 'Id', :id %></th>
      <th><%= sort_order_link 'Ayah', :source_verse_id %></th>
      <th><%= sort_order_link 'Occurrence', :occurrence %></th>
      <th><%= sort_order_link 'Verse count', :verses_count %></th>
      <th><%= sort_order_link 'Words count', :words_count %></th>
      <th><%= sort_order_link 'Approved', :approved %></th>
      <th><%= sort_order_link 'Review', :review_status %></th>
      <th class="text-end">Text</th>
      <th>Actions</th>
    </tr>

    </thead>
    <tbody>
    <% @phrases.each do |phrase| %>
      <tr class="hover:tw-bg-gray-200 tw-border-b">
        <td scope="row" class="tw-py-2 tw-pl-2"><%= phrase.id %></td>
        <td class="tw-py-2">
          <%= phrase.source_verse&.verse_key %>
        </td>
        <td class="tw-py-2">
          <%= phrase.occurrence %>
        </td>
        <td class="tw-py-2"><%= phrase.verses_count %></td>
        <td class="tw-py-2"><%= phrase.words_count %></td>
        <td class="tw-py-2">
          <%= phrase.approved? %>
        </td>
        <td class="tw-py-2">
          <%= phrase.review_status %>
        </td>

        <td class="tw-py-2 qpc-hafs">
          <%= phrase.text_qpc_hafs %>
        </td>

        <td class="tw-py-2">
          <div class="tw-flex tw-flex-col tw-gap-2">
            <%= link_to 'Show', morphology_phrase_path(phrase.id), class: 'tw-px-4 tw-py-2 tw-text-sm tw-font-medium tw-bg-green-600 hover:tw-bg-green-700 tw-text-white tw-rounded tw-transition-colors' %>
            <%= link_to 'Admin', [:cms, phrase], target: :_blank, class: 'btn btn-dark' if user_signed_in? %>
          </div>
        </td>
      </tr>
    <% end %>
    <tr>
      <td colspan="4">
        <%= safe_html pagy_nav_tailwind(@pagy) %>
      </td>

      <td colspan="2">
        <%= safe_html pagy_info(@pagy) %>
      </td>
    </tr>
    </tbody>
  </table>
  </div>
</div>
