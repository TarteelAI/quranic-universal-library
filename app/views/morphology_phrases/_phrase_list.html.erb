<div class="bg-slate-50 rounded-xl border border-slate-200 p-6 mb-6">
  <div class="mb-4 flex items-center gap-2">
    <i class="fas fa-filter text-slate-400"></i>
    <h3 class="text-sm font-bold text-slate-700 uppercase tracking-wider">Filters</h3>
  </div>

  <%= form_tag morphology_phrases_path, method: :get do %>
    <div data-controller="chapter-verses-filter" class="flex items-start flex-wrap gap-4">
      <%= render 'shared/filters' %>

      <div class="flex-grow-1 sm:flex-grow-0">
        <%= search_field_tag :text, params[:text], class: 'w-full sm:w-64 px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all', placeholder: 'Search content...' %>
        <p class="text-xs text-slate-500 mt-1">Keyword search</p>
      </div>

      <div class="flex items-start pt-1">
        <%= submit_tag 'Apply Filters', class: 'h-10 px-6 text-sm font-bold bg-green-600 hover:bg-green-700 text-white rounded-lg transition-all shadow-sm hover:shadow-md', data: { disable_with: 'Loading...' } %>
        <%= link_to 'Clear', morphology_phrases_path, class: 'h-10 px-4 flex items-center text-sm font-medium text-slate-500 hover:text-slate-700 hover:underline transition-colors' if has_filters?(:filter_chapter, :filter_verse, :text) %>
      </div>
    </div>
  <% end %>
</div>

<div class="page-section mt-4">
  <h2 class="text-2xl mb-4">Phrase list</h2>
  <div class="tools-table-overflow">
  <table class="w-full hover:bg-gray-50 mt-4">
    <thead class="sticky top-0 z-10 bg-white border-b-2 border-black">
    <tr>
      <th><%= sort_order_link 'Id', :id %></th>
      <th><%= sort_order_link 'Ayah', :source_verse_id %></th>
      <th><%= sort_order_link 'Occurrence', :occurrence %></th>
      <th><%= sort_order_link 'Verse count', :verses_count %></th>
      <th><%= sort_order_link 'Words count', :words_count %></th>
      <th><%= sort_order_link 'Approved', :approved %></th>
      <th><%= sort_order_link 'Review', :review_status %></th>
      <th class="text-end">Text</th>
      <th>Actions</th>
    </tr>

    </thead>
    <tbody>
    <% @phrases.each do |phrase| %>
      <tr class="hover:bg-gray-200 border-b">
        <td scope="row" class="py-2 pl-2"><%= phrase.id %></td>
        <td class="py-2">
          <%= phrase.source_verse&.verse_key %>
        </td>
        <td class="py-2">
          <%= phrase.occurrence %>
        </td>
        <td class="py-2"><%= phrase.verses_count %></td>
        <td class="py-2"><%= phrase.words_count %></td>
        <td class="py-2">
          <%= phrase.approved? %>
        </td>
        <td class="py-2">
          <%= phrase.review_status %>
        </td>

        <td class="py-2 qpc-hafs">
          <%= phrase.text_qpc_hafs %>
        </td>

        <td class="py-2">
          <div class="flex flex-col gap-2">
            <%= link_to 'Show', morphology_phrase_path(phrase.id), class: 'btn btn-success' %>
            <%= link_to 'Admin', [:cms, phrase], target: :_blank, class: 'btn btn-dark' if user_signed_in? %>
          </div>
        </td>
      </tr>
    <% end %>
    <tr>
      <td colspan="9">
        <%= pagination_section @pagy %>
      </td>
    </tr>
    </tbody>
  </table>
  </div>
</div>
