<%= render 'tools/header',
           name: 'Mutashabihat ul Quran',
           title: 'Mutashabihat Phrase Builder',
           key: 'mutashabihat',
           actions: [link_to('Back', morphology_phrases_path, class: 'tw-h-10 tw-px-4 tw-py-2 tw-text-sm tw-font-medium tw-bg-slate-700 hover:tw-bg-slate-800 tw-text-white tw-rounded tw-transition-colors tw-inline-flex tw-items-center')]
%>

<div class="page-wrapper tw-container tw-max-w-7xl tw-mx-auto tw-px-4 tw-pb-12" style="position: relative">
  <div data-controller="mutashabihat-builder" class="mutashabihat">
    <%= form_with url: new_morphology_phrase_path, method: :get do |f| %>
      <%= f.hidden_field :phrase_id, value: @phrase&.id %>

      <div class="page-section tw-mt-6">
        <!-- Info Banner -->
        <div class="tw-bg-blue-50 tw-border-l-4 tw-border-blue-500 tw-p-4 tw-mb-6 tw-rounded-r-lg tw-shadow-sm">
          <div class="tw-flex tw-items-start">
            <div class="tw-flex-shrink-0">
              <i class="fas fa-info-circle tw-text-blue-500 tw-mt-0.5"></i>
            </div>
            <div class="tw-ml-3">
              <h3 class="tw-text-sm tw-font-bold tw-text-blue-800">Pro Tip: Select a Range of Words</h3>
              <div class="tw-mt-1 tw-text-sm tw-text-blue-700">
                <ul class="tw-list-disc tw-list-inside tw-space-y-1">
                  <li>Click the <i class="fa-solid fa-plus tw-text-[10px] tw-w-4 tw-h-4 tw-inline-flex tw-items-center tw-justify-center tw-rounded-full tw-bg-white tw-text-slate-400 tw-border tw-border-slate-200"></i> (Include) or <i class="fa-solid fa-xmark tw-text-[10px] tw-w-4 tw-h-4 tw-inline-flex tw-items-center tw-justify-center tw-rounded-full tw-bg-white tw-text-slate-400 tw-border tw-border-slate-200"></i> (Exclude) button on the start word.</li>
                  <li>Hold down the <strong>Shift key</strong> and click the same button on your end word.</li>
                  <li>The entire range of words between them will instantly update!</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <!-- Source Selection Card -->
        <div class="tw-bg-white tw-rounded-xl tw-shadow-sm tw-border tw-border-gray-200 tw-p-6 tw-mb-6 tw-sticky tw-top-4 tw-z-30">
          <h3 class="tw-text-lg tw-font-semibold tw-text-gray-800 tw-mb-4 tw-flex tw-items-center">
            <i class="fas fa-book-open tw-mr-2 tw-text-blue-500"></i> Source ayah/phrase
          </h3>
          <%
            ayah, range = @phrase_search.source_verse_and_range
            range ||= [-1, -1]
          %>

          <div class="tw-grid tw-grid-cols-1 lg:tw-grid-cols-12 tw-gap-4 tw-mb-6">
            <div class="lg:tw-col-span-6">
              <%= f.label :ayah_key, 'Selected ayah', class: 'tw-block tw-text-sm tw-font-bold tw-text-slate-700 tw-mb-1' %>
              <%= f.select :ayah_key, options_for_select(Verse.order('id asc').pluck(:verse_key, :verse_key), selected: ayah&.verse_key), { include_blank: true }, class: 'tw-w-full tw-px-3 tw-py-2 tw-border tw-border-slate-300 tw-rounded-lg tw-bg-white focus:tw-ring-2 focus:tw-ring-blue-500 focus:tw-border-blue-500 tw-transition-all', id: 'source_ayah', data: { placeholder: 'Select ayah', controller: 'select2' } %>
            </div>

            <div class="lg:tw-col-span-3">
              <%= f.label :word_from, 'Word from', class: 'tw-block tw-text-sm tw-font-bold tw-text-slate-700 tw-mb-1' %>
              <%= f.select :word_from, options_for_select(ayah.words.map do |w|
                ["#{w.position} - #{w.text_qpc_hafs} ", w.position]
              end, selected: range[0]), { include_blank: true }, class: 'tw-w-full tw-px-3 tw-py-2 tw-border tw-border-slate-300 tw-rounded-lg tw-bg-white focus:tw-ring-2 focus:tw-ring-blue-500 focus:tw-border-blue-500 tw-transition-all word-from', data: { placeholder: 'Start', controller: 'select2' } %>
            </div>

            <div class="lg:tw-col-span-3">
              <%= f.label :word_to, 'Word to', class: 'tw-block tw-text-sm tw-font-bold tw-text-slate-700 tw-mb-1' %>
              <%= f.select :word_to, options_for_select(ayah.words.map do |w|
                ["#{w.position} - #{w.text_qpc_hafs} ", w.position]
              end, selected: range[1]), { include_blank: true }, class: 'tw-w-full tw-px-3 tw-py-2 tw-border tw-border-slate-300 tw-rounded-lg tw-bg-white focus:tw-ring-2 focus:tw-ring-blue-500 focus:tw-border-blue-500 tw-transition-all word-to', data: { placeholder: 'End', controller: 'select2' } %>
            </div>
          </div>

          <div class="tw-bg-gray-50 tw-rounded-lg tw-p-4 tw-border tw-border-gray-100">
            <div class="tw-mb-4">
              <%= f.hidden_field :text, value: @phrase_search.phrase_text, id: 'text' %>
              <div class="tw-text-right tw-dir-rtl quran-text qpc-hafs tw-text-2xl tw-leading-loose">
                <span class="tw-text-sm tw-text-gray-400 tw-ml-2 tw-font-sans tw-align-middle"><%= ayah.verse_key %></span>
                <% ayah.words.each do |w| %>
                  <% if !w.ayah_mark? %>
                    <% highlight = w.position >= range[0].to_f && w.position <= range[1].to_f %>
                    <span class="tw-inline-block tw-px-1 <%= highlight ? 'tw-text-green-600 tw-font-bold' : 'tw-text-gray-700' %>">
                      <%= w.text_qpc_hafs %>
                    </span>
                  <% end %>
                <% end %>
              </div>
            </div>
            
            <div class="tw-flex tw-justify-between tw-items-center">
              <div class="tw-flex tw-flex-wrap tw-gap-4">
                <div class="tw-flex tw-items-center">
                  <%= check_box_tag :use_text_search, 1, params[:use_text_search].blank? || params[:use_text_search].to_i == 1, id: 'use_text_search', class: 'tw-w-4 tw-h-4 tw-rounded tw-border-gray-300 tw-text-blue-600 focus:tw-ring-blue-500' %>
                  <%= label_tag :use_text_search, 'Text', class: 'tw-ml-2 tw-text-xs tw-font-medium tw-text-gray-600 tw-cursor-pointer' %>
                </div>

                <div class="tw-flex tw-items-center">
                  <%= check_box_tag :use_root_search, 1, params[:use_root_search].to_i == 1, id: 'use_root_search', class: 'tw-w-4 tw-h-4 tw-rounded tw-border-gray-300 tw-text-blue-600 focus:tw-ring-blue-500' %>
                  <%= label_tag :use_root_search, 'Root', class: 'tw-ml-2 tw-text-xs tw-font-medium tw-text-gray-600 tw-cursor-pointer' %>
                </div>

                <div class="tw-flex tw-items-center">
                  <%= check_box_tag :use_lemma_search, 1, params[:use_lemma_search].to_i == 1, id: 'use_lemma_search', class: 'tw-w-4 tw-h-4 tw-rounded tw-border-gray-300 tw-text-blue-600 focus:tw-ring-blue-500' %>
                  <%= label_tag :use_lemma_search, 'Lemma', class: 'tw-ml-2 tw-text-xs tw-font-medium tw-text-gray-600 tw-cursor-pointer' %>
                </div>

                <div class="tw-flex tw-items-center">
                  <%= check_box_tag :use_lcs_search, 1, params[:use_lcs_search].to_i == 1, id: 'use_lcs_search', class: 'tw-w-4 tw-h-4 tw-rounded tw-border-gray-300 tw-text-blue-600 focus:tw-ring-blue-500' %>
                  <%= label_tag :use_lcs_search, 'LCS', class: 'tw-ml-2 tw-text-xs tw-font-medium tw-text-gray-600 tw-cursor-pointer' %>
                </div>
              </div>

              <%= submit_tag 'Apply Filter', class: 'btn btn-info tw-shadow-sm hover:tw-shadow-md', data: { disable_with: 'Searching...' } %>
            </div>
          </div>
        </div>

        <!-- Results Section -->
        <div class="tw-bg-white tw-rounded-xl tw-shadow-sm tw-border tw-border-gray-200 tw-overflow-hidden" data-controller="tabs">
          <div class="tw-border-b tw-border-gray-100 tw-bg-gray-50/50 tw-px-4">
            <ul class="tw-flex tw-flex-wrap -tw-mb-px tw-text-sm tw-font-medium tw-text-center" role="tablist">
              <li class="tw-mr-2" role="presentation">
                <button class="tw-inline-block tw-p-4 tw-border-b-2 tw-rounded-t-lg tw-border-blue-600 tw-text-blue-600 aria-selected:tw-border-blue-600 aria-selected:tw-text-blue-600 active"
                   data-action="click->tabs#switch"
                   data-tabs-target-value="tab-suggestions"
                   role="tab" aria-selected="true">
                  Suggestions
                  <span class="tw-ml-2 tw-px-2 tw-py-0.5 tw-text-xs tw-font-bold tw-bg-green-100 tw-text-green-700 tw-rounded-full">
                    <%= @suggestions.keys.size %>
                  </span>
                </button>
              </li>

              <li class="tw-mr-2" role="presentation">
                <button class="tw-inline-block tw-p-4 tw-border-b-2 tw-border-transparent tw-rounded-t-lg hover:tw-text-gray-600 hover:tw-border-gray-300"
                   data-action="click->tabs#switch"
                   data-tabs-target-value="tab-ayahs"
                   role="tab" aria-selected="false">
                  Saved Ayahs
                </button>
              </li>
            </ul>
          </div>

          <div class="tab-content tw-p-6">
        <figure class="highlight tw-mt-4 tw-border tw-border-gray-300 tw-my-2 tw-p-2" data-controller="tabs">
          <ul class="nav nav-tabs nav-tabs-clean" role="tablist">
            <li class="tw-m-0">
              <a class="tw-text-gray-700 tw-font-medium tw-no-underline tw-px-3 tw-py-2 tw-rounded hover:tw-bg-gray-200 active"
                 data-action="click->tabs#switch"
                 data-tabs-target-value="tab-suggestions"
                 role="tab" aria-selected="true">
                Suggestions
                <span class="badge badge-success tw-ms-1">
                  <%= @suggestions.keys.size %>
                </span>
              </a>
            </li>

            <li class="tw-m-0">
              <a class="tw-text-gray-700 tw-font-medium tw-no-underline tw-px-3 tw-py-2 tw-rounded hover:tw-bg-gray-200"
                 data-action="click->tabs#switch"
                 data-tabs-target-value="tab-ayahs"
                 role="tab" aria-selected="false">
                Ayahs
              </a>
            </li>
          </ul>

          <div class="tab-content tw-p-3">
            <div class="tab-pane fade active show" id="tab-suggestions" role="tabpanel" aria-labelledby="tab-suggestions">
              <div id="suggestions">
                <div class="tw-bg-blue-50 tw-rounded-lg tw-p-4 tw-mb-6 tw-border tw-border-blue-100">
                  <h4 class="tw-text-sm tw-font-bold tw-text-blue-800 tw-mb-2">Manual Addition</h4>
                  <%= render 'add_ayah' %>
                </div>

                <div id="suggested-ayahs" class="tw-space-y-4">
                  <% if @suggestions.any? %>
                    <% @suggestions.each do |key, suggestion| %>
                      <%= render 'ayah', options: suggestion %>
                    <% end %>
                  <% else %>
                    <div class="tw-text-center tw-py-12 tw-text-gray-500">
                      <i class="fas fa-search tw-text-4xl tw-mb-4 tw-opacity-20"></i>
                      <p>No suggestions found for current selection.</p>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>

            <div class="tab-pane fade tw-hidden" id="tab-ayahs" role="tabpanel" aria-labelledby="tab-ayahs">
              <% if @phrase&.persisted? %>
                <%= turbo_frame_tag 'phrase-verses', src: morphology_phrase_path(@phrase.id, result_type: 'preview'), loading: "lazy", target: 'self' do %>
                  <div class="tw-flex tw-items-center tw-justify-center tw-py-12">
                    <div class="tw-animate-spin tw-rounded-full tw-h-8 tw-w-8 tw-border-b-2 tw-border-blue-600"></div>
                    <span class="tw-ml-3 tw-text-gray-500">Loading saved phrases...</span>
                  </div>
                <% end %>
              <% else %>
                <div class="tw-text-center tw-py-12 tw-text-gray-500">
                  <p>Save this phrase to see it in the Ayahs tab.</p>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
