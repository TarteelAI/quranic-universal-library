<%
  actions = []

  if @access
    actions << link_to('New Phrase', new_morphology_phrase_path, class: 'tw-h-10 btn btn-success btn-sm tw-inline-flex tw-items-center', data: { controller: 'ajax-modal', url: new_morphology_phrase_path(modal: true) })
    actions << link_to('View bookmarks', '#_', class: 'tw-h-10 tw-px-4 tw-py-2 tw-text-sm tw-font-medium tw-bg-slate-700 hover:tw-bg-slate-800 tw-text-white tw-rounded tw-transition-colors tw-inline-flex tw-items-center', data: { controller: 'phrase-ayah-bookmark' })
  end

  if params[:proofread]
    actions << link_to('Phrase view', morphology_phrases_path, class: 'tw-h-10 btn btn-info btn-sm tw-inline-flex tw-items-center')
  else
    actions << link_to('Proofread view', morphology_phrases_path(proofread: true), class: 'tw-h-10 btn btn-info btn-sm tw-inline-flex tw-items-center')
  end
%>

<%= render 'tools/header', name: 'Mutashabihat ul Quran', actions: actions, key: 'mutashabihat' %>

<div class="page-wrapper tw-container tw-max-w-7xl tw-mx-auto tw-px-4">
  <% if params[:proofread] %>
    <%= render 'proofread_list' %>
  <% else %>
    <%= render 'phrase_list' %>
  <% end %>
</div>
