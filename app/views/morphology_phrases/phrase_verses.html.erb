
<%
  phrase_verses = @phrase.phrase_verses.includes(verse: :words)
  phrase_style = "style='color: #{@phrase.get_color}'".html_safe
%>

<% if params[:modal] %>
  <div id=title>
    Phrase ayahs
  </div>
<% else %>
  <%= render 'tools/header',
             name: 'Mutashabihat ul Quran',
             title: "Phrase ayahs",
             key: 'ayah_mutashabihat',
             help: 'mutashabihat'
  %>
<% end %>

<div id="body">
  <div class="p-6">
    <% phrase_verses.each_with_index do |phrase_verse, index| %>
      <div class="bg-white rounded-lg p-4 mb-4 border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
        <div class="flex justify-between items-start mb-3">
          <span class="px-3 py-1 bg-slate-800 text-white text-xs font-bold rounded-full">
            <%= phrase_verse.verse.verse_key %>
          </span>
          
          <div class="text-xs text-gray-400">
            <%= phrase_verse.verse.chapter.name_simple %>
          </div>
      <div class="quran-text qpc-hafs">
        <div class="badge badge-success">
          <%= phrase_verse.verse.verse_key %>
        </div>

        <div class="quran-text qpc-hafs text-2xl leading-loose text-right dir-rtl">
          <% phrase_verse.verse.words.each do |word| %>
              <span <%= phrase_style if phrase_verse.highlight_word?(word) %>>
                <%= word.text_qpc_hafs %>
              </span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
