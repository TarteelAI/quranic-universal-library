
<%
  phrase_verses = @phrase.phrase_verses.includes(verse: :words)
  phrase_style = "style='color: #{@phrase.get_color}'".html_safe
%>

<% if params[:modal] %>
  <div id=title>
    Phrase ayahs
  </div>
<% else %>
  <%= render 'tools/header',
             name: 'Mutashabihat ul Quran',
             title: "Phrase ayahs",
             key: 'ayah_mutashabihat',
             help: 'mutashabihat'
  %>
<% end %>

<div id="body">
  <div class="tw-p-6">
    <% phrase_verses.each_with_index do |phrase_verse, index| %>
      <div class="tw-bg-white tw-rounded-lg tw-p-4 tw-mb-4 tw-border tw-border-gray-100 tw-shadow-sm hover:tw-shadow-md tw-transition-shadow">
        <div class="tw-flex tw-justify-between tw-items-start tw-mb-3">
          <span class="tw-px-3 tw-py-1 tw-bg-slate-800 tw-text-white tw-text-xs tw-font-bold tw-rounded-full">
            <%= phrase_verse.verse.verse_key %>
          </span>
          
          <div class="tw-text-xs tw-text-gray-400">
            <%= phrase_verse.verse.chapter.name_simple %>
          </div>
      <div class="quran-text qpc-hafs">
        <div class="badge badge-success">
          <%= phrase_verse.verse.verse_key %>
        </div>

        <div class="quran-text qpc-hafs tw-text-2xl tw-leading-loose tw-text-right tw-dir-rtl">
          <% phrase_verse.verse.words.each do |word| %>
              <span <%= phrase_style if phrase_verse.highlight_word?(word) %>>
                <%= word.text_qpc_hafs %>
              </span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
