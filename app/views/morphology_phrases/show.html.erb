<% if params[:proofread] %>
  <%
    actions = []
    if previous_ayah = @verse.previous_ayah
      actions << link_to('Previous ayah', morphology_phrase_path(previous_ayah.id, proofread: true), class: 'btn btn-dark')
    end

    if next_ayah = @verse.next_ayah
      actions << link_to('Next ayah', morphology_phrase_path(next_ayah.id, proofread: true), class: 'btn btn-dark')
    end

    actions << link_to('Back', morphology_phrases_path(proofread: true), class: 'h-10 px-4 py-2 text-sm font-medium bg-slate-700 hover:bg-slate-800 text-white rounded transition-colors inline-flex items-center')
  %>

  <%= render 'tools/header',
             name: 'Mutashabihat ul Quran',
             title: "Mutashabihat phrases for ayah #{@verse.verse_key}",
             key: 'ayah_mutashabihat',
             help: 'mutashabihat',
             actions: actions
  %>
  <div class="page-wrapper container max-w-7xl mx-auto px-4 mt-4 relative z-10">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-6">
      <%= render 'ayah_preview', mapping: {
      verse: @verse,
      phrase_verses: @verse.verse_phrases,
    } %>
    </div>
  </div>
<% else %>
  <%= render 'suggestions' %>
<% end %>