<%
  page_number = @mushaf_page.page_number
%>

<%= turbo_frame_tag 'lines-info' do %>
  <div class="text-center mx-3 my-3">
    <h4>Line alignment(page: <%= page_number %>)</h4>
    <% 1.upto(@mushaf.lines_per_page) do |line| %>
      <div id="page-<%= page_number %>-line-<%= line %>">
        <%
          model = MushafLineAlignment.where(mushaf_id: @mushaf.id, page_number: page_number, line_number: line).first_or_initialize
        %>

        <%= form_with model: model, url: save_line_alignment_mushaf_layout_path(@mushaf, line: line, page_number: page_number), method: :put, html: { class: 'form-inline' } do |form| %>
          <div class="flex my-2">
            <a class="px-4 py-2 rounded font-medium transition-colors px-3 py-1 text-sm">
              <%= line %>
            </a>

            <%= form.submit "C", title: 'Center aligned', class: "btn mx-2 text-xs #{ model.is_center_aligned? ? 'btn-success' : 'btn-dark'}", disabled: !@access,  data: {controller: 'tooltip'} %>
            <%= form.submit "J", title: 'Justify line', class: "btn mx-2 text-xs #{ model.is_justified? ? 'btn-success' : 'btn-dark'}",  disabled: !@access, data: {controller: 'tooltip'} %>
            <%= form.submit "B", title: 'Bismillah', class: "btn mx-2 text-xs #{ model.is_bismillah? ? 'btn-success' : 'btn-dark'}", disabled: !@access, data: {controller: 'tooltip'} %>
            <%= form.submit "N", title: 'Surah name', class: "btn mx-2 text-xs #{ model.is_surah_name? ? 'btn-success' : 'btn-dark'}", disabled: !@access, data: {controller: 'tooltip'} %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>