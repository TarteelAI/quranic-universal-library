<tr class="hover:bg-gray-100 border-b" id="page-row-<%= page.page_number %>">
  <td class="py-3 px-4">
    <%= link_to page.page_number, mushaf_layout_path(@mushaf.id, page_number: page.page_number), class: 'font-medium no-underline cursor-pointer page-number-link', data: { turbo_frame: '_top' } %>
  </td>

  <td class="py-3 px-4">
    <% if page.first_ayah_key && page.last_ayah_key %>
      <span class="text-gray-700"><%= page.first_ayah_key %> - <%= page.last_ayah_key %></span>
    <% else %>
      <span class="text-gray-400">Not set</span>
    <% end %>
  </td>

  <td class="py-3 px-4">
    <% status = page_status(page) %>
    <span class="px-2 py-1 rounded-full text-xs font-medium <%= status_badge_class(status) %>">
      <%= status %>
    </span>
  </td>

  <td class="py-3 px-4">
    <% if @access %>
      <div class="flex flex-col gap-3">
        <div class="flex items-center">
          <%
            ayah_range_done = page.first_verse_id.present? && page.last_verse_id.present?
            word_mapping_done = page.first_word_id.present? && page.last_word_id.present?
            line_alignment_done = page.lines_count.to_i > 0
            all_done = ayah_range_done && word_mapping_done && line_alignment_done
          %>
          <div class="w-8 h-8 rounded-full border-2 <%= ayah_range_done ? 'border-[#70DDA7]' : 'border-gray-500' %> flex items-center justify-center text-[#70DDA7] font-bold flex-shrink-0">
            <% if ayah_range_done %>✓
            <% end %>
          </div>
          <div class="h-0.5 flex-1 <%= ayah_range_done ? 'bg-[#70DDA7]' : 'bg-gray-500' %>"></div>
          <div class="w-8 h-8 rounded-full border-2 <%= word_mapping_done ? 'border-[#70DDA7]' : 'border-gray-500' %> flex items-center justify-center text-[#70DDA7] font-bold flex-shrink-0">
            <% if word_mapping_done %>✓
            <% end %>
          </div>
          <div class="h-0.5 flex-1 <%= word_mapping_done ? 'bg-[#70DDA7]' : 'bg-gray-500' %>"></div>
          <div class="w-8 h-8 rounded-full border-2 <%= line_alignment_done ? 'border-[#70DDA7]' : 'border-gray-500' %> flex items-center justify-center text-[#70DDA7] font-bold flex-shrink-0">
            <% if line_alignment_done %>✓
            <% end %>
          </div>
          <div class="h-0.5 flex-1 <%= line_alignment_done ? 'bg-[#70DDA7]' : 'bg-gray-500' %>"></div>
          <div class="w-8 h-8 rounded-full border-2 <%= all_done ? 'border-[#70DDA7]' : 'border-gray-500' %> flex items-center justify-center text-[#70DDA7] font-bold flex-shrink-0">
            <% if all_done %>✓
            <% end %>
          </div>
        </div>
        <div class="flex items-center">
          <div class="min-w-20 flex justify-center flex-shrink-0">
            <%= link_to 'Set Ayah Range', '#_', class: 'text-gray-700 hover:text-[#70DDA7] no-underline cursor-pointer transition-colors text-sm whitespace-nowrap', data: { controller: 'ajax-modal', url: mushaf_layout_path(@mushaf.id, page_number: page.page_number, view_type: 'page_mapping_modal'), css_class: 'modal-xl' } %>
          </div>
          <div class="flex-1"></div>
          <div class="min-w-24 flex justify-center flex-shrink-0">
            <%= link_to 'Update Word lines', edit_mushaf_layout_path(@mushaf.id, page_number: page.page_number), class: 'text-gray-700 hover:text-[#70DDA7] no-underline cursor-pointer transition-colors text-sm whitespace-nowrap', data: { turbo_frame: '_top' } %>
          </div>
          <div class="flex-1"></div>
          <div class="min-w-24 flex justify-center flex-shrink-0">
            <%= link_to 'Fix line alignment', mushaf_layout_path(@mushaf.id, page_number: page.page_number, view_type: 'line_alignment'), class: 'text-gray-700 hover:text-[#70DDA7] no-underline cursor-pointer transition-colors text-sm whitespace-nowrap', data: { turbo_frame: '_top' } %>
          </div>
          <div class="flex-1"></div>
          <div class="min-w-16 flex justify-center flex-shrink-0">
            <%= link_to 'Preview', mushaf_layout_path(@mushaf.id, page_number: page.page_number), class: 'text-gray-700 hover:text-[#70DDA7] no-underline cursor-pointer transition-colors text-sm whitespace-nowrap', data: { turbo_frame: '_top' } %>
          </div>
        </div>
      </div>
    <% else %>
      <%= link_to 'Preview', mushaf_layout_path(@mushaf.id, page_number: page.page_number), class: 'btn btn-info', data: { turbo_frame: '_top', disable_with: 'Preview' } %>
    <% end %>
  </td>
</tr>

