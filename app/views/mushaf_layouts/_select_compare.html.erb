<div id=title>
  Select mushaf to compare with <%= @resource.name %>
</div>

<div id=body>
  <div class="p-6">
    <ul class="list-group">
      <% Mushaf.where.not(id: @mushaf.id).each do |compare| %>
        <li class="list-group-item">
          <%= link_to compare.name, mushaf_layout_path(@mushaf.id, compare: compare.id, page_number: params[:page_number], view_type: 'compare') %>
        </li>
    <% end %>
    </ul>
  </div>

  <div class="flex items-center justify-end p-6 border-t border-gray-200 space-x-2">
    <button type="button" class="px-4 py-2 rounded font-medium transition-colors btn-default" data-dismiss="modal">Close</button>
  </div>
</div>