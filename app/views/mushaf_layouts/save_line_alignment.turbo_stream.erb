<% id = "page-#{@record.page_number}-line-#{@record.line_number}" %>

<%= turbo_stream.replace id do %>
  <div id="<%= id %>">
    <%= form_with model: @record, url: save_line_alignment_mushaf_layout_path(@mushaf, line: @record.line_number, page_number: @record.page_number), method: :put, html: { class: 'form-inline' } do |form| %>
      <div class="flex my-2">
        <a class="btn btn-sm">
          <%= @record.line_number %>
        </a>

        <%= form.submit "C", title: 'Center aligned', class: "mx-2 px-3 py-1.5 text-sm font-medium rounded transition-colors #{ @record.is_center_aligned? ? 'bg-green-600 hover:bg-green-700 text-white' : 'bg-gray-800 hover:bg-gray-900 text-white'}",  data: {controller: 'tooltip'} %>
        <%= form.submit "J", title: 'Justify line', class: "mx-2 px-3 py-1.5 text-sm font-medium rounded transition-colors #{ @record.is_justified? ? 'bg-green-600 hover:bg-green-700 text-white' : 'bg-gray-800 hover:bg-gray-900 text-white'}",  data: {controller: 'tooltip'} %>
        <%= form.submit "B", title: 'Bismillah', class: "mx-2 px-3 py-1.5 text-sm font-medium rounded transition-colors #{ @record.is_bismillah? ? 'bg-green-600 hover:bg-green-700 text-white' : 'bg-gray-800 hover:bg-gray-900 text-white'}",  data: {controller: 'tooltip'} %>
        <%= form.submit "N", title: 'Surah name', class: "mx-2 px-3 py-1.5 text-sm font-medium rounded transition-colors #{ @record.is_surah_name? ? 'bg-green-600 hover:bg-green-700 text-white' : 'bg-gray-800 hover:bg-gray-900 text-white'}", data: {controller: 'tooltip'} %>
      </div>
    <% end %>
  </div>
<% end %>

<%= turbo_stream.replace dom_id(@mushaf_page.mushaf, "page_#{@mushaf_page.page_number}") do %>
  <%= render 'shared/mushaf_page', words: @words, page: @mushaf_page.page_number, mushaf: @mushaf_page.mushaf, name: @resource.name %>
<% end %>
