<%
  page_number = @mushaf_page.page_number
  actions = []
  more_action = []

  turbo_page_options = {
    turbo_frame: 'page',
    turbo_method: 'get',
    turbo_action: "replace"
  }

  turbo_mushaf_page_options = {
    turbo_frame: 'mushaf-page',
    turbo_method: 'get',
    turbo_action: "replace"
  }

  if @access
    more_action << link_to('Update Word lines', edit_mushaf_layout_path(@mushaf.id, page_number: page_number), class: 'block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100', data: turbo_page_options)
    more_action << link_to('Set Ayah Range', mushaf_layout_path(@mushaf.id, page_number: page_number, view_type: 'page_mapping'), class: 'block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100', data: turbo_page_options)
    more_action << link_to('Fix line alignment', mushaf_layout_path(@mushaf.id, page_number: page_number, view_type: 'line_alignment'), class: 'block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100', data: turbo_page_options)
  end

  more_action << link_to('Proofreading view(With pdf)', mushaf_layout_path(@mushaf.id, page_number: page_number, view_type: 'proofreading'), class: 'block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100', data: turbo_page_options)
  more_action << link_to('Preview Page', mushaf_layout_path(@mushaf.id, page_number: page_number), class: 'block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100', data: turbo_page_options)
  more_action << link_to('Compare with', '#_', class: 'block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100', data: { controller: 'ajax-modal', url: mushaf_layout_path(@mushaf.id, page_number: page_number + 1, view_type: 'select_compare') })
  more_action << link_to('Jump to page', '#_', class: 'block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100', data: { controller: 'ajax-modal', url: mushaf_layout_path(@mushaf.id, page_number: page_number, compare: @compared_mushaf&.id, view_type: 'select_page', previous_view_type: params[:view_type]) })

  actions << %Q{
    <div class='relative' data-controller='dropdown'>
      <button class='btn btn-success gap-2' type='button' data-action='click->dropdown#toggle' aria-expanded='false'>
        Actions
        <svg class='w-4 h-4' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
          <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M19 9l-7 7-7-7'></path>
        </svg>
      </button>
      <ul class='absolute right-0 mt-2 w-56 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5 z-50 hidden' data-dropdown-target='menu'>
        #{more_action.map { |action| "<li>#{action}</li>" }.join('')}
      </ul>
    </div>
  }


  actions << link_to('Previous Page', mushaf_layout_path(@mushaf.id, compare: @compared_mushaf&.id, page_number: page_number - 1, view_type: params[:view_type]), class: 'btn btn-dark', data: turbo_mushaf_page_options)
  actions << link_to('Next page', mushaf_layout_path(@mushaf.id, compare: @compared_mushaf&.id, page_number: page_number + 1, view_type: params[:view_type]), class: 'btn btn-dark', data: turbo_mushaf_page_options)

%>
<% actions << link_to(mushaf_layout_path(@mushaf.id, compare: @compared_mushaf&.id, page_number: page_number - 1, view_type: params[:view_type]), class: 'btn btn-dark btn-header-action', data: turbo_mushaf_page_options, aria: { label: 'Previous page' }) do %>
  <span class="inline-flex md:hidden" aria-hidden="true"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg></span>
  <span class="hidden md:inline">Previous Page</span>
<% end %>
<% actions << link_to(mushaf_layout_path(@mushaf.id, compare: @compared_mushaf&.id, page_number: page_number + 1, view_type: params[:view_type]), class: 'btn btn-dark btn-header-action', data: turbo_mushaf_page_options, aria: { label: 'Next page' }) do %>
  <span class="inline-flex md:hidden" aria-hidden="true"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg></span>
  <span class="hidden md:inline">Next page</span>
<% end %>
<% actions << link_to(mushaf_layout_path(@mushaf.id), class: 'btn btn-info btn-header-action', data: { turbo_frame: '_top' }, aria: { label: 'Back to all pages' }) do %>
  <span class="inline-flex md:hidden" aria-hidden="true"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path></svg></span>
  <span class="hidden md:inline">Back to all pages</span>
<% end %>

<%= turbo_frame_tag :page do %>
  <%= render 'tools/header',
             name: @mushaf.name,
             title: "#{@mushaf.name}<br/><div style='font-size: 0.5em'>(Pg##{page_number} Ayahs: #{@mushaf_page.first_ayah_key} - #{@mushaf_page.last_ayah_key})</div>",
             key: 'mushaf_layout',
             actions: actions,
             breadcrumb_parents: [{ label: 'All pages', path: mushaf_layout_path(@mushaf.id), data: { turbo_frame: '_top' } }]
  %>

  <%= render 'shared/access_message' %>

  <div class="page-wrapper container max-w-7xl mx-auto px-4">
    <% if valid_mushaf_view_type?(params[:view_type]) %>
      <%= render "#{params[:view_type]}_view" %>
    <% else %>
      <%= render 'page_preview' %>
    <% end %>
  </div>
<% end %>

