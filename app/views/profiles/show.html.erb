<div class="max-w-[1200px] mx-auto px-4 md:px-8 py-8">
  <div class="grid grid-cols-1 md:grid-cols-[240px_1fr] gap-6">
    <aside class="bg-white border border-black/10 rounded-xl p-6 h-fit">
      <div class="flex flex-col items-center text-center">
        <span class="w-16 h-16 rounded-full bg-[#46ac7a] text-white flex items-center justify-center text-xl font-bold"><%= current_user.initials %></span>
        <div class="mt-3 font-semibold text-black"><%= current_user.name %></div>
        <div class="text-xs text-gray-500 break-all"><%= current_user.email %></div>
        <div class="text-xs text-gray-500 mt-1">Member since <%= current_user.created_at.strftime("%b %Y") %></div>
        <% if current_user.about_me.present? %>
          <p class="text-xs text-gray-600 mt-3"><%= current_user.about_me %></p>
        <% end %>
        <%= link_to "Edit profile", account_settings_path, class: "mt-4 inline-flex items-center gap-1 text-xs font-medium text-[#46ac7a] hover:underline" %>
      </div>
      <div class="mt-6 space-y-3">
        <div class="border border-black/5 rounded-lg p-3 text-center">
          <div class="text-2xl font-bold text-[#46ac7a]"><%= @downloads_count %></div>
          <div class="text-xs text-gray-500">Downloads</div>
        </div>
        <div class="border border-black/5 rounded-lg p-3 text-center">
          <div class="text-2xl font-bold text-[#46ac7a]"><%= @contributions_count %></div>
          <div class="text-xs text-gray-500">Contributions</div>
        </div>
      </div>
    </aside>

    <section data-controller="remote-tab"
             data-remote-tab-active-class="bg-[#46ac7a] text-white"
             data-remote-tab-inactive-class="text-gray-600 hover:text-black">
      <div class="inline-flex gap-1 border border-black/10 rounded-lg p-1 mb-5">
        <%= profile_tab_link "Downloads", "downloads", @tab %>
        <%= profile_tab_link "Contributions", "contributions", @tab %>
      </div>

      <div class="relative min-h-[120px]">
        <div data-remote-tab-target="loader" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-white/60">
          <svg class="animate-spin h-6 w-6 text-[#46ac7a]" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
          </svg>
        </div>

        <%= turbo_frame_tag "profile_panel", data: { action: "turbo:before-fetch-request->remote-tab#showLoader turbo:frame-load->remote-tab#hideLoader" } do %>
          <% if @tab == "downloads" %>
            <%= render "downloads" %>
          <% else %>
            <%= render "contributions" %>
          <% end %>
        <% end %>
      </div>
    </section>
  </div>
</div>
