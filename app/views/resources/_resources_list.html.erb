<%
  view_type = params[:view] == 'grid' ? 'grid' : 'list'

  active_view_class = 'flex gap-2 rounded bg-[#476CFF]/10 text-[#476CFF] font-bold text-sm px-3 py-2 hover:text-[#476CFF] items-center'
  inactive_view_class = 'flex gap-2 rounded font-bold text-sm px-3 py-2 border hover:text-black items-center'
%>

<%= turbo_frame_tag 'resources' do %>
  <div class="resources-lists" data-controller="resource-search">
    <div class="flex items-start md:items-center gap-4 flex-col lg:flex-row justify-between">
      <div class="flex gap-6 items-center w-full md:w-auto justify-between">
        <h2 class="text-2xl md:text-3xl font-light leading-none">
          Available Resources
        </h2>
        <div class="badge badge-resource">
          <%= downloadable_resource_cards.keys.length %>
        </div>
      </div>

      <div class="flex items-center justify-end gap-3 w-full lg:w-1/3 mt-5 md:mt-0">
        <div class="w-full">
          <%= render partial: 'shared/search_input' %>
        </div>
      </div>

      <div class="flex gap-3 items-center">
        View:
        <%= link_to resources_path(view: 'list'), class: "#{view_type == 'list' ? active_view_class : inactive_view_class }", data: { turbo_frame: 'resources' } do %>
          <%= inline_svg_tag('svgs/list.svg') %>
          List
        <% end %>

        <%= link_to resources_path(view: 'grid'), class: "#{view_type == 'grid' ? active_view_class : inactive_view_class }", data: { turbo_frame: 'resources' } do %>
          <%= inline_svg_tag('svgs/grid.svg') %>
          Grid
        <% end %>
      </div>
    </div>

    <div id="empty-results-message" class="hidden mt-4 text-2xl text-gray-500">
      <p>No results found</p>
    </div>
    <div class="w-full">
        <%= render "resources/resources_view/#{view_type}" %>
    </div>
    </div>
<% end %>
