<%
  search_result ||= @resource_search
  view_type ||= 'list'
%>

<% if search_result.result_count.zero? %>
  <div class="tw-mt-8 tw-rounded-3xl tw-border tw-border-dashed tw-border-slate-300 tw-bg-slate-50 tw-p-8 tw-text-center">
    <h2 class="tw-text-xl tw-font-semibold">No results found</h2>
    <p class="tw-mt-2 tw-text-sm tw-text-slate-500">Try a broader term, a different ayah reference, or remove one of the active tags.</p>
  </div>
<% elsif search_result.global && search_result.quran_reference? && search_result.related_results.any? %>
  <section class="tw-mt-8">
    <div class="tw-mb-4">
      <h2 class="tw-text-xl tw-font-semibold">Ayah-capable resources</h2>
      <p class="tw-text-sm tw-text-slate-500">These resources map most directly to the Quran reference you entered.</p>
    </div>
    <%= render "resources/resource_view/#{view_type}", resources: search_result.primary_results, search_context: search_result %>
  </section>

  <section class="tw-mt-10">
    <div class="tw-mb-4">
      <h2 class="tw-text-xl tw-font-semibold">Related resources</h2>
      <p class="tw-text-sm tw-text-slate-500">These are broader datasets and utilities that can still support the same ayah workflow.</p>
    </div>
    <%= render "resources/resource_view/#{view_type}", resources: search_result.related_results, search_context: search_result %>
  </section>
<% else %>
  <div class="tw-mt-8">
    <%= render "resources/resource_view/#{view_type}", resources: search_result.primary_results, search_context: search_result %>
  </div>
<% end %>
