<%
  search_result ||= @resource_search
  title ||= 'Available Resources'
  view_type ||= 'list'
  count ||= search_result&.result_count || 0
  form_url = action_name == 'show' ? resource_path(params[:id]) : resources_path
  active_view_class = 'tw-flex tw-gap-2 tw-rounded tw-bg-[#476CFF]/10 tw-text-[#476CFF] tw-font-bold tw-text-sm tw-px-3 tw-py-2 hover:tw-text-[#476CFF] tw-items-center'
  inactive_view_class = 'tw-flex tw-gap-2 tw-rounded tw-font-bold tw-text-sm tw-px-3 tw-py-2 tw-border hover:tw-text-black tw-items-center'
%>

<div data-controller="resource-search" data-resource-search-mode-value="submit">
  <div class="tw-flex tw-items-start md:tw-items-center tw-gap-4 tw-flex-col lg:tw-flex-row tw-justify-between">
    <div class="tw-flex tw-gap-6 tw-items-center tw-w-full lg:tw-w-auto tw-justify-between">
      <div class="tw-flex tw-gap-4 tw-items-center">
        <h1 class="tw-text-2xl md:tw-text-3xl tw-leading-none tw-text-pretty">
          <%= title %>
        </h1>

        <div class="tw-rounded-full tw-bg-[#E0FAEC] tw-text-[#099a4d] tw-font-bold tw-px-3.5 tw-py-1 tw-leading-none tw-border-2 tw-border-[#56B599] tw-inline-block tw-min-w-[35px] tw-text-center tw-flex-shrink-0">
          <%= count %>
        </div>
      </div>
    </div>

    <div class="tw-flex tw-items-center tw-justify-end tw-gap-3 tw-w-full lg:tw-w-1/2">
      <%= form_with url: form_url, method: :get, data: { turbo_frame: 'resources', turbo_action: 'advance' }, html: { class: 'tw-w-full' } do %>
        <% if params[:view].present? %>
          <%= hidden_field_tag :view, params[:view] %>
        <% end %>

        <% Array(search_result&.selected_resource_types).each do |resource_type| %>
          <%= hidden_field_tag 'resource_types[]', resource_type %>
        <% end %>

        <% Array(search_result&.selected_tags).each do |tag_name| %>
          <%= hidden_field_tag 'tags[]', tag_name %>
        <% end %>

        <div class="tw-flex tw-items-center tw-gap-3">
          <div class="tw-flex-1">
            <%= render partial: 'shared/search_input',
                       locals: {
                         name: :q,
                         value: search_result&.query,
                         placeholder: 'Search by name, tag, or Quran ref like 2:255'
                       } %>
          </div>

          <%= button_tag 'Search',
                         type: :submit,
                         class: 'tw-inline-flex tw-items-center tw-justify-center tw-rounded-full tw-bg-[#476CFF] tw-px-5 tw-py-3 tw-text-sm tw-font-semibold tw-text-white hover:tw-bg-[#3657d8] focus:tw-outline-none focus:tw-ring-2 focus:tw-ring-[#476CFF]/30' %>
        </div>
      <% end %>
    </div>

    <div class="tw-flex tw-gap-3 tw-items-center">
      View:
      <%= link_to current_resources_page_path(view: 'list'), class: "#{view_type == 'list' ? active_view_class : inactive_view_class}", data: { turbo_frame: 'resources', turbo_action: 'advance' } do %>
        <%= inline_svg_tag('svgs/list.svg') %>
        List
      <% end %>

      <%= link_to current_resources_page_path(view: 'grid'), class: "#{view_type == 'grid' ? active_view_class : inactive_view_class}", data: { turbo_frame: 'resources', turbo_action: 'advance' } do %>
        <%= inline_svg_tag('svgs/grid.svg') %>
        Grid
      <% end %>
    </div>
  </div>
</div>
