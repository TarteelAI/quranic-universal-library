<%
  resource_content = resource.resource_content
  text_type = resource_content.meta_value('text-type') || resource_content.meta_value('script')

  key = params[:ayah] || '73:4'
  ayah = Verse.find_by(verse_key: key) || Verse.find_by(verse_key: '73:4')
  script_class = get_quran_script_font_family(text_type, ayah) || 'qpc-hafs'
  by_word = resource_content.word?
  is_image = text_type.include?('image')
%>

<%= render 'shared/page_font', verses: [ayah] %>

<div class="mt-5" data-controller="tabs">
  <ul class="flex flex-nowrap list-none m-0 p-0 border-b border-gray-200" id="quran-script-tab" role="tablist">
    <li class="m-0 flex-none" role="presentation">
      <button class="btn-tab-active"
              id="tab-preview"
              data-action="click->tabs#switch"
              data-tabs-target-value="tab-preview-pane"
              type="button"
              role="tab"
              aria-controls="tab-preview-pane"
              aria-selected="true">
        Preview
      </button>
    </li>
    <li class="m-0 flex-none" role="presentation">
      <button class="btn-tab"
              id="tab-help"
              data-action="click->tabs#switch"
              data-tabs-target-value="tab-help-pane"
              type="button"
              role="tab"
              aria-controls="tab-help-pane"
              aria-selected="false">
        Help
      </button>
    </li>
  </ul>

  <div class="tab-content" id="quran-script-tab-content">
    <div class="tab-pane fade show active"
         id="tab-preview-pane"
         role="tabpanel"
         aria-labelledby="tab-preview" tabindex="0">
      <div class="space-y-6">
        <h2 class="text-xl font-semibold mt-4">
          <%= resource.name %> preview of Surah <%= ayah.chapter.name_simple %> ayah <%= ayah.verse_number %>
        </h2>

        <div class="flex flex-wrap items-center justify-center gap-4 mb-6">
          <div class="flex items-center">
            <%= label_tag :ayah, 'Jump to Ayah', class: 'me-2 font-medium' %>
            <%= select_tag :ayah,
                           [],
                           onchange: "jumpToAyah(this.value)",
                           class: "px-3 py-2 border rounded bg-white shadow-sm",
                           style: 'min-width: 220px',
                           data: { controller: 'remote-select2', url: '/api/v1/verses/select2.json' } %>
          </div>

          <div class="flex gap-2">
            <% if ayah.previous_ayah %>
              <%= link_to detail_resources_path('translation', resource.id, ayah: ayah.previous_ayah.verse_key), class: 'btn btn-secondary' do %>
                ← Previous
              <% end %>
            <% end %>

            <% if ayah.next_ayah %>
              <%= link_to detail_resources_path('translation', resource.id, ayah: ayah.next_ayah.verse_key), class: 'btn btn-secondary' do %>
                Next →
              <% end %>
            <% end %>
          </div>
        </div>

        <div class="p-6 rounded-xl bg-white shadow max-w-2xl mx-auto">
          <% if by_word %>
            <div class="flex flex-wrap gap-2 quran-text">
              <% ayah.words.each_with_index do |word, index| %>
                <span class="px-4 py-2 border border-gray-300 word">
                  <% if is_image %>
                    <img src="<%= word.send(text_type) %>" alt="<%= word.location %>"/>
                  <% else %>
                    <div class="<%= script_class %>">
                      <%= safe_html word.read_attribute(text_type) %>
                    </div>
                  <% end %>
                </span>
              <% end %>
            </div>
          <% else %>
            <% if is_image %>
              <div>
                <img src="<%= ayah.send(text_type) %>" alt="<%= ayah.verse_key %>"/>
              </div>
            <% else %>
              <div class="<%= script_class %>">
                <%= safe_html ayah.read_attribute(text_type) %>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="tab-pane hidden"
         id="tab-help-pane"
         role="tabpanel"
         aria-labelledby="tab-help" tabindex="1">
      <div class="space-y-6 qul-docs">
        <h2 class="text-xl font-bold"><%= resource.name %> Resource</h2>

        <p class="text-sm text-gray-700">
          This resource provides <strong>Quranic script</strong> in <%= resource.name %> format.
          <% if is_image %>
            The script is rendered as high-quality images for optimal display and printing.
          <% else %>
            The script uses Unicode text with specialized font rendering for digital applications.
          <% end %>
        </p>

        <h3 class="text-sm font-semibold mt-4">Sample JSON</h3>
        <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 text-sm font-mono whitespace-pre overflow-x-auto">
          {
          "1:1": {
          "verse_key": "1:1",
          "text": "<%= is_image ? '[Image URL]' : 'بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ' %>",
          "script_type": "<%= text_type %>",
          "font_family": "<%= script_class %>",
          <% if by_word %>
            "words": [
            {
            "position": 1,
            "text": "<%= is_image ? '[Word Image URL]' : 'بِسۡمِ' %>",
            "location": "1:1:1"
            }
            ],
          <% end %>
          "page_number": 1,
          "juz_number": 1,
          "hizb_number": 1
          }
          }
        </div>

        <h3 class="text-sm font-semibold mt-4">Field Descriptions</h3>
        <div class="tools-table-overflow">
          <table class="min-w-full text-sm text-left border border-gray-200 rounded-lg">
            <thead class="bg-gray-100 text-xs uppercase font-semibold">
            <tr>
              <th class="px-4 py-2">Field</th>
              <th class="px-4 py-2">Type</th>
              <th class="px-4 py-2">Description</th>
            </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
            <tr>
              <td class="px-4 py-2">verse_key</td>
              <td class="px-4 py-2">String</td>
              <td class="px-4 py-2">Reference in the format <code>surah:ayah</code> (e.g., <code>1:1</code>)</td>
            </tr>
            <tr>
              <td class="px-4 py-2">text</td>
              <td class="px-4 py-2">String</td>
              <td class="px-4 py-2">
                <% if is_image %>
                  URL to the image file containing the verse text
                <% else %>
                  Unicode text of the verse in <%= resource.name %> script
                <% end %>
              </td>
            </tr>
            <tr>
              <td class="px-4 py-2">script_type</td>
              <td class="px-4 py-2">String</td>
              <td class="px-4 py-2">Type of script rendering (<code><%= text_type %></code>)</td>
            </tr>
            <tr>
              <td class="px-4 py-2">font_family</td>
              <td class="px-4 py-2">String</td>
              <td class="px-4 py-2">CSS font family for proper rendering (<code><%= script_class %></code>)</td>
            </tr>
            <% if by_word %>
              <tr>
                <td class="px-4 py-2">words</td>
                <td class="px-4 py-2">Array</td>
                <td class="px-4 py-2">Array of word objects with individual word text/images</td>
              </tr>
              <tr>
                <td class="px-4 py-2">words[].position</td>
                <td class="px-4 py-2">Integer</td>
                <td class="px-4 py-2">Position of the word within the verse</td>
              </tr>
              <tr>
                <td class="px-4 py-2">words[].text</td>
                <td class="px-4 py-2">String</td>
                <td class="px-4 py-2">
                  <% if is_image %>
                    URL to the individual word image
                  <% else %>
                    Unicode text of the individual word
                  <% end %>
                </td>
              </tr>
              <tr>
                <td class="px-4 py-2">words[].location</td>
                <td class="px-4 py-2">String</td>
                <td class="px-4 py-2">Word location in format <code>surah:ayah:word</code></td>
              </tr>
            <% end %>
            <tr>
              <td class="px-4 py-2">page_number</td>
              <td class="px-4 py-2">Integer</td>
              <td class="px-4 py-2">Mushaf page number where this verse appears</td>
            </tr>
            <tr>
              <td class="px-4 py-2">juz_number</td>
              <td class="px-4 py-2">Integer</td>
              <td class="px-4 py-2">Juz number (1-30) containing this verse</td>
            </tr>
            <tr>
              <td class="px-4 py-2">hizb_number</td>
              <td class="px-4 py-2">Integer</td>
              <td class="px-4 py-2">Hizb number (1-60) containing this verse</td>
            </tr>
            </tbody>
          </table>
        </div>

        <h3 class="text-sm font-semibold mt-4">Usage Examples</h3>
        <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
          <h4 class="text-sm font-semibold mb-2">CSS Integration</h4>
          <pre class="text-xs font-mono whitespace-pre-wrap">/* Include the font family in your CSS */
.quran-text {
  font-family: '<%= script_class %>', 'Amiri', serif;
  direction: rtl;
  text-align: right;
}</pre>

          <h4 class="text-sm font-semibold mt-4 mb-2">JavaScript Usage</h4>
          <pre class="text-xs font-mono whitespace-pre-wrap">// Fetch verse data
fetch('/api/v1/verses/1:1.json')
  .then(response => response.json())
  .then(data => {
    document.getElementById('verse').innerHTML = data.text;
    document.getElementById('verse').className = '<%= script_class %>';
  });</pre>
        </div>

        <h3 class="text-sm font-semibold mt-4">Features</h3>
        <ul class="list-disc list-inside text-sm text-gray-700">
          <li>High-quality Arabic text rendering</li>
          <li>Proper diacritical marks and Tajweed annotations</li>
          <li>Responsive design for different screen sizes</li>
          <% if by_word %>
            <li>Word-by-word display for detailed study</li>
          <% end %>
          <% if is_image %>
            <li>Optimized image format for printing and display</li>
            <li>Consistent visual quality across all devices</li>
          <% else %>
            <li>Unicode text for easy copying and searching</li>
            <li>Scalable vector rendering</li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
</div>
