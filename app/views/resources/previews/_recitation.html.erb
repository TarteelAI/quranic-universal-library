<%
  key = params[:ayah] || '1:1'
  ayah = Verse.find_by(verse_key: key) || Verse.find_by(verse_key: '1:1')
  chapter = ayah.chapter
%>

<div class="mt-5" data-controller="tabs">
  <ul class="flex flex-nowrap list-none m-0 p-0 border-b border-gray-200" id="docs-tab" role="tablist">
    <li class="m-0 flex-none" role="presentation">
      <button class="btn-tab-active"
              id="tab-docs"
              data-action="click->tabs#switch"
              data-tabs-target-value="tab-preview-pane"
              type="button"
              role="tab"
              aria-controls="tab-preview-pane"
              aria-selected="true">
        Recitation
      </button>
    </li>

    <li class="m-0 flex-none" role="presentation">
      <button class="btn-tab"
              id="tab-help"
              data-action="click->tabs#switch"
              data-tabs-target-value="tab-help-pane"
              type="button" role="tab"
              aria-controls="tab-help-pane"
              aria-selected="false">
        Help
      </button>
    </li>
  </ul>

  <div class="tab-content p-2 mt-3" id="docs-tab-content">
    <div class="tab-pane show active"
         id="tab-preview-pane"
         role="tabpanel"
         aria-labelledby="tab-docs" tabindex="0">
      <div class="space-y-6">
        <h2 class="text-xl font-semibold">
          Recitation and segments preview for <%= resource.name %> recitation.
        </h2>

        <div class="flex flex-wrap items-center justify-center gap-4 mb-6">
          <div class="flex items-center">
            <%= label_tag :ayah, 'Jump to Ayah', class: 'me-2 font-medium' %>
            <%= select_tag :ayah,
                           options_for_select([ayah.verse_key], ayah.verse_key),
                           id: 'ayah-select',
                           class: "px-3 py-2 border rounded bg-white shadow-sm",
                           style: 'min-width: 220px',
                           data: {
                             controller: 'remote-select2',
                             url: '/api/v1/verses/select2.json'
                           }
            %>
          </div>

          <div class="flex gap-2">
            <%= link_to detail_resources_path('recitation', resource.id, ayah: ayah.previous_ayah&.verse_key), id: 'previous-ayah', class: 'btn btn-secondary' do %>
              ← Previous
            <% end %>

            <%= link_to detail_resources_path('recitation', resource.id, ayah: ayah.next_ayah&.verse_key), id: 'next-ayah', class: 'btn btn-secondary' do %>
              Next →
            <% end %>
          </div>
        </div>

        <%= render 'resources/previews/segment_player', resource: resource, ayah: ayah %>
      </div>
    </div>

    <div class="tab-pane hidden"
         id="tab-help-pane"
         role="tabpanel"
         aria-labelledby="tab-docs" tabindex="1">
      <div class="space-y-6">
        <div class="p-6 bg-white shadow-md rounded-md font-sans text-gray-800">
          <p class="text-2xl font-semibold mb-6">
            QUL supports two types of Quranic recitations audio data:
          </p>

          <section class="mb-4">
            <h2 class="font-semibold mb-4">1. Surah-by-Surah (Gapless)</h2>
            <ul class="list-disc list-inside space-y-1">
              <li>Contains <strong>114 audio files</strong>, one per surah.</li>
              <li>Each audio file plays the entire surah continuously without gaps.</li>
              <li>Often referred to as <em>gapless</em> audio.</li>
            </ul>
          </section>

          <section class="mb-4">
            <h2 class="font-semibold mb-4">2. Ayah-by-Ayah (Gapped)</h2>
            <ul class="list-disc list-inside space-y-1">
              <li>Contains <strong>6,236 audio files</strong>, one for each ayah (verse) in the Quran.</li>
              <li>Each audio file corresponds to a single ayah.</li>
              <li>Also called <em>gapped</em> audio due to discrete audio segments for each ayah.</li>
              <li>Useful for playing single ayah without loading the full surah audio.</li>
            </ul>
          </section>

          <section>
            <h2 class="text-2xl font-semibold mb-4">Ayah-by-Ayah Segments Data Format</h2>

            <pre class="bg-gray-100 p-4 rounded overflow-x-auto mb-4"><code>{
  "surah": &lt;surah_number&gt;,
  "ayah": &lt;ayah_number&gt;,
   "audio_url": "audio file url",
  "segments": [
    [ &lt;segment_index&gt;, &lt;start_time_ms&gt;, &lt;end_time_ms&gt; ],
    ...
  ]
}</code></pre>

          </section>

          <section>
            <h2 class="text-2xl font-semibold mb-4">Surah-by-Surah Segments Data Format</h2>

            <pre class="bg-gray-100 p-4 rounded overflow-x-auto mb-4"><code>{
              "surah:ayah": {
  "duration_sec": &lt;duration in seconds&gt;,
   "timestamp_from": "start time of this ayah within audio file",
  "timestamp_to": "end time of ayah",
  "segments": [
    [ &lt;segment_index&gt;, &lt;start_time_ms&gt;, &lt;end_time_ms&gt; ],
    ...
  ]}
}</code></pre>
          </section>

          <section>
            <h2 class="text-2xl font-semibold mb-4">Sample data for surah segment</h2>

            <pre class="bg-gray-100 p-4 rounded overflow-x-auto mb-4"><code>{
  "1:1": {
    "segments": [
      [1, 361, 1051],
      [2, 1051, 1622],
      [3, 1662, 2763],
      [4, 2803, 4385]
    ],
    "duration_sec": 4,
    "duration_ms": 4224,
    "timestamp_from": 361,
    "timestamp_to": 4585
  }
}</code></pre>
          </section>
        </div>

      </div>
    </div>
  </div>
</div>