<%
  resource = resource.resource_content
  recitation = resource.one_ayah? ? Recitation.find_by(resource_content_id: resource.id) : Audio::Recitation.find_by(resource_content_id: resource.id)
%>

<div
  data-controller="<%= resource.one_ayah? ? 'ayah-segment-player' : 'surah-segment-player' %>"
  id="audio-player"
  data-recitation="<%= recitation.id %>"
  data-verse-key="<%= ayah.verse_key %>"
>

<div id="current-ayah" class="relative min-h-32 rounded-2xl bg-slate-50 p-6 shadow-inner">
  <div class="mb-4 flex items-center justify-between gap-3">
    <span class="text-xs font-semibold uppercase tracking-wide text-slate-500">Current ayah</span>
    <span id="current-verse-key" class="rounded-full bg-white px-3 py-1 text-sm font-semibold text-slate-700 shadow-sm"><%= ayah.verse_key %></span>
  </div>
  <div id="words" class="relative z-10 flex flex-wrap qpc-hafs mb-4 gap-1 text-3xl leading-loose"></div>
  <span id="word-highlight" class="pointer-events-none absolute hidden rounded-lg bg-primary-100 ring-2 ring-primary-200 shadow-sm transition-all duration-150"></span>
</div>

<div
  class="fixed bottom-4 left-[50%] w-[94%] md:w-[70%] lg:w-[52%] -translate-x-1/2 bg-white/95 backdrop-blur-sm rounded-2xl shadow-2xl border border-gray-100 z-[100]"
>
  <div class="max-w-4xl mx-auto px-4 py-4 relative">
    <div class="flex items-center gap-3">
      <button
        id="play-button"
        disabled
        class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-full bg-primary-100 shadow-sm transition-all hover:bg-primary-200 hover:shadow-md">
        <i class="fas fa-play text-gray-700"></i>
      </button>

      <button
        id="loop-button"
        type="button"
        aria-pressed="false"
        title="Loop current ayah"
        class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-slate-100 text-slate-500 transition-all hover:bg-slate-200">
        <i class="fas fa-refresh"></i>
      </button>

      <div class="flex min-w-0 flex-1 flex-col gap-2">
        <div class="flex items-center justify-between gap-3">
          <span id="current-time"
                class="text-xs font-semibold tabular-nums text-gray-600">
            0:00
          </span>
          <span id="total-duration"
                class="text-xs font-semibold tabular-nums text-gray-600">
            0:00
          </span>
        </div>

        <div>
          <div
            id="progress-bar"
            class="relative h-3 cursor-pointer rounded-full bg-gray-200">
            <div
              id="progress"
              class="h-full w-0 rounded-full bg-blue-400"></div>
            <div
              id="progress-handle"
              class="absolute left-0 top-1/2 h-5 w-5 -translate-x-1/2 -translate-y-1/2 rounded-full border-2 border-white bg-blue-500 shadow-md"></div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
</div>
