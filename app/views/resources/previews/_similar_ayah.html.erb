<%
  key = params[:ayah] || '1:1'
  ayah = Verse.find_by(verse_key: key) || Verse.find_by(verse_key: '1:1')
  similar_ayahs = ayah.get_matching_verses
%>

<div class="mt-5" data-controller="tabs">
  <ul class="flex flex-nowrap list-none m-0 p-0 border-b border-gray-200" id="translation-docs-tab" role="tablist">
    <li class="m-0 flex-none" role="presentation">
      <button class="btn-tab-active"
              id="tab-docs"
              data-action="click->tabs#switch"
              data-tabs-target-value="tab-preview-pane"
              type="button"
              role="tab"
              aria-controls="tab-preview-pane"
              aria-selected="true">
        Similar Ayah Preview
      </button>
    </li>

    <li class="m-0 flex-none" role="presentation">
      <button class="btn-tab"
              id="tab-help"
              data-action="click->tabs#switch"
              data-tabs-target-value="tab-help-pane"
              type="button" role="tab"
              aria-controls="tab-help-pane"
              aria-selected="false">
        Help
      </button>
    </li>
  </ul>

  <div class="tab-content p-2 mt-3" id="translation-docs-tab-content">
    <div class="tab-pane show active"
         id="tab-preview-pane"
         role="tabpanel"
         aria-labelledby="tab-docs" tabindex="0">
      <div class="space-y-6">
        <h2 class="text-xl font-semibold">
          <%= resource.name %> for Surah <%= ayah.chapter.name_simple %> — Ayah <%= ayah.verse_number %>
        </h2>

        <div class="flex flex-wrap items-center justify-center gap-4 mb-6">
          <div class="flex items-center">
            <%= label_tag :ayah, 'Jump to Ayah', class: 'me-2 font-medium' %>
            <%= select_tag :ayah,
                           [],
                           onchange: "jumpToAyah(this.value)",
                           class: "px-3 py-2 border rounded bg-white shadow-sm",
                           style: 'min-width: 220px',
                           data: { controller: 'remote-select2', url: '/api/v1/verses/select2.json' } %>
          </div>

          <div class="flex gap-2">
            <% if ayah.previous_ayah %>
              <%= link_to detail_resources_path('ayah-theme', resource.id, ayah: ayah.previous_ayah.verse_key), class: 'btn btn-secondary' do %>
                ← Previous
              <% end %>
            <% end %>

            <% if ayah.next_ayah %>
              <%= link_to detail_resources_path('ayah-theme', resource.id, ayah: ayah.next_ayah.verse_key), class: 'btn btn-secondary' do %>
                Next →
              <% end %>
            <% end %>
          </div>
        </div>

        <div class="bg-white border border-gray-200 rounded-lg shadow-sm mb-2">
          <div class="p-6">
            <div class="qpc-hafs quran-text">
              <div class="badge badge-default text-left">
                <%= ayah.verse_key %>
              </div>
              <%= ayah.text_qpc_hafs %>
            </div>
          </div>
        </div>

        <div class="p-6 rounded-xl bg-white shadow max-w-2xl mx-auto">
          <% if similar_ayahs.size > 1 %>
            <div class="bg-green-100 border border-green-300 text-green-800 px-4 py-3 rounded mb-4" role="alert">
              <p class="leading-normal">
                <%= ayah.verse_key %> has <%= pluralize similar_ayahs.size, 'similar ayah' %>
              </p>
            </div>

            <% similar_ayahs.includes(matched_verse: :words).each do |similar| %>
              <%
                matching_ayah = similar.matched_verse
                match_words = similar.matched_word_positions
              %>
              <div class="bg-white border border-gray-200 rounded-lg shadow-sm mb-2">
                <div class="p-6">
                  <div class="qpc-hafs quran-text">
                    <div class="badge badge-default text-left">
                      <%= matching_ayah.verse_key %>
                    </div>

                    <% matching_ayah.words.each do |word| %>
                      <% if match_words.include?(word.position) %>
                        <span class="text-green-600"><%= word.text_qpc_hafs %></span>
                      <% else %>
                        <%= word.text_qpc_hafs %>
                      <% end %>
                    <% end %>
                  </div>
                  <div class="mt-4">
                    <small class="text-gray-600 block mb-2">
                      This ayah matches <%= similar.matched_words_count %> words with <%= similar.coverage %>% coverage and a similarity score of <%= similar.score %>
                    </small>
                  </div>
                </div>
              </div>
            <% end %>
          <% else %>
            <p class="text-gray-500 italic">
              No similar ayah found for  <%= ayah.verse_key %>
            </p>
          <% end %>
        </div>
      </div>
    </div>

    <div class="tab-pane hidden"
         id="tab-help-pane"
         role="tabpanel"
         aria-labelledby="tab-docs" tabindex="1">
      <div class="space-y-6 text-gray-800">

        <div>
          <h2 class="text-2xl font-bold">Similar Ayah Resource</h2>
          <p class="mt-2">
            The Similar Ayah resource in QUL highlights verses in the Quran that share similar words or expressions. This is useful for exploring recurring linguistic patterns, themes, or phrases across the Quran.
          </p>
        </div>

        <div>
          <h3 class="text-xl font-semibold">Export Formats</h3>
          <p class="mt-2">
            QUL exports similar ayah data in both <strong>JSON</strong> and <strong>SQLite</strong> formats.
          </p>
        </div>

        <div>
          <h3 class="text-lg font-semibold">SQLite Schema</h3>
          <div class="overflow-x-auto bg-gray-50 rounded-lg shadow-sm border border-gray-200 mt-2">
            <table class="min-w-full text-sm text-left">
              <thead class="bg-gray-100 uppercase text-xs font-semibold">
              <tr>
                <th class="px-4 py-2">Column</th>
                <th class="px-4 py-2">Type</th>
                <th class="px-4 py-2">Description</th>
              </tr>
              </thead>
              <tbody class="divide-y divide-gray-200">
              <tr>
                <td class="px-4 py-2"><code>verse_key</code></td>
                <td class="px-4 py-2">TEXT</td>
                <td class="px-4 py-2">The ayah key that similar ayahs belongs to (e.g., <code>1:1</code>).</td>
              </tr>
              <tr>
                <td class="px-4 py-2"><code>matched_ayah_key</code></td>
                <td class="px-4 py-2">TEXT</td>
                <td class="px-4 py-2">Matching ayah key that shares similar wording.</td>
              </tr>
              <tr>
                <td class="px-4 py-2"><code>matched_words_count</code></td>
                <td class="px-4 py-2">INTEGER</td>
                <td class="px-4 py-2">Number of matching words between the two ayahs.</td>
              </tr>
              <tr>
                <td class="px-4 py-2"><code>coverage</code></td>
                <td class="px-4 py-2">INTEGER</td>
                <td class="px-4 py-2">Percentage of words in the source ayah that matched.</td>
              </tr>
              <tr>
                <td class="px-4 py-2"><code>score</code></td>
                <td class="px-4 py-2">INTEGER</td>
                <td class="px-4 py-2">Similarity score between the source and matched ayah (0–100).</td>
              </tr>
              <tr>
                <td class="px-4 py-2"><code>match_words_range</code></td>
                <td class="px-4 py-2">TEXT</td>
                <td class="px-4 py-2">Word position range in the matching ayah range that matched with the source ayah.</td>
              </tr>
              </tbody>
            </table>
          </div>
        </div>

        <div>
          <h3 class="text-lg font-semibold">Example</h3>
          <p class="mt-2">
            If <code>1:1</code> matches <code>27:30</code> with the following data:
          </p>
          <pre class="bg-gray-100 p-4 rounded-md mt-2 text-sm whitespace-pre-wrap">
matched_words_count: 4
coverage: 100
score: 100
match_words_range: [5,8]
    </pre>
          <p class="mt-2">
            The interpretation would be:
          </p>
          <div class="bg-blue-50 border-l-4 border-blue-400 p-4 rounded-md text-sm">
            <strong>This ayah matches 4 words</strong>, with <strong>100% coverage</strong> and a <strong>similarity score of 100</strong>.
            Word <strong>5 to 8</strong> matched with source ayah.
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
