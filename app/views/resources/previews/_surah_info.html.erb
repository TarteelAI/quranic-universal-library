<%
  chapter_id = (params[:surah] || 1).to_i
  if chapter_id < 0 || chapter_id > 114
    chapter_id = 1
  end

  chapters = Chapter.order("chapter_number ASC").select(:name_simple, :chapter_number).map do |chapter|
    [chapter.humanize, chapter.chapter_number]
  end
  info = ChapterInfo.where(chapter_id: chapter_id, resource_content_id: resource.resource_content_id).first
%>

<style>
    .info p {
        margin: 10px 0;
    }

    .info h2 {
        font-weight: bold;
        margin-top: 10px;
        text-decoration: underline;
    }
</style>

<div class="mt-5" data-controller="tabs">
  <ul class="flex flex-nowrap list-none m-0 p-0 border-b border-gray-200" id="translation-docs-tab" role="tablist">
    <li class="m-0 flex-none" role="presentation">
      <button class="btn-tab-active"
              id="tab-docs"
              data-action="click->tabs#switch"
              data-tabs-target-value="tab-preview-pane"
              type="button"
              role="tab"
              aria-controls="tab-preview-pane"
              aria-selected="true">
        Surah Info Preview
      </button>
    </li>

    <li class="m-0 flex-none" role="presentation">
      <button class="btn-tab"
              id="tab-help"
              data-action="click->tabs#switch"
              data-tabs-target-value="tab-help-pane"
              type="button" role="tab"
              aria-controls="tab-help-pane"
              aria-selected="false">
        Help
      </button>
    </li>
  </ul>

  <div class="tab-content p-2 mt-3" id="translation-docs-tab-content">
    <div class="tab-pane show active"
         id="tab-preview-pane"
         role="tabpanel"
         aria-labelledby="tab-docs" tabindex="0">
      <div class="space-y-6">
        <div class="flex flex-wrap items-center justify-center gap-4 mb-6">
          <div class="flex items-center">
            <%= label_tag :surah, 'Jump to Surah', class: 'me-2 font-medium' %>
            <%= select_tag :surah,
                           options_for_select(chapters, chapter_id),
                           onchange: "jumpToSurah(this.value)",
                           class: "px-3 py-2 border rounded bg-white shadow-sm",
                           style: 'min-width: 220px',
                           data: { controller: 'select2' } %>
          </div>

          <div class="flex gap-2">
            <% if chapter_id > 1 %>
              <%= link_to detail_resources_path('surah-info', resource.id, surah: chapter_id - 1), class: 'btn btn-secondary' do %>
                ← Previous
              <% end %>
            <% end %>

            <% if chapter_id < 114 %>
              <%= link_to detail_resources_path('surah-info', resource.id, surah: chapter_id + 1), class: 'btn btn-secondary' do %>
                Next →
              <% end %>
            <% end %>
          </div>
        </div>

        <div class="p-6 rounded-xl bg-white shadow max-w-2xl mx-auto">
          <div class="info <%= info.language_name.to_s.downcase %>">
            <p class="strong">
              <%= safe_html info.short_text %>
            </p>

            <div>
              <%= safe_html info.text %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="tab-pane hidden"
         id="tab-help-pane"
         role="tabpanel"
         aria-labelledby="tab-docs" tabindex="1">
      <div class="space-y-6">
        <p>
          The <strong>Surah Information</strong> resource provides detailed information for each Surah. It includes key themes and topics, reasons for revelation, summaries, and other contextual insights to help readers better understand the message of the Surah.
        </p>
        <p>
          Surah Information is available in multiple languages and can be downloaded in <code>SQLite</code>, <code>CSV</code>, and <code>JSON</code> formats. Some languages include both a short summary and a longer, detailed version. The detailed version may use HTML tags for formatting the text.
        </p>
      </div>
    </div>
  </div>
</div>





