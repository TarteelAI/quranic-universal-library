<%
  key = params[:ayah] || '73:4'
  ayah = Verse.find_by(verse_key: key) || Verse.find_by(verse_key: '73:4')
  tafsir = Tafsir.for_verse(ayah, resource.resource_content)
%>

<div class="mt-5" data-controller="tabs">
  <ul class="flex flex-nowrap list-none m-0 p-0 border-b border-gray-200" id="translation-docs-tab" role="tablist">
    <li class="m-0 flex-none" role="presentation">
      <button class="btn-tab-active"
              id="tab-docs"
              data-action="click->tabs#switch"
              data-tabs-target-value="tab-preview-pane"
              type="button"
              role="tab"
              aria-controls="tab-preview-pane"
              aria-selected="true">
        Tafsir Preview
      </button>
    </li>

    <li class="m-0 flex-none" role="presentation">
      <button class="btn-tab"
              id="tab-help"
              data-action="click->tabs#switch"
              data-tabs-target-value="tab-help-pane"
              type="button" role="tab"
              aria-controls="tab-help-pane"
              aria-selected="false">
        Help
      </button>
    </li>
  </ul>

  <div class="tab-content p-2 mt-3" id="translation-docs-tab-content">
    <div class="tab-pane show active"
         id="tab-preview-pane"
         role="tabpanel"
         aria-labelledby="tab-docs" tabindex="0">
      <div class="space-y-6">
        <h2 class="text-xl font-semibold">
          <%= resource.name %> tafsir for Surah <%= ayah.chapter.name_simple %> — Ayah <%= ayah.verse_number %>
        </h2>

        <div class="flex flex-wrap items-center justify-center gap-4 mb-6">
          <div class="flex items-center">
            <%= label_tag :ayah, 'Jump to Ayah', class: 'me-2 font-medium' %>
            <%= select_tag :ayah,
                           [],
                           onchange: "jumpToAyah(this.value)",
                           class: "px-3 py-2 border rounded bg-white shadow-sm",
                           style: 'min-width: 220px',
                           data: { controller: 'remote-select2', url: '/api/v1/verses/select2.json' } %>
          </div>

          <div class="flex gap-2">
            <% if ayah.previous_ayah %>
              <%= link_to detail_resources_path('translation', resource.id, ayah: ayah.previous_ayah.verse_key), class: 'btn btn-secondary' do %>
                ← Previous
              <% end %>
            <% end %>

            <% if ayah.next_ayah %>
              <%= link_to detail_resources_path('translation', resource.id, ayah: ayah.next_ayah.verse_key), class: 'btn btn-secondary' do %>
                Next →
              <% end %>
            <% end %>
          </div>
        </div>

        <% if tafsir %>
          <% verses = tafsir.ayahs %>

          <div class="bg-white border border-gray-200 rounded-lg shadow-sm mb-2">
            <div class="p-6">
              <div class="qpc-hafs quran-text">
                <% verses.each do |verse| %>
                  <%= verse.text_qpc_hafs %>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

        <div class="p-6 rounded-xl bg-white shadow max-w-2xl mx-auto">
          <% if tafsir %>
            <% verses = tafsir.ayahs %>

            <% if tafsir.group_verses_count > 1 %>
              <div class="bg-green-100 border border-green-300 text-green-800 px-4 py-3 rounded mb-4" role="alert">
                <p class="leading-normal">
                  You are reading tafsir of <%= verses.size %> ayahs: <%= verses.first.verse_key %>
                  to <%= verses.last.verse_key %>.
                </p>
              </div>
            <% end %>

            <div class="tafsir <%= tafsir.language_name.to_s.downcase %>">
              <%= safe_html tafsir.text %>
            </div>
          <% else %>
            <p class="text-gray-500 italic">Tafisr is not available for this ayah.</p>
          <% end %>
        </div>
      </div>
    </div>

    <div class="tab-pane hidden"
         id="tab-help-pane"
         role="tabpanel"
         aria-labelledby="tab-docs" tabindex="1">
      <div class="space-y-6">
        <div class="space-y-6 text-gray-800 text-base leading-relaxed">
          <h2 class="text-2xl font-bold text-gray-900">Tafsir Resource</h2>

          <p>
            QUL supports exporting tafsir content in both <strong>JSON</strong> and <strong>SQLite</strong> formats.
            Tafsir text may include <code>&lt;html&gt;</code> tags for formatting such as <code>&lt;b&gt;</code>,
            <code>&lt;i&gt;</code>, etc.
          </p>

          <div class="bg-green-100 border border-green-300 text-green-800 px-4 py-3 rounded" role="alert">
            <p class="font-semibold">Note:</p>
            <p class="leading-normal">
              Tafsir content may span multiple ayahs. QUL exports both the tafsir text and the ayahs it applies to.
            </p>
          </div>

          <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 text-sm font-mono overflow-auto">
            <p class="font-semibold mb-2">Example JSON Format:</p>
            <pre class="whitespace-pre-wrap">{
  "2:3": {
    "text": "tafisr text.",
    "ayah_keys": ["2:3", "2:4"]
  },
  "2:4": "2:3"
}</pre>
          </div>

          <ul class="list-disc pl-6 space-y-2">
            <li>Keys in the JSON are <code>"ayah_key"</code> in <code>"surah:ayah"</code>, e.g. <code>"2:3"</code> means
              3rd ayah of Surah Al-Baqarah.
            </li>
            <li>The value of ayah key can either be:
              <ul class="list-disc pl-6">
                <li>
                  <strong>an object</strong> — this is the main tafsir group. It includes:
                  <ul class="list-disc pl-6">
                    <li><code>text</code>: the tafsir content (can include HTML)</li>
                    <li><code>ayah_keys</code>: an array of ayah keys this tafsir applies to</li>
                  </ul>
                </li>
                <li>
                  <strong>a string</strong> — this indicates the tafsir is part of a group. The string points to the
                  <code>ayah_key</code> where the tafsir text can be found.
                </li>
              </ul>
            </li>
          </ul>

          <h3 class="text-xl font-semibold">SQLite exports includes the following columns</h3>
          <ul class="list-disc pl-6 space-y-2">
            <li><code>ayah_key</code>: the ayah for which this record applies.</li>
            <li><code>group_ayah_key</code>: the ayah key that contains the main tafsir text (used for shared tafsir).
            </li>
            <li><code>from_ayah</code> / <code>to_ayah</code>: start and end ayah keys for convenience (optional).</li>
            <li><code>ayah_keys</code>: comma-separated list of all ayah keys that this tafsir covers.</li>
            <li><code>text</code>: tafsir text. If blank, use the <code>text</code> from the <code>group_ayah_key</code>.
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>
