<tr class="hover:bg-gray-50 transition-colors">
  <td class="px-4 py-3">
    <div class="font-medium text-gray-900">
      <%= topic.name %>
    </div>
  </td>
  <td class="px-4 py-3 hidden md:table-cell">
    <% if topic.arabic_name.present? %>
      <span class="text-gray-700 qpc-hafs">
        <%= topic.arabic_name %>
      </span>
    <% else %>
      <span class="text-gray-400 text-sm">—</span>
    <% end %>
  </td>
  <td class="px-4 py-3 text-center">
    <div class="flex flex-wrap justify-center gap-1">
      <%= topic_type_badges(topic) %>
    </div>
  </td>
  <td class="px-4 py-3 hidden lg:table-cell">
    <% if topic.parent.present? %>
      <div class="text-sm text-gray-700">
        <%= topic.parent.name %>
      </div>
    <% else %>
      <span class="text-gray-400 text-sm">—</span>
    <% end %>
  </td>
  <td class="px-4 py-3 text-center hidden lg:table-cell">
    <% if topic.children.any? %>
      <span class="inline-flex items-center justify-center px-2.5 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-700">
        <%= topic.children.count %>
      </span>
    <% else %>
      <span class="text-gray-400 text-sm">0</span>
    <% end %>
  </td>
  <td class="px-4 py-3 text-center">
    <span class="inline-flex items-center justify-center px-3 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-700">
      <%= topic.verse_topics.count %>
    </span>
  </td>
  <td class="px-4 py-3 text-center">
    <%= link_to detail_resources_path('ayah-topics', resource.id, topic_id: topic.id), class: 'inline-flex items-center px-3 py-1.5 text-sm font-medium text-white bg-blue-600 rounded hover:bg-blue-700 transition-colors' do %>
      View
    <% end %>
  </td>
</tr>

