<%
  children = topic.all_children
  parent = topic.get_parent
%>

<div class="p-4 rounded-lg border mb-6 <%= topic_background_color(topic) %>">
  <h2 class="text-xl font-semibold text-gray-900 mb-2">
    <%= topic.name %>
    <% if topic.arabic_name.present? %>
      <span class="qpc-hafs text-gray-700 font-normal">(<%= topic.arabic_name %>)</span>
    <% end %>
  </h2>

  <div class="flex gap-2 mb-2">
    <%= topic_type_badges(topic) %>
  </div>

  <% if topic.description.present? %>
    <div class="text-gray-600 text-sm mt-3">
      <%= safe_html topic.description %>
    </div>
  <% end %>

  <% if parent %>
    <div class="mt-4">
      <span class="text-gray-700 font-semibold">Parent Topic:</span>
      <% if local_assigns[:resource].present? %>
        <%= link_to parent.name, detail_resources_path('ayah-topics', resource.id, topic_id: parent.id), class: 'text-blue-600 hover:text-blue-800' %>
      <% elsif local_assigns[:ayah_key].present? %>
        <%= link_to parent.name, '#_', class: 'text-blue-600 hover:text-blue-800',
                    data: { controller: 'ajax-modal', url: ayah_topic_path(key: ayah_key, topic_id: parent.id), css_class: 'modal-lg' } %>
      <% else %>
        <span class="text-blue-600"><%= parent.name %></span>
      <% end %>
    </div>
  <% end %>
</div>

<% if children.present? %>
  <div class="mb-6">
    <h3 class="text-lg font-semibold text-gray-800 mb-4">
      Child Topics (<%= children.count %>)
    </h3>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
      <% children.each do |child_topic| %>
        <% child_card = capture do %>
          <div class="bg-white border border-gray-200 rounded-lg p-4 shadow-sm hover:shadow-md hover:border-blue-300 transition-all">
            <div class="flex items-start justify-between">
              <div class="flex-1">
                <h5 class="font-semibold text-gray-900 text-sm mb-1">
                  <%= child_topic.name %>
                </h5>
                <% if child_topic.arabic_name.present? %>
                  <p class="text-xs text-gray-600 qpc-hafs mb-2">
                    <%= child_topic.arabic_name %>
                  </p>
                <% end %>
                <div class="flex items-center gap-2 mt-2">
                  <span class="text-xs text-gray-500">
                    <%= child_topic.verse_topics.count %> ayahs
                  </span>
                  <% if child_topic.children.any? %>
                    <span class="text-xs text-gray-500">
                      • <%= child_topic.children.count %> sub-topics
                    </span>
                  <% end %>
                </div>
              </div>
              <div class="ml-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
            </div>
          </div>
        <% end %>

        <% if local_assigns[:resource].present? %>
          <%= link_to detail_resources_path('ayah-topics', resource.id, topic_id: child_topic.id), class: 'block' do %>
            <%= child_card %>
          <% end %>
        <% elsif local_assigns[:ayah_key].present? %>
          <%= link_to '#_', class: 'block',
                      data: { controller: 'ajax-modal', url: ayah_topic_path(key: ayah_key, topic_id: child_topic.id), css_class: 'modal-lg' } do %>
            <%= child_card %>
          <% end %>
        <% else %>
          <div class="block"><%= child_card %></div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<div class="space-y-4">
  <% if verse_topics.any? %>
    <% sorted_verse_topics = @sorted_verse_topics || verse_topics %>
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-semibold text-gray-800">
        Ayahs Associated with This Topic (<%= verse_topics.count %>)
      </h3>
      <% if local_assigns[:resource].present? %>
        <% new_ayahs_sort = @ayahs_sort == 'asc' ? 'desc' : 'asc' %>
        <%= link_to detail_resources_path('ayah-topics', resource.id, topic_id: topic.id, ayahs_sort: new_ayahs_sort),
                    class: 'text-sm text-blue-600 hover:text-blue-800 flex items-center gap-1',
                    style: 'text-decoration: none;' do %>
          Sort ⇅
        <% end %>
      <% end %>
    </div>

    <div class="space-y-3">
      <% sorted_verse_topics.each do |verse_topic| %>
        <%= render 'resources/previews/ayah_topics/verse_card', verse_topic: verse_topic, topic: topic %>
      <% end %>
    </div>
  <% else %>
    <div class="p-6 rounded-xl bg-gray-50 border border-gray-200">
      <p class="text-gray-600 text-center italic">
        No ayahs found for this topic.
      </p>
    </div>
  <% end %>
</div>

