<div class="space-y-6">

  <h2 class="text-xl font-bold">Ayah Resource</h2>

  <p class="text-sm text-gray-700">
    This resource provides <strong>metadata</strong> about each ayah in the Quran.
    If you are looking to download a specific ayah by ayah Quranic script, refer to the <a href='/resources/quran-script' class="underline">Quran Script</a> resource instead.
  </p>

  <h3 class="text-sm font-semibold mt-4">Sample JSON</h3>
  <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 text-sm font-mono whitespace-pre overflow-x-auto">
    {
    "1": {
    "id": 1,
    "surah_number": 1,
    "ayah_number": 1,
    "verse_key": "1:1",
    "words_count": 4,
    "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ ١"
    }
    }
  </div>

  <h3 class="text-sm font-semibold mt-4">Field Descriptions</h3>
  <div class="tools-table-overflow">
    <table class="min-w-full text-sm text-left border border-gray-200 rounded-lg">
      <thead class="bg-gray-100 text-xs uppercase font-semibold">
      <tr>
        <th class="px-4 py-2">Field</th>
        <th class="px-4 py-2">Type</th>
        <th class="px-4 py-2">Description</th>
      </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
      <tr>
        <td class="px-4 py-2">id</td>
        <td class="px-4 py-2">Integer</td>
        <td class="px-4 py-2">Unique internal ID for the ayah</td>
      </tr>
      <tr>
        <td class="px-4 py-2">surah_number</td>
        <td class="px-4 py-2">Integer</td>
        <td class="px-4 py-2">Surah number to which the ayah belongs</td>
      </tr>
      <tr>
        <td class="px-4 py-2">ayah_number</td>
        <td class="px-4 py-2">Integer</td>
        <td class="px-4 py-2">Ayah number within the Surah</td>
      </tr>
      <tr>
        <td class="px-4 py-2">verse_key</td>
        <td class="px-4 py-2">String</td>
        <td class="px-4 py-2">Reference in the format <code>surah:ayah</code> (e.g., <code>1:1</code>)</td>
      </tr>
      <tr>
        <td class="px-4 py-2">words_count</td>
        <td class="px-4 py-2">Integer</td>
        <td class="px-4 py-2">Number of words in this ayah</td>
      </tr>
      <tr>
        <td class="px-4 py-2">text</td>
        <td class="px-4 py-2">String</td>
        <td class="px-4 py-2">Plain Unicode text of the ayah</td>
      </tr>
      </tbody>
    </table>
  </div>

</div>
