<%
  resources = local_assigns[:resources] || @resources
  search_context = local_assigns[:search_context] || @resource_search
  show_tags_column = resources.any? { |card| card.get_tags.present? }
%>

<table class="w-full">
  <thead>
  <tr class="border-b bg-slate-100 text-sm">
    <th class="py-3 min-w-48 px-4 font-normal align-top">
      <%= search_context&.active? ? 'Name' : sort_order_link('Name', :name, {}, data: { turbo_action: 'advance' }) %>
    </th>
    <th class="py-3 px-4 font-normal hidden md:table-cell w-max align-top">Category</th>
    <% if show_tags_column %>
      <th class="py-3 px-4 font-normal hidden md:table-cell align-top">Tags</th>
    <% end %>
    <th class="py-3 px-4 font-normal w-20 hidden md:table-cell align-top">Download</th>
  </tr>
  </thead>
  <tbody>

  <% resources.each do |card| %>
    <% tags = card.get_tags %>

    <tr class="border-b" id="<%= dom_id card %>"
        data-search="<%= "#{card.name.downcase} #{card.info.to_s.downcase} #{card.humanize_cardinality_type.to_s.downcase} #{card.tag_names.join(' ').downcase}" %>">
      <td class="py-3 px-4 text-sm text-pretty max-w-[500px] align-top">
        <p class="font-semibold block">
          <%= link_to card.name, resource_search_detail_path(card, search_context), class: 'hover:text-[#46ac7a] transition-colors', data: { turbo_frame: '_top' } %>
        </p>

        <% if card.related_resources.present? %>
          <div>
            <small>
              View
              <%= link_to pluralize(card.related_resources.size, 'related resource'),  related_resources_path(card.resource_type, card.id), data: { turbo_frame: '_top', controller: 'ajax-modal', css_class: 'modal-lg', url: related_resources_path(card.resource_type, card.id) } %>
            </small>
          </div>
        <% end %>

        <div class="text-gray-500 text-xs mt-1 md:hidden flex flex-col gap-1 space-y-1">
          <div class="flex flex-wrap gap-2">
            <span class="inline-flex items-center rounded-full bg-emerald-50 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wide text-emerald-700">
              <%= resource_type_label(card.resource_type) %>
            </span>

            <% if card.humanize_cardinality_type.present? %>
              <span class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-1 text-[11px] font-medium text-slate-700">
                <%= card.humanize_cardinality_type %>
              </span>
            <% end %>
          </div>

          <%= render 'card/card-description', description: card.description.presence || card.info.presence || card.humanize_cardinality_type %>

          <% if tags.present? %>
            <div class="flex flex-wrap gap-1 pb-1">
              <% tags.each do |tag| %>
                <% facet = Resources::SearchQuery::TagFacet.new(tag: tag, name: tag.name, count: nil, selected: Array(search_context&.selected_tags).include?(tag.name)) %>
                <%= render partial: 'resources/tag_filter', locals: { facet: facet } %>
              <% end %>
            </div>
          <% end %>

          <div>
            <%= render 'card/download_dropdown', resource: card %>
          </div>
        </div>
      </td>

      <td class="py-3 px-4 text-sm hidden md:table-cell w-max align-top">
        <div class="flex flex-col items-start gap-2">
          <span class="inline-flex items-center rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-emerald-700">
            <%= resource_type_label(card.resource_type) %>
          </span>

          <% if card.humanize_cardinality_type.present? %>
            <span class="text-xs text-slate-500"><%= card.humanize_cardinality_type %></span>
          <% end %>
        </div>
      </td>

      <% if show_tags_column %>
        <td class="py-3 px-4 text-sm hidden md:table-cell text-pretty align-top">
          <% if card.get_tags.present? %>
            <div class="flex flex-wrap gap-2">
              <% card.get_tags.each do |tag| %>
                <% facet = Resources::SearchQuery::TagFacet.new(tag: tag, name: tag.name, count: nil, selected: Array(search_context&.selected_tags).include?(tag.name)) %>
                <%= render partial: 'resources/tag_filter', locals: { facet: facet } %>
              <% end %>
            </div>
          <% end %>
        </td>
      <% end %>

      <td class="text-center py-3 px-4 hidden md:table-cell align-top">
        <%= render 'card/download_dropdown', resource: card %>
      </td>
    </tr>
  <% end %>
  </tbody>
</table>
