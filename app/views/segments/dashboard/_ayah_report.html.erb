<div class="page-wrapper container max-w-7xl mx-auto px-4 mt-4">
  <div class="page-section filters">
    <%= form_with url: segments_ayah_report_path, method: :get, class: "flex gap-4 mb-6" do %>
      <div>
        <label class="block text-sm font-semibold">Surah:</label>
        <select name="surah" class="border rounded px-2 py-1">
          <option value="">All</option>

          <% @presenter.segmented_surah.each do |s| %>
            <option value="<%= s %>" <%= 'selected' if @presenter.selected_surah.to_s == s.to_s %>>Surah <%= s %></option>
          <% end %>
        </select>
      </div>

      <div class="flex items-end">
        <button type="submit" class="px-4 py-2 rounded font-medium transition-colors bg-blue-400 hover:bg-blue-500 text-white">Filter</button>
      </div>
    <% end %>
  </div>

  <div class="page-section mt-4">
    <h1 class="text-xl font-bold mb-4">Per-Ayah Mistake Report</h1>
    <table class="w-full border-collapse shadow-sm rounded-md">
      <thead>
      <tr class="bg-gray-100 text-left">
        <th class="p-2 border-b">Surah</th>
        <th class="p-2 border-b">Ayah</th>
        <th class="p-2 border-b">Total Mistakes</th>
        <th class="p-2 border-b">Reciters</th>
        <th class="p-2 border-b">Failure Types</th>
      </tr>
      </thead>
      <tbody>
      <% @presenter.ayah_failures.each do |f| %>
        <tr class="border-b hover:bg-gray-50">
          <td class="p-2"><%= f.surah_number %></td>
          <td class="p-2"><%= f.ayah_number %></td>
          <td class="p-2"><%= f.total_failures %></td>
          <td class="p-2"><%= f.reciters %></td>
          <td class="p-2"><%= f.failure_types %></td>
        </tr>
      <% end %>
      </tbody>
    </table>
  </div>
</div>