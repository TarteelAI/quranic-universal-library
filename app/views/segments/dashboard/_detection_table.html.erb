<div class="page-wrapper container max-w-7xl mx-auto px-4 mt-4">
  <div class="page-section filters">
    <%= form_with url: segments_detections_path, method: :get, local: true, class: "flex gap-4 mb-6" do %>
      <div>
        <label class="block text-sm font-semibold">Reciter:</label>
        <select name="reciter_id" class="border rounded px-2 py-1">
          <option value="">All</option>
          <% @presenter.reciters.each do |reciter| %>
            <option value="<%= reciter.id %>" <%= 'selected' if @presenter.selected_reciter == reciter.id %>><%= reciter.name %></option>
          <% end %>
        </select>
      </div>

      <div>
        <label class="block text-sm font-semibold">Surah:</label>
        <select name="surah" class="border rounded px-2 py-1">
          <option value="">All</option>
          <% @presenter.segmented_surah.each do |s| %>
            <option value="<%= s %>" <%= 'selected' if @presenter.selected_surah.to_s == s.to_s %>>Surah <%= s %></option>
          <% end %>
        </select>
      </div>

      <div class="flex items-end">
        <button type="submit" class="px-4 py-2 rounded font-medium transition-colors bg-blue-400 hover:bg-blue-500 text-white">Filter</button>
      </div>
    <% end %>
  </div>

  <div class="page-section mt-4">
    <h1 class="text-xl font-bold mb-4">Detection Type Summary</h1>

    <table class="w-full border-collapse rounded-md shadow-sm">
      <thead>
      <tr class="bg-gray-100 text-left">
        <th class="p-2 border-b">Reciter</th>
        <th class="p-2 border-b">Surah</th>
        <th class="p-2 border-b">Type</th>
        <th class="p-2 border-b">Count</th>
      </tr>
      </thead>
      <tbody>
      <% @grouped_detections.each do |d| %>
        <tr class="border-b hover:bg-gray-50">
          <td class="p-2"><%= d.reciter_name %></td>
          <td class="p-2">Surah <%= d.surah_number %></td>
          <td class="p-2"><%= d.detection_type %></td>
          <td class="p-2"><%= d.total %></td>
        </tr>
      <% end %>
      </tbody>
    </table>
  </div>
</div>
