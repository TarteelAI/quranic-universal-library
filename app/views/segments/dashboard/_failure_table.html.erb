<%
  pagy, failures = @presenter.failures
%>

<div class="page-wrapper container max-w-7xl mx-auto px-4">
  <div class="page-section filters">
    <%= form_tag segments_failures_path, method: :get do %>
      <div data-controller="chapter-verses-filter" class="flex flex-wrap">
        <div class="mb-4 me-2">
          <%= select_tag :surah, options_for_select(@presenter.chapter_options, @presenter.selected_surah), include_blank: true, class: 'form-select w-[85vw] sm:w-auto ', id: 'chapter-select', data: { controller: 'select2' } %>
          <p class="text-sm text-gray-600 mt-1">Filter by Surah</p>
        </div>

        <div class="mb-4 me-2">
          <%= select_tag :reciter, options_for_select(@presenter.reciters.pluck(:name, :id), @presenter.selected_reciter), include_blank: true, class: 'form-select w-[85vw] sm:w-[200px]', data: { controller: 'select2' } %>
          <p class="text-sm text-gray-600 mt-1">Filter reciter</p>
        </div>

        <div class="mb-4 me-2">
          <%= search_field_tag :failure_type, params[:failure_type], class: 'w-[85vw] sm:w-[200px]' %>
          <p class="text-sm text-gray-600 mt-1">Search with failure type</p>
        </div>

        <div class="mb-4 me-2">
          <%= search_field_tag :expected_text, params[:expected_text], class: 'w-[85vw] sm:w-[200px]' %>
          <p class="text-sm text-gray-600 mt-1">Search with expected script</p>
        </div>

        <div class="mb-4 me-2">
          <%= search_field_tag :received_text, params[:received_text], class: 'w-[85vw] sm:w-[200px]' %>
          <p class="text-sm text-gray-600 mt-1">Search with received script</p>
        </div>

        <div class="mb-4 me-2">
          <div class="mb-4 me-2">
            <%= select_tag :correction_status, options_for_select([['All', 'all'], ['Corrected', 'corrected'], ['Pending', 'pending']], params[:corrected]), include_blank: true, class: 'form-select w-[85vw] sm:w-[200px]' %>
            <p class="text-sm text-gray-600 mt-1">Filter by correction</p>
          </div>
        </div>

        <div class="mb-4">
          <%= submit_tag 'Filter', class: 'btn btn-success', data: { disable_with: 'Please wait..' } %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="page-section mt-4">
    <h2 class="text-2xl my-2">
      Failures
    </h2>
    <div class="tools-table-overflow">
      <table class="w-full hover:bg-gray-50">
        <thead class="position-sticky bg-white border-b border-gray-300 top-0">
        <tr class="bg-gray-100 text-left">
          <th class="p-2 border-b">Surah</th>
          <th class="p-2 border-b">Ayah</th>
          <th class="p-2 border-b">Word</th>
          <th class="p-2 border-b">Start Time</th>
          <th class="p-2 border-b">End Time</th>
          <th class="p-2 border-b">Reciter</th>
          <th class="p-2 border-b">Failure Type</th>
          <th>
            Received transcript
          </th>
          <th>
            Expected
          </th>

          <th>
            Corrected?
          </th>

          <th>
            Actions
          </th>
        </tr>
        </thead>

        <tbody>
        <% failures.each do |failure| %>
          <tr class="border-b hover:bg-gray-50">
            <td class="p-2">
              <%= failure.surah_number %>
            </td>

            <td class="p-2">
              <%= failure.ayah_number %>
              <% if failure.corrected_ayah_number && failure.corrected_ayah_number != failure.ayah_number %>
                <span class="ml-2 inline-block bg-green-100 text-green-800 text-xs font-semibold px-2 py-1 rounded-full">
                  <%= failure.corrected_ayah_number %>
                 </span>
              <% end %>
            </td>
            <td class="p-2">
              <%= failure.word_number %>
              <% if failure.corrected_word_number && failure.corrected_word_number != failure.word_number %>
                <span class="ml-2 inline-block bg-green-100 text-green-800 text-xs font-semibold px-2 py-1 rounded-full">
                  <%= failure.corrected_word_number %>
                 </span>
              <% end %>
            </td>
            <td class="p-2">
              <%= failure.start_time %>

              <% if failure.corrected_start_time %>
                <span class="ml-2 inline-block bg-green-100 text-green-800 text-xs font-semibold px-2 py-1 rounded-full">
                  <%= failure.corrected_start_time %>
                 </span>
              <% end %>
            </td>

            <td class="p-2">
              <%= failure.end_time %>

              <% if failure.corrected_end_time %>
                <span class="ml-2 inline-block bg-green-100 text-green-800 text-xs font-semibold px-2 py-1 rounded-full">
                  <%= failure.corrected_end_time %>
                 </span>
              <% end %>
            </td>
            <td class="p-2"><%= failure.reciter_id || "N/A" %></td>
            <td class="p-2">
              <div data-controller="tooltip" title="<%= failure.mistake_positions %>">
                <%= failure.failure_type %>
              </div>
            </td>
            <td class="p-2">
              <span class="qpc-hafs">
                <%= failure.received_transcript %>
              </span>
            </td>
            <td class="p-2">
              <span class="qpc-hafs">
                <%= failure.expected_transcript.presence || failure.text %>
              </span>
            </td>
            <td>
              <% if failure.corrected? %>
                <span class="badge badge-pill badge-success"
                  data-controller="tooltip"
                  title="Corrected word <%= failure.surah_number %>:<%= failure.corrected_ayah_number %>:<%= failure.corrected_word_number %>"
                >
                  Yes
                </span>
              <% else %>
                <span class="badge badge-pill badge-danger">No</span>
              <% end %>
            </td>
            <td>
              <%= link_to 'logs', segments_logs_path(reciter: failure.reciter_id, surah: failure.surah_number), target: '_blank' %>
              <%= link_to '<i class="fas fa-stream"></i>'.html_safe, segments_timeline_path(reciter: failure.reciter_id, surah: failure.surah_number, ayah: failure.ayah_number || failure.corrected_ayah_number), target: '_blank' %>
            </td>
          </tr>
        <% end %>

        <tr>
          <td colspan="10">
            <%= pagination_section pagy %>
          </td>
        </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
