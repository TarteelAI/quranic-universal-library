<div class="page-wrapper container max-w-7xl mx-auto px-4">
  <div class="page-section mt-4">
    <h2>Logs</h2>

    <div class="overflow-x-auto">
      <table class="w-full hover:bg-gray-50">
        <thead class="sticky top-0 z-10 bg-white border-b border-gray-300">
        <tr class="bg-gray-100 text-left">
          <th class="p-2 border-b">Time</th>
          <th class="p-2 border-b">Surah</th>
          <th class="p-2 border-b">Log</th>
        </tr>
        </thead>

        <tbody>
        <% @logs.each do |log| %>
          <tr class="border-b hover:bg-gray-50">
            <td class="p-2"><%= Time.at log.timestamp %></td>
            <td class="p-2"><%= log.surah_number %></td>
            <td class="p-2"><%= log.log %></td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>