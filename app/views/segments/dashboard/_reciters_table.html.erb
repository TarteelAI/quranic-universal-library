<div class="page-wrapper container max-w-7xl mx-auto px-4 mt-4">
  <div class="page-section filters">
    <%= form_with url: segments_reciters_path, method: :get, class: "flex gap-4 mb-6" do %>
      <div>
        <label class="block text-sm font-semibold">Surah:</label>
        <select name="surah" class="border rounded px-2 py-1">
          <option value="">All</option>
          <% @presenter.segmented_surah.each do |s| %>
            <option value="<%= s %>" <%= 'selected' if @presenter.selected_surah.to_s == s.to_s %>>Surah <%= s %></option>
          <% end %>
        </select>
      </div>

      <div class="flex items-end">
        <button type="submit" class="px-4 py-2 rounded font-medium transition-colors bg-blue-400 hover:bg-blue-500 text-white">Filter</button>
      </div>
    <% end %>
  </div>

  <div class="page-section mt-4">
    <h1 class="text-xl font-bold mb-4">
      Reciters Summary (total <%= @presenter.reciters.size %>)
    </h1>


    <table class="w-full border-collapse rounded-md shadow-sm">
      <thead>
      <tr class="bg-gray-100 text-left">
        <th class="p-2 border-b">Reciter</th>
        <th class="p-2 border-b">Positions</th>
        <th class="p-2 border-b">Failures</th>
        <th class="p-2 border-b">Corrected</th>
        <th class="p-2 border-b">Pending</th>
        <th class="p-2 border-b">Missed Words</th>
        <th class="p-2 border-b">Fixed missed Words</th>
        <th class="p-2 border-b">Actions</th>
      </tr>
      </thead>
      <tbody>
      <% @presenter.reciter_stats.each do |reciter| %>
        <tr class="border-b hover:bg-gray-50">
          <td class="p-2">
            <%= link_to reciter[:name], segments_reciter_path(reciter[:id]), 
                class: "text-blue-600 hover:text-blue-800 hover:underline" %>
          </td>
          <td class="p-2"><%= reciter[:positions] %></td>

          <td class="p-2">
            <%= link_to reciter[:failures], segments_failures_path(reciter: reciter[:id]) %>
          </td>

          <td class="p-2">
            <%= link_to reciter[:corrected_failures], segments_failures_path(reciter: reciter[:id], correction_status: 'corrected') %>

            <span class="ml-2 inline-block bg-green-100 text-green-800 text-xs font-semibold px-2 py-1 rounded-full">
             <%= number_to_percentage(reciter[:corrected_percentage], precision: 1) %>
            </span>
          </td>

          <td class="p-2">
            <%= link_to reciter[:pending_failures], segments_failures_path(reciter: reciter[:id], correction_status: 'pending') %>
            <span class="ml-2 inline-block bg-red-100 text-red-800 text-xs font-semibold px-2 py-1 rounded-full">
             <%= number_to_percentage(reciter[:pending_percentage], precision: 1) %>
            </span>
          </td>

          <td class="p-2">
            <%= link_to reciter[:missing_words], segments_failures_path(reciter: reciter[:id], failure_type: 'MISSED_WORD') %>

            <span class="ml-2 inline-block bg-green-100 text-green-800 text-xs font-semibold px-2 py-1 rounded-full">
             <%= number_to_percentage(reciter[:missing_words_percentage], precision: 1) %>
            </span>
          </td>

          <td class="p-2">
            <%= link_to reciter[:corrected_missing_words], segments_failures_path(reciter: reciter[:id], failure_type: 'MISSED_WORD',  correction_status: 'corrected') %>

            <span class="ml-2 inline-block bg-green-100 text-green-800 text-xs font-semibold px-2 py-1 rounded-full">
             <%= number_to_percentage(reciter[:corrected_missing_words_percentage], precision: 1) %>
            </span>
          </td>
          <td class="p-2">
            <%= link_to segments_download_reciter_path(reciter[:id]), 
                method: :post,
                class: "bg-blue-500 hover:bg-blue-600 text-white px-3 py-1 rounded text-sm no-underline inline-flex items-center gap-1",
                data: { 
                  confirm: "This will prepare segments data for #{reciter[:name]} and send it to your email. Continue?",
                  turbo_method: :post
                } do %>
              <i class="fas fa-download"></i>
              <span>Download</span>
            <% end %>
          </td>
        </tr>
      <% end %>
      </tbody>
    </table>
  </div>
</div>
