<%
  selected_reciter = @presenter.selected_reciter
  selected_surah = @presenter.selected_surah
  selected_review_type = @presenter.selected_review_type
  pagination, ayah_reviews = @presenter.ayah_reviews

  type_colors = {
    'missing_segments' => 'bg-red-100 text-red-800',
    'repetition' => 'bg-orange-100 text-orange-800',
    'auto_fixed' => 'bg-blue-100 text-blue-800'
  }
%>

<div class="page-wrapper container-lg mt-4">
  <div class="page-section filters">
    <%= form_with url: segments_review_ayahs_path, method: :get, local: true, class: "flex gap-4 mb-6" do %>
      <div>
        <label class="block text-sm font-semibold">Reciter:</label>
        <select name="reciter" class="border rounded px-2 py-1">
          <option value="">All</option>
          <% @presenter.reciters.each do |reciter| %>
            <option value="<%= reciter.id %>" <%= 'selected' if selected_reciter.to_s == reciter.id.to_s %>><%= reciter.name %></option>
          <% end %>
        </select>
      </div>

      <div>
        <label class="block text-sm font-semibold">Surah:</label>
        <select name="surah" class="border rounded px-2 py-1">
          <option value="">All</option>
          <% @presenter.segmented_surah.each do |s| %>
            <option value="<%= s %>" <%= 'selected' if selected_surah.to_s == s.to_s %>>Surah <%= s %></option>
          <% end %>
        </select>
      </div>

      <div>
        <label class="block text-sm font-semibold">Review Type:</label>
        <select name="review_type" class="border rounded px-2 py-1">
          <option value="">All</option>
          <% @presenter.review_types.each do |type| %>
            <option value="<%= type %>" <%= 'selected' if selected_review_type == type %>>
              <%= type.humanize %>
            </option>
          <% end %>
        </select>
      </div>

      <div class="flex items-end">
        <button type="submit" class="btn btn-info">Filter</button>
      </div>
    <% end %>
  </div>

  <div class="page-section mt-4">
    <h1 class="text-xl font-bold mb-4">Review Ayah Issues</h1>
    
    <% if ayah_reviews.any? %>
      <div class="mb-4">
        <p class="text-sm text-gray-600">
          Showing <%= ayah_reviews.count %> review issue(s) found during segmentation processing.
        </p>
      </div>

      <table class="w-full border-collapse rounded-md shadow-sm">
        <thead>
        <tr class="bg-gray-100 text-left">
          <th class="p-3 border-b">Reciter</th>
          <th class="p-3 border-b">Surah</th>
          <th class="p-3 border-b">Ayah</th>
          <th class="p-3 border-b">Type</th>
          <th class="p-3 border-b">Comment</th>
          <th class="p-3 border-b">Actions</th>
        </tr>
        </thead>
        <tbody>
        <% ayah_reviews.each do |issue| %>
          <tr class="border-b hover:bg-gray-50">
            <td class="p-3">
              <span class="font-medium"><%= issue.reciter_id %></span>
            </td>
            <td class="p-3">
              <span class="bg-blue-100 text-blue-800 px-2 py-1 rounded text-sm">
                Surah <%= issue.surah_number %>
              </span>
            </td>
            <td class="p-3">
              <span class="bg-green-100 text-green-800 px-2 py-1 rounded text-sm">
                Ayah <%= issue.ayah_number %>
              </span>
            </td>
            <td class="p-3">
              <%
                type_color = type_colors[issue.review_type] || 'bg-gray-100 text-gray-800'
              %>
              <span class="px-2 py-1 rounded text-sm <%= type_color %>">
                <%= issue.review_type&.humanize || 'Unknown' %>
              </span>
            </td>
            <td class="p-3">
              <div class="max-w-md">
                <p class="text-sm text-gray-700 leading-relaxed">
                  <%= issue.comment %>
                </p>
              </div>
            </td>
            <td class="p-3">
              <div class="flex gap-2">
                <%= link_to "Timeline", 
                    segments_timeline_path(reciter: issue.reciter_id, surah: issue.surah_number, ayah: issue.ayah_number),
                    class: "bg-green-500 hover:bg-green-600 text-white px-3 py-1 rounded text-sm no-underline" %>
              </div>
            </td>
          </tr>
        <% end %>

        <tr>
          <td colspan="6">
            <%= pagination_section pagination %>
          </td>
        </tr>

        </tbody>
      </table>
    <% else %>
      <div class="text-center py-12">
        <div class="text-gray-500 text-lg mb-4">
          <i class="fas fa-check-circle text-green-500 text-4xl mb-4"></i>
          <p>No review issues found!</p>
        </div>
      </div>
    <% end %>
  </div>
</div>
