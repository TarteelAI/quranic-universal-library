<%= render 'segments/header' %>

<%
  reciter = @presenter.reciter
%>

<div class="page-wrapper container-lg">
  <div class="page-section mt-4" data-turbo="false">
    <!-- Header Section -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-3xl font-bold mb-2"><%= reciter.name %></h1>
        <p class="text-gray-600">Segmentation Statistics & Progress Report</p>
      </div>
      <div class="flex gap-2">
        <%= link_to segments_reciters_path, class: "bg-gray-500 hover:bg-gray-600 text-white px-4 py-2 rounded text-sm no-underline" do %>
          <i class="fas fa-arrow-left mr-2"></i>
          Back to Reciters
        <% end %>
        <%= button_to segments_download_reciter_path(reciter.id),
                    method: :post,
                    class: "bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded text-sm no-underline inline-flex items-center gap-2",
                    data: {
                      confirm: "This will prepare segments data for #{reciter[:name]} and send it to your email. Continue?",
                      turbo_method: :post
                    } do %>
          <i class="fas fa-download"></i>
          <span>Download Data</span>
        <% end %>
      </div>
    </div>

    <!-- Overall Progress Section -->
    <div class="bg-white rounded-lg shadow-sm border p-6 mb-6">
      <h2 class="text-xl font-semibold mb-4">Overall Progress</h2>
      
      <!-- Stats Row -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
        <div class="text-center">
          <div class="text-2xl font-bold text-blue-600"><%= @presenter.overall_progress_percentage %>%</div>
          <div class="text-xs text-gray-600">Completion</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-green-600"><%= number_with_delimiter(@presenter.segmentation_stats[:total_segmented_ayahs]) %></div>
          <div class="text-xs text-gray-600">Ayahs</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-purple-600"><%= number_with_delimiter(@presenter.segmentation_stats[:total_segmented_words]) %></div>
          <div class="text-xs text-gray-600">Words</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-orange-600"><%= @presenter.segmentation_stats[:segmented_chapters_count] %></div>
          <div class="text-xs text-gray-600">Surahs</div>
        </div>
      </div>
      
      <!-- Progress Bar Row -->
      <div class="mt-6">
        <div class="flex justify-between items-center mb-3">
          <span class="text-sm font-medium text-gray-700">
            Progress: <%= number_with_delimiter(@presenter.segmentation_stats[:total_segmented_ayahs]) %> / <%= number_with_delimiter(@presenter.total_verses) %> ayahs
          </span>
          <span class="text-lg font-bold text-blue-600"><%= @presenter.overall_progress_percentage %>%</span>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-4 shadow-inner">
          <div class="bg-gradient-to-r from-blue-500 to-blue-600 h-4 rounded-full shadow-sm transition-all duration-300" 
               style="width: <%= @presenter.overall_progress_percentage %>%">
          </div>
        </div>
        <div class="text-xs text-gray-500 mt-1 text-center">
          <%= @presenter.segmentation_stats[:total_segmented_ayahs] %> ayahs completed
        </div>
      </div>
    </div>

    <div class="bg-white rounded-lg shadow-sm border p-6 mb-6">
      <h2 class="text-xl font-semibold mb-4">Missing Surahs</h2>
      
      <% if @presenter.missing_ayahs_stats[:missing_surahs].any? %>
        <div class="mb-6">
          <h3 class="text-lg font-medium mb-3 text-red-600">
            <i class="fas fa-exclamation-triangle mr-2"></i>
            Completely Missing Surahs (<%= @presenter.missing_ayahs_stats[:missing_surahs].size %>)
          </h3>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
            <% @presenter.missing_ayahs_stats[:missing_surahs].each do |surah| %>
              <div class="bg-red-50 border border-red-200 rounded p-3">
                <div class="font-medium text-red-800">Surah <%= surah.is_a?(Hash) ? surah[:chapter_id] : surah %> - <%= surah.is_a?(Hash) ? surah[:chapter_name] : 'Unknown' %></div>
                <div class="text-sm text-red-600"><%= surah.is_a?(Hash) ? surah[:expected_verses] : 0 %> ayahs missing</div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Partially Missing Surahs -->
      <% if @presenter.missing_ayahs_stats[:missing_ayahs_by_surah].any? %>
        <div>
          <h3 class="text-lg font-medium mb-3 text-orange-600">
            <i class="fas fa-exclamation-circle mr-2"></i>
            Partially Missing Ayahs (<%= @presenter.missing_ayahs_stats[:missing_ayahs_by_surah].size %> surahs)
          </h3>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
            <% @presenter.missing_ayahs_stats[:missing_ayahs_by_surah].each do |chapter_id, surah| %>
              <div class="bg-orange-50 border border-orange-200 rounded p-3">
                <div class="font-medium text-orange-800">Surah <%= surah[:chapter_id] %> - <%= surah[:chapter_name] %></div>
                <div class="text-sm text-orange-600">
                  <%= surah[:actual_verses] %> / <%= surah[:expected_verses] %> ayahs 
                  (<%= surah[:missing_count] %> missing)
                </div>
                <div class="w-full bg-orange-200 rounded-full h-1 mt-2">
                  <div class="bg-orange-500 h-1 rounded-full" 
                       style="width: <%= (surah[:actual_verses] / surah[:expected_verses].to_f) * 100 %>%"></div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if @presenter.missing_ayahs_stats[:missing_surahs].empty? && @presenter.missing_ayahs_stats[:missing_ayahs_by_surah].empty? %>
        <div class="text-center py-8 text-gray-500">
          <i class="fas fa-check-circle text-4xl text-green-500 mb-2"></i>
          <p class="text-lg">No missing content detected!</p>
          <p class="text-sm">All segmented surahs appear to be complete.</p>
        </div>
      <% end %>
    </div>

    <div class="bg-white rounded-lg shadow-sm border p-6 mb-6">
      <h2 class="text-xl font-semibold mb-4">Surah Segments details</h2>
      
      <% if @presenter.segmented_surahs.any? %>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse rounded-md">
            <thead>
              <tr class="bg-gray-100">
                <th class="p-3 text-left border-b">Surah</th>
                <th class="p-3 text-center border-b">Verses</th>
                <th class="p-3 text-center border-b">Segmented</th>
                <th class="p-3 text-center border-b">Words</th>
                <th class="p-3 text-center border-b">Progress</th>
                <th class="p-3 text-center border-b">Status</th>
              </tr>
            </thead>
            <tbody>
              <% @presenter.segmented_surahs.each do |surah| %>
                <tr class="border-b hover:bg-gray-50">
                  <td class="p-3">
                    <div class="font-medium">Surah <%= surah[:chapter_id] %></div>
                    <div class="text-sm text-gray-600"><%= surah[:chapter_name] %></div>
                  </td>
                  <td class="p-3 text-center font-mono">
                    <%= surah[:verses_count] %>
                  </td>
                  <td class="p-3 text-center font-mono">
                    <%= surah[:segmented_verses] %>
                  </td>
                  <td class="p-3 text-center font-mono">
                    <%= number_with_delimiter(surah[:segmented_words]) %>
                  </td>
                  <td class="p-3">
                    <div class="flex items-center gap-2">
                      <div class="flex-1 bg-gray-200 rounded-full h-2">
                        <div class="bg-blue-600 h-2 rounded-full" 
                             style="width: <%= surah[:completion_percentage] %>%"></div>
                      </div>
                      <span class="text-sm font-medium min-w-0"><%= surah[:completion_percentage] %>%</span>
                    </div>
                  </td>
                  <td class="p-3 text-center">
                    <% if surah[:completion_percentage] == 100 %>
                      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                        <i class="fas fa-check mr-1"></i>
                        Complete
                      </span>
                    <% elsif surah[:completion_percentage] > 0 %>
                      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                        <i class="fas fa-clock mr-1"></i>
                        Partial
                      </span>
                    <% else %>
                      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">
                        <i class="fas fa-times mr-1"></i>
                        Missing
                      </span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-8 text-gray-500">
          <i class="fas fa-info-circle text-4xl text-blue-500 mb-2"></i>
          <p class="text-lg">No segmented surahs found</p>
          <p class="text-sm">This reciter doesn't have any segmentation data yet.</p>
        </div>
      <% end %>
    </div>

    <!-- Summary Stats -->
    <div class="bg-white rounded-lg shadow-sm border p-6">
      <h2 class="text-xl font-semibold mb-4">Summary Statistics</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="text-2xl font-bold text-blue-600"><%= @presenter.segmentation_stats[:segmented_chapters_count] %></div>
          <div class="text-sm text-gray-600">of <%= @presenter.total_chapters %> Surahs</div>
          <div class="text-xs text-gray-500">Segmented</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-green-600"><%= @presenter.missing_ayahs_stats[:total_missing_surahs] %></div>
          <div class="text-sm text-gray-600">Completely</div>
          <div class="text-xs text-gray-500">Missing Surahs</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-orange-600"><%= @presenter.missing_ayahs_stats[:missing_ayahs_by_surah].size %></div>
          <div class="text-sm text-gray-600">Partially</div>
          <div class="text-xs text-gray-500">Missing Surahs</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-red-600"><%= number_with_delimiter(@presenter.missing_ayahs_stats[:total_missing_ayahs]) %></div>
          <div class="text-sm text-gray-600">Total Missing</div>
          <div class="text-xs text-gray-500">Ayahs</div>
        </div>
      </div>
    </div>
  </div>
</div>
