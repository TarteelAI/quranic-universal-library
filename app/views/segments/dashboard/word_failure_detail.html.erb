<%= render 'segments/header' %>

<%
  failures = @presenter.word_failures
%>
<div
  class="page-wrapper container max-w-7xl mx-auto px-4"
  data-controller="segments--failure-player"
>
  <div class="bg-white border border-gray-200 rounded-lg shadow-sm mb-4">
    <div class="px-6 py-4 bg-gray-50 border-b border-gray-200 rounded-t-lg">
      <h5 class="text-lg font-semibold mb-3 mb-0">Word Information</h5>
    </div>
    <div class="p-6">
      <div class="flex flex-wrap gap-4">
        <div class="w-full md:w-1/2">
          <p><strong>Word Text:</strong> <span class="qpc-hafs text-xl"><%= @word_text %></span></p>
          <p><strong>Total Failures:</strong> <span class="badge badge-pill badge-danger"><%= failures.count %></span></p>
        </div>
        <div class="w-full md:w-1/2">
          <p><strong>Failure Types:</strong></p>
          <% failures.group(:failure_type).count.each do |type, count| %>
            <span class="badge badge-pill badge-warning"><%= type %> (<%= count %>)</span>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg shadow-sm">
    <div class="px-6 py-4 bg-gray-50 border-b border-gray-200 rounded-t-lg">
      <h5 class="text-lg font-semibold mb-3 mb-0">Failure Variants</h5>
    </div>

    <div class="p-6 p-0">
      <div class="table-responsive">
        <table class="w-full hover:bg-gray-50 mb-0">
          <thead class="table-light">
          <tr>
            <th class="p-3">Surah:Ayah:Word</th>
            <th class="p-3">Reciter</th>
            <th class="p-3">Expected</th>
            <th class="p-3">Received</th>
            <th class="p-3">Failure Type</th>
            <th class="p-3">Time Range</th>
            <th class="p-3">Status</th>
            <th class="p-3">Actions</th>
          </tr>
          </thead>
          <tbody>
            <% failures.each do |failure| %>
              <tr>
                <td class="p-3">
                  <span class="badge badge-pill badge-info">
                    <%= link_to "#{failure.surah_number}:#{failure.ayah_number}:#{failure.word_number}", segments_timeline_path(reciter: failure.reciter_id, surah: failure.surah_number, ayah: failure.ayah_number), target: '_blank' %>
                  </span>
                </td>
                <td class="p-3">
                  <%= failure.reciter_id %>
                </td>
                <td class="p-3">
                  <span class="qpc-hafs font-semibold"><%= failure.expected_transcript %></span>
                </td>
                <td class="p-3">
                  <span class="qpc-hafs text-red-600"><%= failure.received_transcript %></span>
                </td>
                <td class="p-3">
                  <span class="badge badge-pill badge-warning"><%= failure.failure_type %></span>
                </td>
                <td class="p-3">
                  <% if failure.start_time && failure.end_time %>
                    <span class="text-sm">
                      <%= failure.start_time %> - <%= failure.end_time %>
                    </span>
                  <% else %>
                    <span class="text-muted">N/A</span>
                  <% end %>
                </td>
                <td class="p-3">
                  <% if failure.corrected %>
                    <span class="badge badge-pill badge-success">Corrected</span>
                  <% else %>
                    <span class="badge badge-pill badge-danger">Pending</span>
                  <% end %>
                </td>
                <td class="p-3">
                  <% if failure.start_time && failure.end_time %>
                    <button class="px-4 py-2 rounded font-medium transition-colors px-3 py-1 text-sm border border-blue-500 text-blue-500 hover:bg-blue-500 hover:text-white play-audio-btn" 
                            data-start-time="<%= failure.start_time %>" 
                            data-end-time="<%= failure.end_time %>"
                            data-reciter-id="<%= failure.reciter_id %>"
                            data-surah="<%= failure.surah_number %>"
                            data-ayah="<%= failure.ayah_number %>"
                            data-audio-url="<%= failure.reciter.audio_url(failure.surah_number) %>">
                      <i class="fas fa-play"></i> Play
                    </button>
                  <% else %>
                    <span class="text-muted">No audio</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div id="audio-player" class="mt-4" style="display: none;">
    <div class="bg-white border border-gray-200 rounded-lg shadow-sm">
      <div class="px-6 py-4 bg-gray-50 border-b border-gray-200 rounded-t-lg">
        <h6 class="text-lg font-semibold mb-3 mb-0">Audio Player</h6>
      </div>
      <div class="p-6">
        <audio id="audio-element" controls class="w-full">
          Your browser does not support the audio element.
        </audio>
        <div class="mt-2">
          <small class="text-gray-600">
            Playing segment: <span id="current-segment-info"></span>
          </small>
        </div>
      </div>
    </div>
  </div>
</div>
