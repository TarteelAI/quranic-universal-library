<%
  filter_juz = local_assigns[:juz]
  filter_page = local_assigns[:page]
  filter_verse = local_assigns[:verse] != false

  chapters = Chapter.order('id asc').map do |c|
    [
      c.humanize,
      c.id,
      data: {
        verses: c.verses_count
      }
    ]
  end

  chapter = Chapter.find_by(id: params[:filter_chapter].to_i) if params[:filter_chapter].present?

  verses_range = (1 .. chapter&.verses_count || 286)
%>

<% if filter_juz %>
  <div class="mb-4 me-2">
    <%= select_tag :filter_juz, options_for_select(1..30, params[:filter_juz]), include_blank: true, class: 'w-full sm:w-44 px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all', id: 'juz-select', data: { placeholder: 'Filter by juz/para', controller: 'select2' } %>
    <p class="text-xs text-slate-500 mt-1">Filter by Juz/Para</p>
  </div>
<% end %>

<% if filter_page %>
  <div class="mb-4 me-2">
    <%= select_tag :filter_page, options_for_select(1..604, params[:filter_page]), include_blank: true, class: 'w-full sm:w-44 px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all', id: 'page-select', data: { placeholder: 'Filter by page', controller: 'select2' } %>
    <p class="text-xs text-slate-500 mt-1">Filter by Page</p>
  </div>
<% end %>

<div class="mb-4 me-2">
  <%= select_tag :filter_chapter, options_for_select(chapters, params[:filter_chapter]), include_blank: true, class: 'w-full sm:w-64 px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all', id: 'chapter-select', data: { controller: 'select2' } %>
  <p class="text-xs text-slate-500 mt-1">Filter by Surah</p>
</div>

<% if filter_verse %>
  <div class="mb-4 me-2">
    <%= select_tag :verse_number, options_for_select(verses_range, params[:verse_number]), include_blank: true, class: 'w-full sm:w-32 px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all', id: 'verse-select', data: { controller: 'select2' } %>
    <p class="text-xs text-slate-500 mt-1">Filter by Ayah</p>
  </div>
<% end %>
