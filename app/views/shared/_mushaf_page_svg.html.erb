<%
  mushaf_page = MushafPage.where(page_number: page, mushaf: mushaf).first
  lines_count = mushaf.lines_per_page.to_i.positive? ? mushaf.lines_per_page : 15
%>

<div
  data-controller="svg-mushaf"
  class="svg-mushaf-demo relative w-full min-w-0"
>
  <div
    data-svg-mushaf-target="toolsBackdrop"
    data-action="click->svg-mushaf#closeToolsPanel"
    class="fixed inset-0 z-40 bg-slate-900/40 opacity-0 pointer-events-none invisible transition-opacity duration-200"
    aria-hidden="true"
  ></div>

  <div class="min-w-0 w-full">
    <div
      data-svg-mushaf-target="svgHost"
      class="relative w-full rounded-xl border border-slate-200 bg-slate-50 p-1 sm:p-2 shadow-inner"
    >
      <div class="[&>svg]:block [&>svg]:w-full [&>svg]:max-w-full [&>svg]:h-auto">
        <%= raw mushaf_page&.text %>
      </div>
    </div>

    <div class="mt-3 rounded-xl border border-slate-200 bg-white px-2 sm:px-4 py-4 shadow-sm">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div class="space-y-2 text-xs leading-relaxed text-slate-600">
          <p>
            This is a Ligature based SVG Mushaf dataset, where each page is represented as a single standalone SVG element. The layout follows the official format published by the King Fahad Quran Printing Complex(1441 AH edition). The dataset consists of 604 pages with 15 lines per page. Each SVG includes semantic markup for lines, ayah, words, diacritical marks to support accurate rendering, indexing, and text-level interaction. This dataset is contributed by
            <a href="https://mushafdatabase.com/" target="_blank" rel="noopener noreferrer" class="underline decoration-dotted underline-offset-2 hover:text-sky-900 text-sky-700">
              Mushaf Database
            </a>.
          </p>
          <p class="text-slate-500">
            Click the Customize button to interact with the mushaf.
          </p>
        </div>
        <div class="flex shrink-0 items-center">
          <button
            type="button"
            data-action="click->svg-mushaf#openCustomizePanel"
            class="rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-800 shadow-sm hover:bg-slate-50"
          >
            Customize
          </button>
        </div>
      </div>
    </div>
  </div>

  <aside
    data-svg-mushaf-target="toolsPanel"
    id="svg-mushaf-tools-panel"
    class="fixed inset-y-0 right-0 z-50 h-full w-[min(22rem,calc(100vw-1rem))] max-w-full overflow-y-auto border-l border-slate-200 bg-white px-4 py-5 shadow-2xl transition-transform duration-300 ease-out translate-x-full pointer-events-none rounded-l-2xl"
    aria-label="Customize mushaf"
    aria-hidden="true"
    hidden
  >
    <div class="mx-auto max-w-3xl space-y-6">
      <div class="flex items-center justify-between gap-3 border-b border-slate-100 pb-4">
        <h2 class="text-sm font-semibold text-slate-900">Customize</h2>
        <button
          type="button"
          data-action="click->svg-mushaf#closeToolsPanel"
          class="rounded-lg border border-slate-200 bg-white px-2.5 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-50"
        >
          Close
        </button>
      </div>

      <p class="text-xs leading-relaxed text-slate-500">
        Use the actions below to interact with the SVG-based Mushaf. You can highlight specific lines, ayahs, or words, and toggle the display of diacritics, waqf marks, page margins, and other elements.
        This is for demonstration purposes only and showcases a sample of how you can interact with the SVG dataset.
      </p>

      <div>
        <h3 class="mb-3 text-xs font-semibold uppercase tracking-wide text-slate-500">Display</h3>
        <div class="flex flex-wrap gap-2">
          <button type="button" class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-xs font-medium text-slate-700 hover:bg-slate-50" data-action="click->svg-mushaf#toggleState" data-key="showDiacritics" data-svg-mushaf-key-param="showDiacritics" data-on-label="Hide diacritics" data-off-label="Show diacritics">Hide diacritics</button>
          <button type="button" class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-xs font-medium text-slate-700 hover:bg-slate-50" data-action="click->svg-mushaf#toggleState" data-key="highlightDiacritics" data-svg-mushaf-key-param="highlightDiacritics" data-on-label="Disable diacritic highlight" data-off-label="Enable diacritic highlight">Enable diacritic highlight</button>
          <button type="button" class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-xs font-medium text-slate-700 hover:bg-slate-50" data-action="click->svg-mushaf#toggleState" data-key="showWaqf" data-svg-mushaf-key-param="showWaqf" data-on-label="Hide waqf" data-off-label="Show waqf">Hide waqf</button>
          <button type="button" class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-xs font-medium text-slate-700 hover:bg-slate-50" data-action="click->svg-mushaf#toggleState" data-key="waqfHighlight" data-svg-mushaf-key-param="waqfHighlight" data-on-label="Disable waqf highlight" data-off-label="Enable waqf highlight">Enable waqf highlight</button>
        </div>
      </div>

      <div>
        <h3 class="mb-3 text-xs font-semibold uppercase tracking-wide text-slate-500">Page margins</h3>
        <p class="mb-3 text-xs text-slate-500">Surah name, juz, page number, hizb, sajda.</p>
        <div class="flex flex-wrap gap-2">
          <% %w[surah juz pageNumber hizb sajda].each do |key| %>
            <% label = { "surah" => "Surah name", "juz" => "Juz name", "pageNumber" => "Page number", "hizb" => "Hizb", "sajda" => "Sajda" }[key] %>
            <button type="button" class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-xs font-medium text-slate-700 hover:bg-slate-50" data-margin-key="<%= key %>" data-action="click->svg-mushaf#toggleMargin" data-on-label="Hide <%= label %>" data-off-label="Show <%= label %>">Hide <%= label %></button>
          <% end %>
        </div>
      </div>

      <div>
        <h3 class="mb-3 text-xs font-semibold uppercase tracking-wide text-slate-500">Lines</h3>
        <div class="flex flex-wrap gap-1.5">
          <% 1.upto(lines_count) do |n| %>
            <button type="button" class="min-w-[2.25rem] rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-xs font-medium text-slate-700 hover:bg-slate-50" data-line="<%= n %>" data-action="click->svg-mushaf#selectLine"><%= n %></button>
          <% end %>
        </div>
      </div>

      <div>
        <h3 class="mb-3 text-xs font-semibold uppercase tracking-wide text-slate-500">Ayahs</h3>
        <p class="mb-3 text-xs text-slate-500">From SVG word groups. Click to highlight and play words (1&nbsp;s each). Click again to clear.</p>
        <div class="flex flex-wrap gap-1.5" data-svg-mushaf-target="ayahList"></div>
        <div class="mt-4">
          <button type="button" class="rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-xs font-medium text-rose-800 hover:bg-rose-100" data-action="click->svg-mushaf#stopSequenceClick">Stop playback</button>
        </div>
      </div>

      <div>
        <h3 class="mb-3 text-xs font-semibold uppercase tracking-wide text-slate-500">Search</h3>
        <div class="flex flex-wrap items-center gap-2">
          <input type="search" placeholder="One word or space-separated phrase…" autocomplete="off" class="min-w-0 flex-1 rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-slate-900" data-svg-mushaf-target="searchInput" data-action="keydown.enter->svg-mushaf#search">
          <button type="button" class="rounded-lg bg-amber-600 px-3 py-2 text-xs font-semibold text-white hover:bg-amber-700" data-action="click->svg-mushaf#search">Search</button>
          <button type="button" class="rounded-lg border border-slate-200 bg-white px-3 py-2 text-xs font-medium text-slate-700 hover:bg-slate-50" data-action="click->svg-mushaf#clearSearch">Clear search</button>
          <span class="text-xs font-medium text-slate-600" data-svg-mushaf-target="matchCount"></span>
        </div>
      </div>
    </div>
  </aside>
</div>
