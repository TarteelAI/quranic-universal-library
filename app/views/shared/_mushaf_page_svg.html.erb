<%
  mushaf_page = MushafPage.where(page_number: page, mushaf: mushaf).first
  lines_count = mushaf.lines_per_page.to_i.positive? ? mushaf.lines_per_page : 15
%>

<div
  data-controller="svg-mushaf"
  class="svg-mushaf-demo tw-relative tw-w-full tw-min-w-0"
>
  <div
    data-svg-mushaf-target="toolsBackdrop"
    data-action="click->svg-mushaf#closeToolsPanel"
    class="tw-fixed tw-inset-0 tw-z-40 tw-bg-slate-900/40 tw-opacity-0 tw-pointer-events-none tw-invisible tw-transition-opacity tw-duration-200"
    aria-hidden="true"
  ></div>

  <div class="tw-min-w-0 tw-w-full">
    <div
      data-svg-mushaf-target="svgHost"
      class="tw-relative tw-w-full tw-rounded-xl tw-border tw-border-slate-200 tw-bg-slate-50 tw-p-1 sm:tw-p-2 tw-shadow-inner"
    >
      <div class="[&>svg]:tw-block [&>svg]:tw-w-full [&>svg]:tw-max-w-full [&>svg]:tw-h-auto">
        <%= raw mushaf_page&.text %>
      </div>
    </div>

    <div class="tw-mt-3 tw-rounded-xl tw-border tw-border-slate-200 tw-bg-white tw-px-2 sm:tw-px-4 tw-py-4 tw-shadow-sm">
      <div class="tw-flex tw-flex-col tw-gap-4 sm:tw-flex-row sm:tw-items-end sm:tw-justify-between">
        <div class="tw-space-y-2 tw-text-xs tw-leading-relaxed tw-text-slate-600">
          <p>
            This is a Ligature based SVG Mushaf dataset, where each page is represented as a single standalone SVG element. The layout follows the official format published by the King Fahad Quran Printing Complex(1441 AH edition). The dataset consists of 604 pages with 15 lines per page. Each SVG includes semantic markup for lines, ayah, words, diacritical marks to support accurate rendering, indexing, and text-level interaction. This dataset is contributed by
            <a href="https://mushafdatabase.com/" target="_blank" rel="noopener noreferrer" class="tw-underline tw-decoration-dotted tw-underline-offset-2 hover:tw-text-sky-900 tw-text-sky-700">
              Mushaf Database
            </a>.
          </p>
          <p class="tw-text-slate-500">
            Click the Customize button to interact with the mushaf.
          </p>
        </div>
        <div class="tw-flex tw-shrink-0 tw-items-center">
          <button
            type="button"
            data-action="click->svg-mushaf#openCustomizePanel"
            class="tw-rounded-full tw-border tw-border-slate-300 tw-bg-white tw-px-4 tw-py-2 tw-text-sm tw-font-semibold tw-text-slate-800 tw-shadow-sm hover:tw-bg-slate-50"
          >
            Customize
          </button>
        </div>
      </div>
    </div>
  </div>

  <aside
    data-svg-mushaf-target="toolsPanel"
    id="svg-mushaf-tools-panel"
    class="tw-fixed tw-inset-y-0 tw-right-0 tw-z-50 tw-h-full tw-w-[min(22rem,calc(100vw-1rem))] tw-max-w-full tw-overflow-y-auto tw-border-l tw-border-slate-200 tw-bg-white tw-px-4 tw-py-5 tw-shadow-2xl tw-transition-transform tw-duration-300 tw-ease-out tw-translate-x-full tw-pointer-events-none tw-rounded-l-2xl"
    aria-label="Customize mushaf"
    aria-hidden="true"
    hidden
  >
    <div class="tw-mx-auto tw-max-w-3xl tw-space-y-6">
      <div class="tw-flex tw-items-center tw-justify-between tw-gap-3 tw-border-b tw-border-slate-100 tw-pb-4">
        <h2 class="tw-text-sm tw-font-semibold tw-text-slate-900">Customize</h2>
        <button
          type="button"
          data-action="click->svg-mushaf#closeToolsPanel"
          class="tw-rounded-lg tw-border tw-border-slate-200 tw-bg-white tw-px-2.5 tw-py-1.5 tw-text-xs tw-font-medium tw-text-slate-600 hover:tw-bg-slate-50"
        >
          Close
        </button>
      </div>

      <p class="tw-text-xs tw-leading-relaxed tw-text-slate-500">
        Use the actions below to interact with the SVG-based Mushaf. You can highlight specific lines, ayahs, or words, and toggle the display of diacritics, waqf marks, page margins, and other elements.
        This is for demonstration purposes only and showcases a sample of how you can interact with the SVG dataset.
      </p>

      <div>
        <h3 class="tw-mb-3 tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide tw-text-slate-500">Display</h3>
        <div class="tw-flex tw-flex-wrap tw-gap-2">
          <button type="button" class="tw-rounded-lg tw-border tw-border-slate-200 tw-bg-white tw-px-3 tw-py-2 tw-text-xs tw-font-medium tw-text-slate-700 hover:tw-bg-slate-50" data-action="click->svg-mushaf#toggleState" data-key="showDiacritics" data-svg-mushaf-key-param="showDiacritics" data-on-label="Hide diacritics" data-off-label="Show diacritics">Hide diacritics</button>
          <button type="button" class="tw-rounded-lg tw-border tw-border-slate-200 tw-bg-white tw-px-3 tw-py-2 tw-text-xs tw-font-medium tw-text-slate-700 hover:tw-bg-slate-50" data-action="click->svg-mushaf#toggleState" data-key="highlightDiacritics" data-svg-mushaf-key-param="highlightDiacritics" data-on-label="Disable diacritic highlight" data-off-label="Enable diacritic highlight">Enable diacritic highlight</button>
          <button type="button" class="tw-rounded-lg tw-border tw-border-slate-200 tw-bg-white tw-px-3 tw-py-2 tw-text-xs tw-font-medium tw-text-slate-700 hover:tw-bg-slate-50" data-action="click->svg-mushaf#toggleState" data-key="showWaqf" data-svg-mushaf-key-param="showWaqf" data-on-label="Hide waqf" data-off-label="Show waqf">Hide waqf</button>
          <button type="button" class="tw-rounded-lg tw-border tw-border-slate-200 tw-bg-white tw-px-3 tw-py-2 tw-text-xs tw-font-medium tw-text-slate-700 hover:tw-bg-slate-50" data-action="click->svg-mushaf#toggleState" data-key="waqfHighlight" data-svg-mushaf-key-param="waqfHighlight" data-on-label="Disable waqf highlight" data-off-label="Enable waqf highlight">Enable waqf highlight</button>
        </div>
      </div>

      <div>
        <h3 class="tw-mb-3 tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide tw-text-slate-500">Page margins</h3>
        <p class="tw-mb-3 tw-text-xs tw-text-slate-500">Surah name, juz, page number, hizb, sajda.</p>
        <div class="tw-flex tw-flex-wrap tw-gap-2">
          <% %w[surah juz pageNumber hizb sajda].each do |key| %>
            <% label = { "surah" => "Surah name", "juz" => "Juz name", "pageNumber" => "Page number", "hizb" => "Hizb", "sajda" => "Sajda" }[key] %>
            <button type="button" class="tw-rounded-lg tw-border tw-border-slate-200 tw-bg-white tw-px-3 tw-py-2 tw-text-xs tw-font-medium tw-text-slate-700 hover:tw-bg-slate-50" data-margin-key="<%= key %>" data-action="click->svg-mushaf#toggleMargin" data-on-label="Hide <%= label %>" data-off-label="Show <%= label %>">Hide <%= label %></button>
          <% end %>
        </div>
      </div>

      <div>
        <h3 class="tw-mb-3 tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide tw-text-slate-500">Lines</h3>
        <div class="tw-flex tw-flex-wrap tw-gap-1.5">
          <% 1.upto(lines_count) do |n| %>
            <button type="button" class="tw-min-w-[2.25rem] tw-rounded-lg tw-border tw-border-slate-200 tw-bg-white tw-px-2 tw-py-1.5 tw-text-xs tw-font-medium tw-text-slate-700 hover:tw-bg-slate-50" data-line="<%= n %>" data-action="click->svg-mushaf#selectLine"><%= n %></button>
          <% end %>
        </div>
      </div>

      <div>
        <h3 class="tw-mb-3 tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide tw-text-slate-500">Ayahs</h3>
        <p class="tw-mb-3 tw-text-xs tw-text-slate-500">From SVG word groups. Click to highlight and play words (1&nbsp;s each). Click again to clear.</p>
        <div class="tw-flex tw-flex-wrap tw-gap-1.5" data-svg-mushaf-target="ayahList"></div>
        <div class="tw-mt-4">
          <button type="button" class="tw-rounded-lg tw-border tw-border-rose-200 tw-bg-rose-50 tw-px-3 tw-py-2 tw-text-xs tw-font-medium tw-text-rose-800 hover:tw-bg-rose-100" data-action="click->svg-mushaf#stopSequenceClick">Stop playback</button>
        </div>
      </div>

      <div>
        <h3 class="tw-mb-3 tw-text-xs tw-font-semibold tw-uppercase tw-tracking-wide tw-text-slate-500">Search</h3>
        <div class="tw-flex tw-flex-wrap tw-items-center tw-gap-2">
          <input type="search" placeholder="One word or space-separated phrase…" autocomplete="off" class="tw-min-w-0 tw-flex-1 tw-rounded-lg tw-border tw-border-slate-200 tw-bg-white tw-px-3 tw-py-2 tw-text-sm tw-text-slate-900" data-svg-mushaf-target="searchInput" data-action="keydown.enter->svg-mushaf#search">
          <button type="button" class="tw-rounded-lg tw-bg-amber-600 tw-px-3 tw-py-2 tw-text-xs tw-font-semibold tw-text-white hover:tw-bg-amber-700" data-action="click->svg-mushaf#search">Search</button>
          <button type="button" class="tw-rounded-lg tw-border tw-border-slate-200 tw-bg-white tw-px-3 tw-py-2 tw-text-xs tw-font-medium tw-text-slate-700 hover:tw-bg-slate-50" data-action="click->svg-mushaf#clearSearch">Clear search</button>
          <span class="tw-text-xs tw-font-medium tw-text-slate-600" data-svg-mushaf-target="matchCount"></span>
        </div>
      </div>
    </div>
  </aside>
</div>
