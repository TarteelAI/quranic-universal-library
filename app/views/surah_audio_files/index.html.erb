<%
  recitations = @presenter.recitations
  audio_files = @presenter.audio_files
%>

<%= render 'tools/header',
           name: 'Surah recitations',
           title: @recitation.humanize,
           key: 'surah_recitation_segment_builder'
%>

<%= render 'shared/access_message' %>

<div class="page-wrapper container max-w-7xl mx-auto px-4">
  <div class="page-section filters">
    <div class="flex flex-wrap gap-4">
      <div class="col-lg-12">
        <%= form_tag surah_audio_files_path, method: :get do %>
          <div data-controller="chapter-verses-filter" class="flex flex-wrap">
            <%= render 'shared/filters', verse: false %>

            <div class="mb-4 me-2">
              <%= select_tag :recitation_id, options_for_select(recitations, params[:recitation_id]), class: 'form-select w-[85vw] sm:w-auto', data: { controller: 'select2' } %>
              <p class="text-sm text-gray-600 mt-1">Filter by recitation</p>
            </div>

            <div class="mb-4">
              <%= submit_tag 'Filter', class: 'btn btn-success', data: { disable_with: 'Please wait..' } %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="page-section mt-4">
    <h2 class="text-2xl mb-4">Surah list</h2>
    <div class="tools-table-overflow">
    <table class="w-full hover:bg-gray-50">
      <thead class="sticky top-0 z-10 bg-white border-b-2 border-black">
      <tr>
        <th>
          <%= sort_order_link 'Surah', :chapter_id, recitation_id: @recitation.id %>
        </th>
        <th class="truncate whitespace-nowrap">Segment Progress</th>
        <th>Actions</th>
      </tr>
      </thead>

      <tbody>
      <% audio_files.each do |file| %>
        <tr class="hover:bg-gray-200 border-b">
          <th scope="row" class="py-2 pl-2 text-left">
            <%= file.chapter_id %> - <%= file.chapter&.name_simple %>
          </th>

          <td class="py-2">
            <% progress = [file.segment_progress, 100].min %>
            <div class="w-full bg-gray-200 rounded-full h-6">
              <div class="h-6 rounded-full text-white text-xs flex items-center justify-center transition-all duration-300 bg-green-500"
                   role="progressbar"
                   aria-valuenow="<%= progress %>"
                   aria-valuemin="0"
                   aria-valuemax="100"
                   style="width: <%= progress %>%; min-width: 30px"
              >
                <%= progress %>%
              </div>
            </div>
          </td>

          <td class="py-2">
            <div class="flex gap-1">
              <%= link_to 'Show', surah_audio_file_path(@recitation.id, chapter_id: file.chapter_id), class: 'btn btn-success whitespace-normal' %>
              <%= link_to 'Fix Segments', segment_builder_surah_audio_file_path(@recitation.id, chapter_id: file.chapter_id), class: 'btn btn-success whitespace-normal' %>
            </div>
          </td>
        </tr>
      <% end %>
      </tbody>
    </table>
    </div>
  </div>
</div>


