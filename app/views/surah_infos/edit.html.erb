<%
  resource = @presenter.resource
  resource_content = resource.resource_content
%>

<%= render 'tools/header',
           name: 'Surah Information',
           title: "Update #{resource_content.name} For Surah #{resource.chapter.name_simple}",
           key: 'surah_info'
%>

<%= render 'shared/access_message' %>

<div class="page-wrapper container max-w-7xl mx-auto px-4">
  <div class="page-section">
    <%= form_with model: resource, url: surah_info_path(resource.id), method: :put, html: { class: 'form formtastic', autocomplete: 'off', id: 'info-form' } do |form| %>
      <div class="mb-4 mb-3">
        <%= form.label :short_text, class: 'form-label h2' %>
        <%= form.text_area :short_text, class: 'w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500', row: 2 %>
      </div>

      <div class="mb-4">
        <%= form.label :text, 'Surah Info text', class: 'form-label h2' %>
        <%= form.text_area :text, class: 'w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500', id: 'editor', required: true, autofocus: true, data: { controller: 'tinymce' } %>
      </div>

      <div class="mb-4 flex justify-end mt-3 gap-3">
        <%= link_to 'Cancel', surah_info_path(resource.id), class: 'px-4 py-2 text-sm font-medium bg-gray-200 hover:bg-gray-300 text-gray-800 rounded transition-colors' %>
        <%= form.submit "Save Surah Info", class: 'btn btn-success btn-sm', data: { disable_with: 'Please wait...' } %>
      </div>
    <% end %>
  </div>
</div>
