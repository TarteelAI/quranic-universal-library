<%
  records = @presenter.resources
  resource = @presenter.resource_content
  language = @presenter.language
  available_languages = @presenter.available_languages
%>

<%= render 'tools/header',
           name: 'Surah Information',
           title: "Proofread Surah info for #{language.name} language",
           key: 'surah_info',
           resource: resource
%>

<%= render 'shared/access_message' %>

<div class="page-wrapper container max-w-7xl mx-auto px-4">
  <div class="page-section filters">
    <%= form_tag surah_infos_path, method: :get do %>
      <div data-controller="chapter-verses-filter" class="flex flex-wrap">
        <div class="mb-4 me-2">
          <%= select_tag :language_id,
                         options_from_collection_for_select(available_languages, :id, :name, selected: language.id),
                         include_blank: false, class: 'form-select w-[85vw] sm:w-[200px]',
                         data: { placeholder: 'Select language', controller: 'select2' }
          %>
          <p class="text-sm text-gray-600 mt-1">Filter by language</p>
        </div>

        <%= render 'shared/filters', verse: false %>

        <div class="mb-4">
          <%= submit_tag 'Filter', class: 'btn btn-success', data: { disable_with: 'Please wait..' } %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="page-section mt-4">
    <h2 class="text-2xl mb-4">Surah list</h2>
    <div class="tools-table-overflow">
    <table class="w-full hover:bg-gray-50">
      <thead class="sticky top-0 z-10 bg-white border-b-2 border-black">
      <tr>
        <th><%= sort_order_link 'Surah', :chapter_id, resource_id: resource.id %></th>
        <th>Language</th>
        <th>Short text</th>
        <th>Actions</th>
      </tr>
      </thead>

      <tbody>
      <% records.each do |info| %>
        <tr class="hover:bg-gray-200 border-b">
          <th scope="row" class="py-2 pl-2 text-left">
            <%= info.chapter_id %> - <%= info.chapter.name_simple %>
          </th>

          <td class="py-2">
            <%= info.language_name %>
          </td>

          <td class="py-2">
            <%= truncate (info.short_text.presence || info.text).to_s, length: 200 %>
          </td>

          <td class="py-2">
            <div class="flex gap-1">
              <%= link_to 'Edit', edit_surah_info_path(info.id), class: 'btn btn-info' if @access %>
              <%= link_to 'Show', surah_info_path(info.id), class: 'btn btn-success' %>
            </div>
          </td>
        </tr>
      <% end %>
      </tbody>
    </table>
    </div>
  </div>
</div>
