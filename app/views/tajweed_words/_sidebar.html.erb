<%
  page_number = @word.page_number
  new_tajweed_img_host = "https://static-cdn.tarteel.ai/qul/images/page/daralmarfiah-tajweed"
%>


<div class="fixed top-0 left-0 h-full w-full max-w-md bg-white shadow-xl z-[999] transform transition-transform duration-300 ease-in-out hidden"
     tabindex="-1" id="tajweed-rules-sidebar"
     aria-labelledby="tajweed-paletee"
     data-controller="offcanvas"
     data-offcanvas-target="offcanvas"
     style="transform: translateX(-100%);">
  <div class="flex items-center justify-between p-4 border-b">
    <h5 class="text-lg font-semibold" id="tajweed-paletee">Tajweed Rule Palette</h5>
    <button type="button" class="absolute top-2 right-2 text-gray-400 hover:text-gray-900 bg-transparent hover:bg-gray-200 rounded-lg p-1.5 inline-flex items-center justify-center transition-colors" data-action="click->offcanvas#toggle" aria-label="Close">
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
      </svg>
    </button>
  </div>

  <div class="p-4 overflow-y-auto" style="max-height: calc(100vh - 80px);">
    <div class="tajweed-palette">
      <% documentation = tajweed.documentation %>
      <% tajweed.rules.each_with_index do |r, i| %>
        <%
          key = r[0]
          rule = documentation[key.to_sym]
        %>

        <div class="py-2 border-b border-gray-300">
          <div class="flex">
            <span class="me-2">
              <%= i + 1 %>
            </span>
            <span class="tajweed-new tajweed-rule-icon <%= key %>"></span>
            <span class="ms-2">
              <%= key %>
            </span>

            <span class="ms-auto">
              <%= link_to 'View detail', tajweed_rule_path(key), target: '_blank' %>
            </span>
          </div>

          <div class="flex items-center justify-between">
            <span>
              Letters
            </span>
            <span class="qpc-hafs" style="font-size: 20px">
               <%= rule[:rule_letters] %>
            </span>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div class="fixed top-0 left-0 h-full w-[90%] bg-white shadow-xl z-[999] transform transition-transform duration-300 ease-in-out hidden"
     tabindex="-1"
     id="tajweed-page-sidebar"
     aria-labelledby="tajweed-page"
     data-controller="offcanvas"
     data-offcanvas-target="offcanvas"
     style="transform: translateX(-100%);">
  <div class="flex items-center justify-between p-4 border-b">
    <h5 class="text-lg font-semibold" id="tajweed-page">
      Page <span class="page-number"><%= page_number %></span>
    </h5>
    <button type="button" class="absolute top-2 right-2 text-gray-400 hover:text-gray-900 bg-transparent hover:bg-gray-200 rounded-lg p-1.5 inline-flex items-center justify-center transition-colors" data-action="click->offcanvas#toggle" aria-label="Close">
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
      </svg>
    </button>
  </div>

  <div class="p-4 overflow-y-auto" style="max-height: calc(100vh - 80px);">
    <div class="text-center flex">
      <div class="p-4 text-center zoomable"
           data-controller="zoom-image"
           data-page="<%= page_number %>"
           data-host="<%= new_tajweed_img_host %>"
      >
        <label for="zoom-slider" class="block text-sm font-medium text-gray-700 mb-1">New Tajweed page</label>
        <input type="range" class="form-range" min="1" max="3" step="0.1" id="zoom-slider" value="1"/>
        <div class="flex justify-between">
          <button class="btn btn-primary" id="previous-page">Previous Page</button>
          <button class="btn btn-primary" id="next-page">Next page</button>
        </div>

        <div id="image-container" class="mt-4 p-4">
          <img id="zoom-image" data-controller="lazy-load" width="100%" data-src="<%= new_tajweed_img_host %>/<%= page_number %>.jpg" />
        </div>
      </div>
    </div>
  </div>
</div>