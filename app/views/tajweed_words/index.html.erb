<%= render 'tools/header',
           name: "Tajweed",
           title: "Tajweed rules tool",
           key: 'tajweed'
%>

<div class="page-wrapper container max-w-7xl mx-auto px-4">
  <div class="page-section filters">
    <%= form_tag tajweed_words_path, method: :get, class: 'flex' do %>
      <div class="flex flex-wrap gap-4" data-controller="chapter-verses-filter">
        <div class="flex flex-col sm:flex-row flex-wrap space-y-4 sm:space-y-0">
          <% if false %>
            <div class="mb-4 me-2">
              <%= select_tag :filter_tajweed_rule_old, options_for_select(tajweed_rule_options_for_select(TajweedRules.new, display: 'name'), params[:filter_tajweed_rule_old]), include_blank: true, class: 'form-select w-[100%]', data: { placeholder: 'Filter by tajweed rule(old)', controller: 'select2' } %>
              <p class="text-sm text-gray-600 mt-1">Filter by Tajweed rule(old)</p>
            </div>
          <% end %>
          <div class="mb-4 me-2">
            <%= select_tag :filter_tajweed_rule_new, options_for_select(tajweed_rule_options_for_select(TajweedRules.new('new'), display: 'name'), params[:filter_tajweed_rule_new]), include_blank: true, class: 'form-select w-[100%] border-gray-400 rounded-[5px]', data: { placeholder: 'Filter by tajweed rule(new)', controller: 'select2' } %>
            <p class="text-sm text-gray-600 mt-1">Filter by Tajweed rule</p>
          </div>

          <div class="mb-4 me-2">
            <%= text_field_tag :filter_text, params[:filter_text], class: 'form-control border-gray-400 rounded-[5px] h-[38px]' %>
            <p class="text-sm text-gray-600 mt-1">Filter by text</p>
          </div>

          <div class="mb-4 me-2">
            <div class="flex space-y-4 sm:space-y-0 flex-col sm:flex-row">
              <%= text_field_tag :filter_regexp_start, params[:filter_regexp_start], placeholder: 'Start with', class: 'form-control me-2  w-[100%] sm:w-auto border-gray-400 rounded-[5px] h-[38px]'%>
              <%= text_field_tag :filter_regexp_end, params[:filter_regexp_end], placeholder: 'Ends with', class: 'form-control me-2 w-[100%] sm:w-auto border-gray-400 rounded-[5px] h-[38px]'%>
              <label for="filter_word_boundary">
                <%= check_box_tag :filter_word_boundary, '1', params[:filter_word_boundary] == '1' %>
                Filter whole word
              </label>
            </div>
            <p class="text-sm text-gray-600 mt-1 mb-4 sm:mb-0">Filter by Regexp(Find word that start and ends with specific letter)</p>
          </div>
        </div>

        <div class="flex space-y-4 sm:space-y-0 flex-col sm:flex-row w-[100%]">
          <%= render 'shared/filters', page: true %>

          <div class="mb-4 ms-auto">
            <%= submit_tag 'Filter', class: 'btn btn-success', data: { disable_with: 'Please wait..' } %>
            <%= link_to 'Clear', tajweed_words_path, class: 'text-gray-900 hover:text-gray-700 hover:underline' if has_filters?(:filter_page, :filter_chapter, :filter_verse, :filter_text, :filter_tajweed_rule) %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="page-section mt-4">
    <h2 class="text-2xl mb-4">Words</h2>
    <div class= "tools-table-overflow">
    <table class="w-full hover:bg-gray-50">
      <thead class="sticky top-0 z-10 bg-white border-b-2 border-black">
      <tr>
        <th><%= sort_order_link 'Word index', :word_index %></th>
        <th>Location</th>
        <th>QPC Hafs</th>
        <th class="truncate whitespace-nowrap">Digital Khatt</th>
        <th>Text(old)</th>
        <th>Text(new)</th>
        <th class="truncate whitespace-nowrap">V4 Tajweed Img</th>
        <th class="truncate whitespace-nowrap">RQ Tajweed Img</th>
        <th>Actions</th>
      </tr>
      </thead>

      <tbody>
      <% @words.each do |word| %>
        <tr class="hover:bg-gray-200 border-b">
          <td class="py-2 pl-2">
            <%= link_to word.word_index, tajweed_word_path(word.location) %>
          </td>

          <td class="py-2 text-left">
            <%= word.location %>
          </td>
          <td class="py-2 qpc-hafs">
            <%= word.text_qpc_hafs %>
          </td>
          <td class="py-2 digitalkhatt">
            <%= word.text_digital_khatt %>
          </td>

          <td class="py-2 qpc-hafs" data-controller="tajweed-highlight">
            <%= safe_html word.text_uthmani_tajweed %>
          </td>

          <td class="py-2 qpc-hafs tajweed-new" data-controller="tajweed-highlight">
            <%= safe_html word.text_qpc_hafs_tajweed %>
          </td>

          <td class="py-2" style="text-align: right">
            <%= image_tag word.tajweed_v4_image_url, style: 'max-height: 70px' %>
          </td>

          <td class="py-2" style="text-align: right">
            <% s, a, w = word.location.split(':') %>
            <%= link_to "https://recitequran.com/#{s}:#{a}/w#{w}", target: '_blank' do %>
              <%= image_tag word.rq_tajweed_image_url, style: 'max-height: 70px' %>
            <% end %>
          </td>

          <td class="py-2 text-right">
            <div class="flex gap-1">
              <%= link_to 'Show', tajweed_word_path(word.location), class: 'btn btn-success' %>
            </div>
          </td>
        </tr>
      <% end %>

      <tr>
        <td colspan="7">
          <%= pagination_section @pagy %>
        </td>
      </tr>
      </tbody>
    </table>
  </div>
</div>
</div>


