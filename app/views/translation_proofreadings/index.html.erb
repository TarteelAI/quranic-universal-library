<%= render 'tools/header',
           name: "Ayah translation",
           title: @presenter.page_title,
           # title: 'Ayah translation proofreading',
           key: 'ayah_translation'
%>

<div class="page-wrapper container max-w-7xl mx-auto px-4">
  <div class="page-section filters">
    <%= form_tag translation_proofreadings_path, method: :get do %>
      <div data-controller="chapter-verses-filter" class="flex flex-wrap">
        <div class="mb-4 me-2">
          <%= select_tag :resource_id, options_from_collection_for_select(@ayah_translations, :id, :humanize, selected: @resource.id), include_blank: false, class: 'form-select w-[85vw] sm:w-[200px]', data: { placeholder: 'Select translation', controller: 'select2' } %>
          <p class="text-sm text-gray-600 mt-1">Select the translation</p>
        </div>

        <%= render 'shared/filters' %>

        <div class="mb-4 me-2">
          <%= text_field_tag :query, params[:query], class: 'form-control w-[85vw] sm:w-[200px] border-gray-400 rounded-[5px] h-[38px]', placeholder: 'Search' %>
          <p class="text-sm text-gray-600 mt-1">Search translation content</p>
        </div>

        <div class="mb-4">
          <%= submit_tag 'Filter', class: 'btn btn-success', data: { disable_with: 'Please wait..' } %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="page-section mt-4">
    <h2><%= @resource.name %></h2>
    <div class="tools-table-overflow">
    <table class="w-full hover:bg-gray-50">
      <thead class="sticky top-0 z-10 bg-white border-b-2 border-black">
      <tr>
        <th><%= sort_order_link 'Ayah key', :verse_key, resource_id: @resource.id %></th>
        <th>Footnotes</th>
        <th>Resource</th>
        <th>Text</th>
        <th>Actions</th>
      </tr>
      </thead>
      <tbody>
      <% @translations.each do |translation| %>
        <tr class="hover:bg-gray-200 border-b">
          <td scope="row" class="py-2 pl-2"><%= translation.verse.verse_key %></td>
          <td class="py-2">
            <%= translation.foot_notes.size %>
          </td>
          <td class="py-2">
            <%= translation.resource_name %>
          </td>
          <td class="py-2" dir="<%= @resource.language&.direction %>">
            <%= safe_html translation.text %>
          </td>
          <td class="py-2">
            <div class="flex gap-1">
              <%= link_to 'Edit', edit_translation_proofreading_path(translation.verse_id, resource_id: @resource.id), class: 'btn btn-info' %>
              <%= link_to 'Show', translation_proofreading_path(translation.verse_id, resource_id: @resource.id), class: 'btn btn-success' %>
            </div>
          </td>
        </tr>
      <% end %>
      <tr>
        <td colspan="4">
          <%= pagination_section @pagy %>
        </td>
      </tr>
      </tbody>
    </table>
    </div>
  </div>
</div>
