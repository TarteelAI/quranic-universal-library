<%= render 'tools/header',
           name: "Quran corpus tool",
           title: "Quran Word By Word Data Concordance Labeling, POS and grammar tagging",
           key: 'corpus'
%>

<div class="page-wrapper container max-w-7xl mx-auto px-4">
  <div class="page-section filters">
    <%= form_tag word_concordance_labels_path, method: :get do %>
      <div data-controller="chapter-verses-filter" class="flex flex-wrap">
        <%= render 'shared/filters', juz: true %>

        <div class="mb-4">
          <%= submit_tag 'Filter', class: 'btn btn-success', data: { disable_with: 'Please wait..' } %>
          <%= link_to 'Clear', word_concordance_labels_path, class: 'text-gray-900 hover:text-gray-700 hover:underline' if has_filters?(:filter_verse, :filter_chapter, :filter_juz) %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="page-section mt-4">
    <h2 class="text-2xl mb-4">Ayah list</h2>
    <div class="tools-table-overflow">
    <table class="w-full hover:bg-gray-50">
      <thead class="sticky top-0 z-10 bg-white border-b-2 border-black">
      <tr>
        <th><%= sort_order_link 'Ayah#', :id %></th>
        <th>Key</th>
        <th>Text</th>
        <th>Actions</th>
      </tr>
      </thead>

      <tbody>
      <% @verses.each do |verse| %>
        <tr class="hover:bg-gray-200 border-b">
          <th scope="row" class="py-2 pl-2"><%= verse.id %></th>
          <td class="py-2"><%= verse.verse_key %></td>
          <td class="py-2 me_quran">
            <%= verse.text_uthmani %>
          </td>

          <td class="py-2">
            <div class="d-grid">
              <%= link_to 'Show', word_concordance_label_path(verse.id), class: 'btn btn-success' %>
            </div>
          </td>
        </tr>
      <% end %>

      <tr>
        <td colspan="4">
          <%= pagination_section @pagy %>
        </td>
      </tr>
      </tbody>
    </table>
    </div>
  </div>
</div>