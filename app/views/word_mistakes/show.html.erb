<%
  page_number = @presenter.page_number
%>

<%= render 'layouts/qul_head' %>

<div class="container mx-auto px-4 py-6">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-3xl font-bold">Mistake Heatmap - Page <%= page_number %></h1>
    <div class="flex gap-4">
      <% if page_number > 1 %>
        <%= link_to "Previous Page", mistake_heatmap_path(page_number: page_number - 1), class: "px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-600" %>
      <% end %>
      <% if page_number < 604 %>
        <%= link_to "Next Page", mistake_heatmap_path(page_number: page_number + 1), class: "px-4 py-2 bg-blue-500 text-white rounded hover:bg-blue-600" %>
      <% end %>
      <%= link_to "Edit Mistakes", edit_mistake_heatmap_path(page_number: page_number), class: "btn btn-success" %>
    </div>
  </div>

  <div class="flex justify-center items-center min-h-[calc(100vh-250px)] py-8">
    <div class="theme-light mushaf text-qpc-hafs">

      <div class="page-wrapper container max-w-7xl mx-auto px-4 flex">
        <%= render 'page_preview' %>
      </div>
    </div>
  </div>
</div>