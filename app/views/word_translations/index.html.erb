<%
  words_count = Word.count
  word_translation_count = WordTranslation.where(language_id: current_language.id).size
  missing_words = words_count - word_translation_count
%>

<%= render 'tools/header',
           name: "Word translation proofreading",
           title: "#{current_language.name} word-by-word translation <div style='font-size: 0.5em'>Total Words: #{words_count}<br>With Translations: #{word_translation_count} <br>Missing: #{link_to missing_words, word_translations_path(language_id: current_language.id, filter_missing: true)} </div>",
           key: 'word_translation'
%>

<div class="page-wrapper container max-w-7xl mx-auto px-4">
  <div class="page-section filters">
    <%= form_tag word_translations_path, method: :get do %>
      <div data-controller="chapter-verses-filter" class="flex flex-wrap">
        <%= hidden_field_tag :language, current_language.id %>

        <div class="mb-4 me-2">
          <%= select_tag :language, options_from_collection_for_select(@word_translation_languages, :id, :name, selected: current_language.id), include_blank: false, class: 'form-select w-[85vw] sm:w-[200px]', data: { placeholder: 'Select language', controller: 'select2' } %>
          <p class="text-sm text-gray-600 mt-1">Select language</p>
        </div>

        <%= render 'shared/filters', juz: true %>

        <div class="mb-4">
          <%= submit_tag 'Filter', class: 'btn btn-success', data: { disable_with: 'Please wait..' } %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="page-section mt-4">
    <h2 class="text-2xl mb-4">Ayahs</h2>
    <div class="tools-table-overflow">
    <table class="w-full hover:bg-gray-50">
      <thead class="sticky top-0 z-10 bg-white border-b-2 border-black">
      <tr>
        <th><%= sort_order_link 'Ayah key', :verse_key %></th>
        <th>Progress</th>
        <th>Text</th>
        <th>Actions</th>
      </tr>
      </thead>
      <tbody>
      <% @verses.each do |verse| %>
        <tr class="hover:bg-gray-200 border-b">
          <th scope="row" class="py-2 pl-2"><%= verse.verse_key %></th>

          <% progress = verse.word_translation_progress(current_language.id) %>
          <td class="py-2">
            <div class="w-full bg-gray-200 rounded-full h-6">
              <div class="bg-green-500 h-6 rounded-full text-white text-xs flex items-center justify-center transition-all duration-300" role="progressbar" aria-valuenow="<%= progress %>" aria-valuemin="0" aria-valuemax="100" style="min-width: 1em;width: <%= progress %>%;">
                <%= progress %>%
              </div>
            </div>
          </td>

          <td class="py-2 qpc-hafs">
            <%= truncate verse.text_qpc_hafs, length: 100 %>
          </td>

          <td class="py-2">
            <div class="flex gap-1">
              <%= link_to 'Edit', new_word_translation_path(ayah: verse.id, language: current_language.id), class: 'btn btn-info' %>
              <%= link_to 'Show', word_translation_path(verse.id, language: current_language.id), class: 'btn btn-success' %>
            </div>
          </td>
        </tr>
      <% end %>
      <tr>
        <td colspan="4">
          <%= pagination_section @pagy %>
        </td>
      </tr>
      </tbody>
    </table>
    </div>
  </div>
</div>
