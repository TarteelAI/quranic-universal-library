#!/usr/bin/env sh

# Ensure rbenv is available even when shell init files were not loaded.
if [ -d "${HOME}/.rbenv" ]; then
  export PATH="${HOME}/.rbenv/bin:${PATH}"
fi

if command -v rbenv >/dev/null 2>&1; then
  # Avoid hard failure from rehash under strict shells; fallback for older rbenv.
  eval "$(rbenv init - --no-rehash 2>/dev/null || rbenv init -)"
fi

# Enforce this repository's pinned Ruby for all bin/dev subprocesses.
if [ -f ".ruby-version" ] && command -v rbenv >/dev/null 2>&1; then
  export RBENV_VERSION="$(cat .ruby-version)"
fi
